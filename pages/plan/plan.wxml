<!-- pages/plan/plan.wxml -->
<view class="container plan-page">
  <!-- 页面标题区 -->
  <view class="page-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <text class="header-title">📋计划管理</text>
      <text class="header-subtitle">管理您的班次模板</text>
    </view>
  </view>

  <!-- 班次列表卡片 -->
  <view class="card shift-list-card">
    <view class="card-header">
      <view class="card-icon">📋</view>
      <text class="card-title">班次列表</text>
      <view class="card-action">
        <button type="default" class="add-template-btn" bindtap="showAddTemplateModal">添加班次模板</button>
      </view>
    </view>
    <view class="template-list">
      <view class="template-item" wx:for="{{shiftTemplates}}" wx:key="index" style="background-color:{{item.color}}20">
        <view class="template-content">
          <view class="template-left">
            <view class="template-header">
              <text class="template-name" style="color:{{item.color}}">{{item.name}}</text>
              <text class="template-type" style="background-color:{{item.color}}">{{item.type}}</text>
            </view>
            <view class="template-details">
              <text class="work-hours">工时: {{item.workHours}}小时</text>
              <text class="time-range">时间: {{item.startTime}} - {{item.endTime}}</text>
            </view>
          </view>
          <view class="template-actions">
            <button type="default" class="edit-btn" bindtap="showEditTemplateModal" data-index="{{index}}">编辑</button>
            <button type="default" class="delete-btn" bindtap="deleteTemplate" data-index="{{index}}">删除</button>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{shiftTemplates.length === 0}}" class="empty-tip">
      暂无班次模板，请添加
    </view>
  </view>

  <!-- 添加模板弹窗 -->
  <block wx:if="{{showAddTemplate}}">
    <view class="modal-mask show" bindtap="hideAddTemplateModal" catchtouchmove="true"></view>
    <view class="modal-content show" catchtouchmove="true">
      <view class="modal-header">
        <view class="modal-header-left">
          <text class="modal-header-icon">📋</text>
          <text class="modal-title">添加班次模板</text>
        </view>
        <view class="modal-close" bindtap="hideAddTemplateModal">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="form-group">
          <view class="label-row">
            <text class="label">班次名称</text>
            <text class="label-required">*</text>
          </view>
          <input class="input" placeholder="请输入班次名称" placeholder-class="input-placeholder" bindinput="onTemplateInput" data-field="name" value="{{newTemplate.name || ''}}" />
        </view>
        <view class="form-group">
          <text class="label">班次类型</text>
          <picker mode="selector" range="{{shiftTypes}}" bindchange="onTypeChange" value="{{newTemplate.typeIndex}}">
            <view class="picker">
              <text class="picker-text">{{shiftTypes[newTemplate.typeIndex]}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <view class="form-group">
          <color-picker
            presetColors="{{presetColors}}"
            colorNames="{{colorNames}}"
            value="{{newTemplate.color}}"
            bind:change="onColorChange"
            data-mode="add"
          />
        </view>
        <view class="form-group">
          <text class="label">时间段</text>
          <view class="time-pair">
            <view class="time-pair-col">
              <text class="time-pair-label">开始</text>
              <picker class="time-picker" mode="time" value="{{newTemplate.startTime}}" bindchange="onTemplateInput" data-field="startTime">
                <view class="picker picker-time">
                  <text class="picker-text">{{newTemplate.startTime}}</text>
                </view>
              </picker>
            </view>
            <view class="time-pair-col">
              <text class="time-pair-label">结束</text>
              <picker class="time-picker" mode="time" value="{{newTemplate.endTime}}" bindchange="onTemplateInput" data-field="endTime">
                <view class="picker picker-time">
                  <text class="picker-text">{{newTemplate.endTime}}</text>
                </view>
              </picker>
            </view>
          </view>
        </view>
        <view class="form-group">
          <text class="label">工时</text>
          <view class="time-input-container">
            <picker class="time-picker" mode="selector" range="{{hoursRange}}" bindchange="onHoursChange" value="{{newTemplate.hoursIndex}}">
              <view class="picker picker-time">
                <text class="picker-text">{{hoursRange[newTemplate.hoursIndex || 0]}} 小时</text>
              </view>
            </picker>
            <picker class="time-picker" mode="selector" range="{{minutesRange}}" bindchange="onMinutesChange" value="{{newTemplate.minutesIndex}}">
              <view class="picker picker-time">
                <text class="picker-text">{{minutesRange[newTemplate.minutesIndex || 0]}} 分钟</text>
              </view>
            </picker>
          </view>
          <view class="work-hours-display">
            <text class="work-hours-text">工时总计：</text>
            <text class="work-hours-value">{{newTemplate.workHours}} 小时</text>
          </view>
        </view>
        <view class="modal-footer">
          <button class="cancel-btn" bindtap="hideAddTemplateModal">取消</button>
          <button class="confirm-btn" bindtap="saveTemplate" disabled="{{!newTemplate.name}}">保存</button>
        </view>
      </view>
    </view>
  </block>

  <!-- 编辑模板弹窗 -->
  <block wx:if="{{showEditTemplate}}">
    <view class="modal-mask show" bindtap="hideEditTemplateModal" catchtouchmove="true"></view>
    <view class="modal-content show" catchtouchmove="true">
      <view class="modal-header">
        <view class="modal-header-left">
          <text class="modal-header-icon">✏️</text>
          <text class="modal-title">编辑班次模板</text>
        </view>
        <view class="modal-close" bindtap="hideEditTemplateModal">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="form-group">
          <view class="label-row">
            <text class="label">班次名称</text>
            <text class="label-required">*</text>
          </view>
          <input class="input" placeholder="请输入班次名称" placeholder-class="input-placeholder" bindinput="onEditTemplateInput" data-field="name" value="{{editTemplate.name || ''}}" />
        </view>
        <view class="form-group">
          <text class="label">班次类型</text>
          <picker mode="selector" range="{{shiftTypes}}" bindchange="onEditTypeChange" value="{{editTemplate.typeIndex}}">
            <view class="picker">
              <text class="picker-text">{{shiftTypes[editTemplate.typeIndex]}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <view class="form-group">
          <color-picker
            presetColors="{{presetColors}}"
            colorNames="{{colorNames}}"
            value="{{editTemplate.color}}"
            bind:change="onColorChange"
            data-mode="edit"
          />
        </view>
        <view class="form-group">
          <text class="label">时间段</text>
          <view class="time-pair">
            <view class="time-pair-col">
              <text class="time-pair-label">开始</text>
              <picker class="time-picker" mode="time" value="{{editTemplate.startTime}}" bindchange="onEditTemplateInput" data-field="startTime">
                <view class="picker picker-time">
                  <text class="picker-text">{{editTemplate.startTime}}</text>
                </view>
              </picker>
            </view>
            <view class="time-pair-col">
              <text class="time-pair-label">结束</text>
              <picker class="time-picker" mode="time" value="{{editTemplate.endTime}}" bindchange="onEditTemplateInput" data-field="endTime">
                <view class="picker picker-time">
                  <text class="picker-text">{{editTemplate.endTime}}</text>
                </view>
              </picker>
            </view>
          </view>
        </view>
        <view class="form-group">
          <text class="label">工时</text>
          <view class="time-input-container">
            <picker class="time-picker" mode="selector" range="{{hoursRange}}" bindchange="onEditHoursChange" value="{{editTemplate.hoursIndex}}">
              <view class="picker picker-time">
                <text class="picker-text">{{hoursRange[editTemplate.hoursIndex || 0]}} 小时</text>
              </view>
            </picker>
            <picker class="time-picker" mode="selector" range="{{minutesRange}}" bindchange="onEditMinutesChange" value="{{editTemplate.minutesIndex}}">
              <view class="picker picker-time">
                <text class="picker-text">{{minutesRange[editTemplate.minutesIndex || 0]}} 分钟</text>
              </view>
            </picker>
          </view>
          <view class="work-hours-display">
            <text class="work-hours-text">工时总计：</text>
            <text class="work-hours-value">{{editTemplate.workHours}} 小时</text>
          </view>
        </view>
        <view class="modal-footer">
          <button class="cancel-btn" bindtap="hideEditTemplateModal">取消</button>
          <button class="confirm-btn" bindtap="saveEditTemplate" disabled="{{!editTemplate.name}}">保存</button>
        </view>
      </view>
    </view>
  </block>

    
</view>