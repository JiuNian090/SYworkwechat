/* pages/plan/plan.wxss */
/* 主色变量和统一按钮样式 */
.main-color {
  color: #07c160;
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(7,193,96,0.08);
}
.btn-primary:active {
  background: #059e4d;
}
.modal {
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12);
}
.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 20rpx 0;
}

.template-list {
  margin-top: 30rpx;
}

.template-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.template-item:hover {
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-2rpx);
}

.template-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx dashed #eee;
}

.template-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: flex;
  align-items: center;
}

.template-name::before {
  content: "●";
  margin-right: 12rpx;
  font-size: 36rpx;
}

.template-type {
  font-size: 26rpx;
  color: #fff;
  background: #07c160;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

.template-detail {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #666;
  margin-top: 12rpx;
  padding: 16rpx 0;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.template-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 20rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #eee;
}

.edit-btn, .delete-btn {
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  font-size: 26rpx;
  border: none;
  min-width: 80rpx;
  text-align: center;
}

.edit-btn {
  background-color: #e6f7ff;
  color: #1890ff;
  border: 1rpx solid #91d5ff;
}

.delete-btn {
  background-color: #fff1f0;
  color: #ff4d4f;
  border: 1rpx solid #ffa39e;
}

.select-checkbox {
  margin-left: auto;
  transform: scale(1.3);
}

.time-input-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.time-range-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.time-picker {
  flex: 1;
}

.time-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  flex: 1;
  margin-right: 10rpx;
}

.time-separator {
  font-size: 28rpx;
  color: #666;
  margin: 0 10rpx;
}

.work-hours-display {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
  text-align: right;
}

.picker {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  flex: 1;
  background: #fff;
}

.delete-btn {
  margin-top: 20rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 28rpx;
  border-radius: 10rpx;
}

.add-button {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
}

.add-btn {
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 10rpx;
  padding: 20rpx 0;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  width: 80%;
  border-radius: 10rpx;
  padding: 30rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 10rpx;
  color: #333;
}

.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.picker {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.select-all-btn, .reverse-select-btn {
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  margin-right: 20rpx;
  font-weight: 500;
}

.reverse-select-btn {
  background: #faad14;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  margin: 0 10rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.cancel-btn {
  background: #f0f0f0;
  color: #666;
}

.confirm-btn {
  background: #07c160;
  color: #fff;
}

.empty-tip {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
  font-size: 28rpx;
  padding: 80rpx 0;
  background: #fafafa;
  border-radius: 16rpx;
  border: 1rpx dashed #e0e0e0;
}

.empty-tip::before {
  content: "📅";
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}