/* pages/plan/plan.wxss */
/* 主色变量和统一按钮样式 */
.main-color {
  color: #07c160;
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(7,193,96,0.08);
}
.btn-primary:active {
  background: #059e4d;
}
.modal {
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12);
}
.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 20rpx 0;
}

.template-list {
  margin-top: 30rpx;
  padding: 0 10rpx;
}

.template-item {
  position: relative;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  border: 1rpx solid #f0f0f0;
}



.template-item:hover {
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-4rpx);
}

.template-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.template-left {
  flex: 1;
}

.template-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.template-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  display: flex;
  align-items: center;
  line-height: 1.4;
  margin-right: 20rpx;
}

.template-name::before {
  content: "●";
  margin-right: 16rpx;
  font-size: 28rpx;
}

.template-type {
  font-size: 26rpx;
  color: #fff;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  font-weight: 600;
  box-shadow: 0 3rpx 10rpx rgba(24, 144, 255, 0.2);
  white-space: nowrap;
}

.template-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.work-hours, .time-range {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.template-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-end;
  gap: 20rpx;
  margin-left: 20rpx;
}

.edit-btn, .delete-btn {
  padding: 2rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
  min-width: 80rpx;
  text-align: center;
  transition: all 0.3s ease;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.edit-btn {
  background-color: #bae7ff;
  color: #096dd9;
  border: 1rpx solid #40a9ff;
}

.edit-btn:active {
  background-color: #91d5ff;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.15);
  transform: translateY(1rpx);
}

.delete-btn {
  background-color: #ffccc7;
  color: #cf1322;
  border: 1rpx solid #ff7875;
}

.delete-btn:active {
  background-color: #ff9c9c;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.15);
  transform: translateY(1rpx);
}

.select-checkbox {
  margin-left: auto;
  transform: scale(1.3);
}

.time-input-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.time-range-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.time-picker {
  flex: 1;
}

.time-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  flex: 1;
  margin-right: 10rpx;
}

.time-separator {
  font-size: 28rpx;
  color: #666;
  margin: 0 10rpx;
}

.work-hours-display {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
  text-align: right;
}

.picker {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  flex: 1;
  background: #fff;
}



.add-button {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 30%;
}

.add-btn {
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  padding: 6rpx 0;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.add-btn:active {
  background: #059e4d;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
  transform: translateY(2rpx);
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  width: 85%;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 12rpx;
  color: #333;
  font-weight: 500;
}

.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.input:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 2rpx rgba(7, 193, 96, 0.2);
  outline: none;
}

.picker {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}

.picker:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 2rpx rgba(7, 193, 96, 0.2);
  outline: none;
}

.select-all-btn, .reverse-select-btn {
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  margin-right: 20rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.select-all-btn:active, .reverse-select-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.25);
}

.reverse-select-btn {
  background: #faad14;
  box-shadow: 0 4rpx 12rpx rgba(250, 173, 20, 0.3);
}

.reverse-select-btn:active {
  box-shadow: 0 2rpx 8rpx rgba(250, 173, 20, 0.25);
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  gap: 20rpx;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
  text-align: center;
  transition: all 0.3s ease;
  font-weight: 500;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

.cancel-btn:active {
  background: #e0e0e0;
  transform: translateY(1rpx);
}

.confirm-btn {
  background: #07c160;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.confirm-btn:active {
  background: #059e4d;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.25);
  transform: translateY(1rpx);
}

.empty-tip {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
  font-size: 28rpx;
  padding: 80rpx 0;
  background: #fafafa;
  border-radius: 16rpx;
  border: 1rpx dashed #e0e0e0;
}

.empty-tip::before {
  content: "📅";
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}