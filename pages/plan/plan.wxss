/* pages/plan/plan.wxss */
.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.template-list {
  margin-top: 30rpx;
}

.template-item {
  background: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.template-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.template-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.template-type {
  font-size: 28rpx;
  color: #666;
  background: #f0f0f0;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
}

.template-detail {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

.delete-btn {
  margin-top: 20rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 28rpx;
  border-radius: 10rpx;
}

.add-button {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
}

.add-btn {
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 10rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  width: 80%;
  border-radius: 10rpx;
  padding: 30rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 10rpx;
  color: #333;
}

.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.picker {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  margin: 0 10rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.cancel-btn {
  background: #f0f0f0;
  color: #666;
}

.confirm-btn {
  background: #07c160;
  color: #fff;
}

.empty-tip {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
  font-size: 28rpx;
}