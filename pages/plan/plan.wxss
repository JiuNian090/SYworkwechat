/* pages/plan/plan.wxss */
/* CSS Variables - 统一设计系统 */
page {
  --primary-color: #34d399;
  --primary-light: #6ee7b7;
  --primary-dark: #10b981;
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #e5e5e5;
  --shadow-color: rgba(0, 0, 0, 0.08);

  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

/* 主色变量和统一按钮样式 */
.main-color {
  color: #34d399;
}
.btn-primary {
  background: #34d399;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(52,211,153,0.08);
}
.btn-primary:active {
  background: #10b981;
}
.modal {
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12);
}
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 页面标题区 - 与profile页面头像标题区一致 */
.page-header {
  position: relative;
  margin: 30rpx 30rpx 30rpx;
  padding: 71rpx 30rpx 71rpx;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  border-bottom: 2rpx solid var(--border-color);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border-radius: 24rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* 卡片基础样式 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin: 30rpx 30rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
  position: relative;
  z-index: 2;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  width: 48rpx;
  height: 48rpx;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.card-action {
  margin-left: auto;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 20rpx 0;
}

.section-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  padding: 10rpx 0 10rpx 20rpx;
  text-align: left;
  position: relative;
  flex: 1;
}

.section-title::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
  width: 6rpx;
  height: 60%;
  background-color: #07c160;
  border-radius: 3rpx;
}

.title-icon {
  margin-right: 10rpx;
  color: #07c160;
  vertical-align: middle;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 30rpx 0 20rpx 0;
}

.add-template-btn {
  background: #07c160 !important;
  color: #fff !important;
  font-size: 28rpx;
  border-radius: 30rpx;
  padding: 2rpx 16rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
  border: none !important;
  white-space: nowrap;
  min-width: 120rpx;
  text-align: center;
}

.add-template-btn::after {
  border-radius: 30rpx;
  border: none;
}

.template-list {
  margin-top: 30rpx;
  padding: 0 10rpx;
}

.template-item {
  position: relative;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  border: 1rpx solid #f0f0f0;
}



.template-item:hover {
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-4rpx);
}

.template-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.template-left {
  flex: 1;
}

.template-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.template-name {
    font-size: 32rpx;
    font-weight: 700;
    color: #333;
    display: flex;
    align-items: center;
    line-height: 1.3;
    margin-right: 16rpx;
  }

.template-name::before {
    content: "●";
    margin-right: 16rpx;
    font-size: 28rpx;
  }

.template-header {
    display: flex;
    align-items: center;
    margin-bottom: 12rpx;
  }

.template-type {
    font-size: 22rpx;
    color: #fff;
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
    font-weight: 600;
    box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.2);
    white-space: nowrap;
  }

.template-details {
    display: flex;
    flex-direction: column;
    gap: 6rpx;
  }

.work-hours, .time-range {
    font-size: 24rpx;
    color: #666;
    line-height: 1.4;
  }

.template-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-end;
  gap: 20rpx;
  margin-left: 20rpx;
}

.edit-btn, .delete-btn {
  padding: 0rpx 20rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  min-width: 80rpx;
  text-align: center;
  font-weight: 500;
  height: 50rpx;
  line-height: 50rpx;
  background-size: 100% 100%;
  background-repeat: no-repeat;
}

.edit-btn {
  background-color: #bae7ff !important;
  color: #096dd9 !important;
  border: 1rpx solid #40a9ff !important;
}

.edit-btn::after {
  border-radius: 30rpx;
  border: none;
}

.delete-btn {
  background-color: #ffccc7 !important;
  color: #cf1322 !important;
  border: 1rpx solid #ff7875 !important;
}

.delete-btn::after {
  border-radius: 30rpx;
  border: none;
}

.select-checkbox {
  margin-left: auto;
  transform: scale(1.3);
}

.time-input-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.time-range-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.time-picker {
  flex: 1;
}

.time-separator {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin: 0 10rpx;
  font-weight: 500;
}

.work-hours-display {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
  text-align: right;
  font-weight: 500;
}

.picker {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  flex: 1;
  background: #fff;
}



.add-button {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 30%;
}

.add-btn {
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  padding: 6rpx 0;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.add-btn:active {
  background: #059e4d;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
  transform: translateY(2rpx);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  width: 85%;
  max-width: 640rpx;
  background: var(--card-bg);
  border-radius: 24rpx;
  z-index: 1001;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translate(-50%, -50%) scale(0.9);
}

.modal-content.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.modal-close:active {
  background: rgba(255, 255, 255, 0.3);
}

.close-icon {
  font-size: 28rpx;
  color: #ffffff;
}

.modal-body {
  padding: 20rpx;
  overflow-y: auto;
  flex: 1;
}

.form-group {
  margin-bottom: 20rpx;
  padding: 0 24rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 12rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.input {
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  transition: all 0.3s ease;
  background: #fff;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.input:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 2rpx rgba(52, 211, 153, 0.2);
  outline: none;
}

.picker {
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.3s ease;
  background: #fff;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.picker:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 2rpx rgba(52, 211, 153, 0.2);
  outline: none;
}

.select-all-btn, .reverse-select-btn {
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  margin-right: 20rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.select-all-btn:active, .reverse-select-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.25);
}

.reverse-select-btn {
  background: #faad14;
  box-shadow: 0 4rpx 12rpx rgba(250, 173, 20, 0.3);
}

.reverse-select-btn:active {
  box-shadow: 0 2rpx 8rpx rgba(250, 173, 20, 0.25);
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  gap: 20rpx;
  padding: 0 24rpx 24rpx;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  border-radius: 40rpx;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  transition: all 0.3s ease;
  font-weight: 500;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

.cancel-btn:active {
  background: #e0e0e0;
  transform: translateY(1rpx);
}

.confirm-btn {
  background: #07c160;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.confirm-btn:active {
  background: #059e4d;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.25);
  transform: translateY(1rpx);
}

.confirm-btn:disabled {
  background: #b3b3b3;
  box-shadow: none;
}

.confirm-btn:disabled:active {
  background: #b3b3b3;
  transform: none;
}

.empty-tip {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
  font-size: 28rpx;
  padding: 80rpx 0;
  background: #fafafa;
  border-radius: 16rpx;
  border: 1rpx dashed #e0e0e0;
}

.empty-tip::before {
  content: "📅";
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* 颜色条选择器样式 */
.color-bar-container {
  padding: 20rpx 0;
}

.label-container {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.color-indicator {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  margin-left: 20rpx;
  border: 2rpx solid #e0e0e0;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.color-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  margin-left: 20rpx;
  border: 2rpx solid #e0e0e0;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

.color-bar {
  position: relative;
  height: 60rpx;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.2);
}

.color-slider {
  width: 100%;
  height: 100%;
}

.slider-indicator {
  position: absolute;
  top: 50%;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #ffffff;
  border: 4rpx solid #ffffff;
  box-shadow: 0 0 10rpx rgba(0, 0, 0, 0.5);
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 2;
}