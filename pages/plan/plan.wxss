/* pages/plan/plan.wxss */
/* CSS Variables - 统一设计系统 */
.plan-page {
  --primary-color: #34d399;
  --primary-light: #6ee7b7;
  --primary-dark: #10b981;
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #e5e5e5;
  --shadow-color: rgba(0, 0, 0, 0.08);

  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  min-height: 100vh;
}

/* 主色变量和统一按钮样式 */
.main-color {
  color: #34d399;
}
.btn-primary {
  background: #34d399;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(52,211,153,0.08);
}
.btn-primary:active {
  background: #10b981;
}
.modal {
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12);
}
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
  opacity: 1;
  transition: opacity 0.2s ease-in-out;
}

/* 页面标题区 - 与profile页面头像标题区一致 */
.page-header {
  position: relative;
  margin: 30rpx 30rpx 30rpx;
  padding: 65rpx 30rpx 65rpx;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  border-bottom: 2rpx solid var(--border-color);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border-radius: 24rpx;
  opacity: 1;
  transform: translateY(0);
  transition: all 0.3s ease-in-out;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* 卡片基础样式 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin: 30rpx 30rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
  position: relative;
  z-index: 2;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  width: 48rpx;
  height: 48rpx;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.card-action {
  margin-left: auto;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 20rpx 0;
}

.section-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  padding: 10rpx 0 10rpx 20rpx;
  text-align: left;
  position: relative;
  flex: 1;
}

.section-title::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
  width: 6rpx;
  height: 60%;
  background-color: #07c160;
  border-radius: 3rpx;
}

.title-icon {
  margin-right: 10rpx;
  color: #07c160;
  vertical-align: middle;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 30rpx 0 20rpx 0;
}

.add-template-btn {
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%) !important;
  color: #fff !important;
  font-size: 28rpx;
  border-radius: 30rpx;
  padding: 2rpx 16rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
  border: none !important;
  white-space: nowrap;
  min-width: 120rpx;
  text-align: center;
}

.add-template-btn::after {
  border-radius: 30rpx;
  border: none;
}

.template-list {
  margin-top: 30rpx;
  padding: 0 10rpx;
}

.template-item {
  position: relative;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  border: 1rpx solid #f0f0f0;
}



.template-item:hover {
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-4rpx);
}

.template-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.template-left {
  flex: 1;
}

.template-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.template-name {
    font-size: 32rpx;
    font-weight: 700;
    color: #333;
    display: flex;
    align-items: center;
    line-height: 1.3;
    margin-right: 16rpx;
  }

.template-name::before {
    content: "●";
    margin-right: 16rpx;
    font-size: 28rpx;
  }

.template-header {
    display: flex;
    align-items: center;
    margin-bottom: 12rpx;
  }

.template-type {
    font-size: 22rpx;
    color: #fff;
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
    font-weight: 600;
    box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.2);
    white-space: nowrap;
  }

.template-details {
    display: flex;
    flex-direction: column;
    gap: 6rpx;
  }

.work-hours, .time-range {
    font-size: 24rpx;
    color: #666;
    line-height: 1.4;
  }

.template-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-end;
  gap: 20rpx;
  margin-left: 20rpx;
}

.edit-btn, .delete-btn {
  padding: 0rpx 20rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  min-width: 80rpx;
  text-align: center;
  font-weight: 500;
  height: 50rpx;
  line-height: 50rpx;
  background-size: 100% 100%;
  background-repeat: no-repeat;
}

.edit-btn {
  background-color: #bae7ff !important;
  color: #096dd9 !important;
  border: 1rpx solid #40a9ff !important;
}

.edit-btn::after {
  border-radius: 30rpx;
  border: none;
}

.delete-btn {
  background-color: #ffccc7 !important;
  color: #cf1322 !important;
  border: 1rpx solid #ff7875 !important;
}

.delete-btn::after {
  border-radius: 30rpx;
  border: none;
}

.select-checkbox {
  margin-left: auto;
  transform: scale(1.3);
}

.time-picker {
  flex: 1;
}

.picker {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  flex: 1;
  background: #fff;
}



.add-button {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 30%;
}

.add-btn {
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  padding: 6rpx 0;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.add-btn:active {
  background: #059e4d;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
  transform: translateY(2rpx);
}

/* ============ 弹窗 ============ */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.55);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  backdrop-filter: blur(4rpx);
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  width: 86%;
  max-width: 640rpx;
  background: #ffffff;
  border-radius: 28rpx;
  z-index: 1001;
  opacity: 0;
  visibility: hidden;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.25);
  max-height: 82vh;
  display: flex;
  flex-direction: column;
  transform: translate(-50%, -50%) scale(0.92) translateY(20rpx);
}

.modal-content.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1) translateY(0);
}

/* 弹窗头部 */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  border-radius: 28rpx 28rpx 0 0;
}

.modal-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.modal-header-icon {
  font-size: 32rpx;
  line-height: 1;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.modal-close {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.modal-close:active {
  background: rgba(255, 255, 255, 0.35);
  transform: scale(0.9);
}

.close-icon {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 300;
}

/* 弹窗内容 */
.modal-body {
  padding: 28rpx 0 0;
  overflow-y: auto;
  flex: 1;
}

/* ============ 表单组件 ============ */
.form-group {
  margin-bottom: 24rpx;
  padding: 0 32rpx;
}

.label-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.label-required {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: 700;
  line-height: 1;
}

.input {
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 26rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.25s ease;
  background: #fafafa;
  width: 100%;
  min-height: 88rpx;
  box-sizing: border-box;
}

.input:focus {
  border-color: #34d399;
  background: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(52, 211, 153, 0.12);
}

.input-placeholder {
  color: #bfbfbf;
}

/* 选择器 */
.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  background: #fafafa;
  transition: all 0.25s ease;
  min-height: 72rpx;
  box-sizing: border-box;
}

.picker:active {
  border-color: #34d399;
  background: #ffffff;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.picker-arrow {
  font-size: 36rpx;
  color: #bfbfbf;
  font-weight: 300;
  line-height: 1;
  margin-left: 8rpx;
}

.picker-time {
  justify-content: center;
}

/* 时间输入区域 - 工时 */
.time-input-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.time-input-container .picker-text {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.time-picker {
  flex: 1;
}

/* 时间段并排布局 */
.time-pair {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
}

.time-pair-col {
  flex: 1;
}

.time-pair-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  padding-left: 4rpx;
}

.time-pair-col .picker {
  width: 100%;
}

.time-pair-col .picker-text {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* 工时显示 */
.work-hours-display {
  margin-top: 12rpx;
  text-align: right;
  padding: 0 4rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
}

.work-hours-text {
  font-size: 24rpx;
  color: #999;
}

.work-hours-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #10b981;
}

/* ============ 弹窗底部按钮 ============ */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 8rpx 32rpx 32rpx;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  border-radius: 44rpx;
  font-size: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-weight: 600;
  border: none;
  transition: all 0.25s ease;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.cancel-btn:active {
  background: #e8e8e8;
  transform: scale(0.96);
}

.confirm-btn {
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(16, 185, 129, 0.35);
}

.confirm-btn:active {
  opacity: 0.9;
  transform: scale(0.96);
  box-shadow: 0 2rpx 12rpx rgba(16, 185, 129, 0.3);
}

.confirm-btn:disabled {
  background: #d9d9d9;
  box-shadow: none;
  opacity: 0.6;
}

.confirm-btn:disabled:active {
  background: #d9d9d9;
  transform: none;
  box-shadow: none;
}

.empty-tip {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
  font-size: 28rpx;
  padding: 80rpx 0;
  background: #fafafa;
  border-radius: 16rpx;
  border: 1rpx dashed #e0e0e0;
}

.empty-tip::before {
  content: "📅";
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .card {
    margin: 20rpx 20rpx 20rpx;
    padding: 20rpx;
  }
  
  .header-title {
    font-size: 40rpx;
  }
  
  .header-subtitle {
    font-size: 22rpx;
  }
  
  .card-title {
    font-size: 28rpx;
  }
  
  .template-name {
    font-size: 28rpx;
  }
  
  .work-hours, .time-range {
    font-size: 22rpx;
  }
  
  .edit-btn, .delete-btn {
    font-size: 24rpx;
    padding: 0rpx 16rpx;
  }
}

/* 平板设备适配 */
@media (min-width: 768px) {
  .card {
    margin: 40rpx 60rpx 40rpx;
    padding: 40rpx;
  }
  
  .header-title {
    font-size: 56rpx;
  }
  
  .header-subtitle {
    font-size: 32rpx;
  }
  
  .card-title {
    font-size: 36rpx;
  }
  
  .template-name {
    font-size: 36rpx;
  }
  
  .work-hours, .time-range {
    font-size: 28rpx;
  }
  
  .edit-btn, .delete-btn {
    font-size: 28rpx;
    padding: 0rpx 24rpx;
  }
  
  .modal-content {
    width: 70%;
    max-width: 800rpx;
  }
  
  .form-group {
    margin-bottom: 30rpx;
  }
  
  .label {
    font-size: 32rpx;
  }
  
  .input, .picker {
    font-size: 32rpx;
    padding: 24rpx;
  }
}

/* 横屏适配 */
@media (orientation: landscape) {
  .container {
    padding-bottom: 20rpx;
  }
  
  .page-header {
    margin: 20rpx 20rpx 20rpx;
    padding: 40rpx 30rpx 40rpx;
  }
  
  .card {
    margin: 0 20rpx 20rpx;
  }
  
  .template-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400rpx, 1fr));
    gap: 20rpx;
  }
  
  .template-item {
    margin-bottom: 0;
  }
  
  .template-content {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .template-actions {
    flex-direction: row;
    margin-left: 0;
    margin-top: 20rpx;
    width: 100%;
    justify-content: flex-end;
  }
  
  .edit-btn, .delete-btn {
    margin-right: 10rpx;
  }
}

/* 平板横屏适配 */
@media (min-width: 768px) and (orientation: landscape) {
  .template-list {
    grid-template-columns: repeat(auto-fit, minmax(500rpx, 1fr));
    gap: 30rpx;
  }
  
  .template-item {
    padding: 30rpx;
  }
  
  .template-header {
    margin-bottom: 20rpx;
  }
  
  .template-details {
    gap: 10rpx;
  }
  
  .work-hours, .time-range {
    font-size: 32rpx;
  }
  
  .edit-btn, .delete-btn {
    font-size: 32rpx;
    padding: 0rpx 32rpx;
    height: 60rpx;
    line-height: 60rpx;
  }
  
  .modal-content {
    width: 60%;
    max-width: 900rpx;
    max-height: 70vh;
  }
  
  .modal-body {
    padding: 30rpx;
  }
  
  .form-group {
    margin-bottom: 40rpx;
  }
  
  .label {
    font-size: 36rpx;
    margin-bottom: 16rpx;
  }
  
  .input, .picker {
    font-size: 36rpx;
    padding: 28rpx;
  }
  
  .modal-footer {
    margin-top: 30rpx;
  }
  
  .cancel-btn, .confirm-btn {
    font-size: 32rpx;
    height: 100rpx;
    line-height: 100rpx;
  }
}

/* ============ 颜色选择器 ============ */
.color-circles-container {
  padding: 6rpx 0;
}

.color-circles-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.color-circle-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
  position: relative;
  min-width: 0;
}

.color-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid #e8e8e8;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.color-circle-item:active .color-dot,
.color-circle-item:active .custom-color-entry {
  transform: scale(0.88);
}

.color-circle-item.active .color-dot,
.color-circle-item.active .custom-color-entry {
  border-color: #333;
  border-width: 4rpx;
  box-shadow: 0 0 0 4rpx rgba(0, 0, 0, 0.08), 0 2rpx 10rpx rgba(0, 0, 0, 0.18);
}

/* 自定义颜色入口 */
.custom-color-entry {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid #e8e8e8;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.custom-color-icon {
  font-size: 30rpx;
  font-weight: 700;
  color: #555;
  line-height: 1;
  position: relative;
  z-index: 1;
  text-shadow: 0 0 6rpx rgba(255,255,255,0.9);
}

.custom-color-overlay {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 0;
}

/* 颜色标签 */
.color-circle-label {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  white-space: nowrap;
  line-height: 1.3;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.color-circle-item.active .color-circle-label {
  color: #333;
  font-weight: 600;
}

/* 标签行：色块+名称 */
.label-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.color-indicator {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0,0,0,0.1);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.color-name-tag {
  font-size: 26rpx;
  font-weight: 600;
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(0,0,0,0.04);
  -webkit-font-smoothing: antialiased;
}

/* ============ 颜色调色器 ============ */
.color-picker-panel {
  margin-top: 12rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #f0f0f0;
}

.palette-container {
  margin-bottom: 14rpx;
}

.palette-area {
  position: relative;
  width: 100%;
  height: 220rpx;
  border-radius: 10rpx;
  overflow: hidden;
  cursor: pointer;
}

.palette-white {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to right, #fff 0%, transparent 100%);
  pointer-events: none;
}

.palette-black {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to top, #000 0%, transparent 100%);
  pointer-events: none;
}

.palette-cursor {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 0 8rpx rgba(0,0,0,0.6), inset 0 0 4rpx rgba(0,0,0,0.2);
  transform: translate(-50%, 50%);
  pointer-events: none;
  z-index: 5;
}

/* 色相滑块 */
.hue-slider-container {
  margin-top: 14rpx;
}

.hue-slider {
  position: relative;
  width: 100%;
  height: 36rpx;
  border-radius: 18rpx;
  background: linear-gradient(to right, #ff0000 0%, #ffff00 16%, #00ff00 33%, #00ffff 50%, #0000ff 67%, #ff00ff 83%, #ff0000 100%);
  cursor: pointer;
  box-shadow: inset 0 1rpx 4rpx rgba(0,0,0,0.1);
}

.hue-slider-thumb {
  position: absolute;
  top: 50%;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 0 8rpx rgba(0,0,0,0.45);
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 2;
}

/* 颜色预览区域 */
.picker-preview-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
  padding: 0 4rpx;
}

.picker-preview {
  width: 60rpx;
  height: 48rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e8e8e8;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  flex-shrink: 0;
}

.picker-hex-value {
  font-size: 28rpx;
  color: #555;
  font-family: 'Courier New', 'Consolas', monospace;
  font-weight: 600;
  letter-spacing: 1rpx;
  user-select: all;
}

/* 调色器按钮 */
.picker-actions {
  display: flex;
  gap: 16rpx;
}

.picker-cancel-btn, .picker-confirm-btn {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  font-size: 26rpx;
  border-radius: 34rpx;
  font-weight: 500;
  border: none;
  transition: all 0.2s ease;
}

.picker-cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.picker-cancel-btn:active {
  background: #e8e8e8;
  transform: scale(0.96);
}

.picker-confirm-btn {
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  color: #fff;
  box-shadow: 0 2rpx 10rpx rgba(16, 185, 129, 0.35);
}

.picker-confirm-btn:active {
  opacity: 0.9;
  transform: scale(0.96);
}