/* pages/docs/docs.wxss */

/* ========== 基础变量与重置 ========== */
page {
  --primary-color: #34d399;
  --primary-dark: #10b981;
  --primary-light: #d1fae5;
  --title-color: #1a1a1a;
  --text-color: #4a4a4a;
  --text-secondary: #8c8c8c;
  --tip-bg: #fff8e6;
  --tip-color: #f59e0b;
  --warning-bg: #fef2f2;
  --warning-color: #f87171;
  --bg-color: #f7f8fa;
  --card-bg: #ffffff;
  --border-color: #f0f0f0;
  --shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-hover: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ========== 顶部导航栏 - WeUI样式 ========== */
.nav-header {
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  margin: 30rpx 30rpx 30rpx;
  padding: 40rpx 30rpx 40rpx;
  text-align: center;
  border-bottom: 2rpx solid var(--border-color);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border-radius: 24rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.nav-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 12rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* ========== WeUI导航栏样式 ========== */
.weui-navbar {
  background: var(--card-bg);
  margin: 30rpx 24rpx 24rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  position: relative;
  z-index: 2;
  transition: all 0.3s ease;
  overflow: hidden;
}

.weui-navbar.fixed {
  position: fixed;
  top: 5rpx;
  left: 24rpx;
  right: 24rpx;
  margin: 0;
  z-index: 100;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  border-radius: var(--radius-lg);
}

/* 为固定导航添加顶部安全区域适配 */
.weui-navbar.fixed::before {
  content: '';
  position: absolute;
  top: -5rpx;
  left: 0;
  right: 0;
  height: calc(5rpx + env(safe-area-inset-top));
  background: transparent;
}

.weui-navbar.fixed .weui-navbar__content {
  padding-top: env(safe-area-inset-top);
}

.weui-navbar__wrapper {
  padding: 16rpx 24rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.weui-navbar__title {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
  text-align: center;
}

.weui-navbar__content {
  padding: 16rpx 24rpx;
}

.weui-tabbar {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.weui-tabbar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 12rpx;
  border-radius: var(--radius-md);
  transition: all 0.3s ease;
}

.weui-tabbar__item:active {
  background: var(--bg-color);
}

.weui-tabbar__item--active {
  color: var(--primary-color);
}

.weui-tabbar__icon {
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 40rpx;
}

.weui-tabbar__label {
  font-size: 22rpx;
  color: var(--text-color);
  font-weight: 500;
}

.weui-tabbar__item--active .weui-tabbar__label {
  color: var(--primary-color);
  font-weight: 600;
}

/* ========== 内容区域 ========== */
.content {
  padding: 0 24rpx;
}

/* ========== 区块卡片 ========== */
.section {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.section.highlight {
  border-color: var(--primary-color);
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.15);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.section-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.data-icon {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.webdav-icon {
  background: linear-gradient(135deg, #f0f5ff 0%, #f5f8ff 100%);
}

.stats-icon {
  background: linear-gradient(135deg, #f6ffed 0%, #f0fff0 100%);
}

.about-icon {
  background: linear-gradient(135deg, #fff7e6 0%, #fff9f0 100%);
}

.section-icon {
  font-size: 44rpx;
}

.section-title-wrapper {
  flex: 1;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--title-color);
  display: block;
  margin-bottom: 6rpx;
}

.section-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ========== 引导列表 ========== */
.guide-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.guide-list.compact {
  gap: 20rpx;
}

.guide-item {
  display: flex;
  gap: 16rpx;
}

.guide-item.warning {
  background: var(--warning-bg);
  padding: 20rpx;
  border-radius: var(--radius-md);
  margin: -8rpx;
}

.guide-item.compact-item {
  align-items: flex-start;
}

.guide-badge {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.25);
}

.guide-badge.small {
  width: 36rpx;
  height: 36rpx;
  font-size: 20rpx;
}

.guide-body {
  flex: 1;
}

.guide-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--title-color);
  display: block;
  margin-bottom: 8rpx;
}

.guide-text {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.7;
  display: block;
}

.guide-tip {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 16rpx;
  background: var(--tip-bg);
  border-radius: var(--radius-sm);
  border-left: 4rpx solid var(--tip-color);
}

.guide-tip.warning-tip {
  background: var(--warning-bg);
  border-left-color: var(--warning-color);
}

.tip-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: var(--tip-color);
  line-height: 1.5;
  flex: 1;
}

.warning-tip .tip-text {
  color: var(--warning-color);
}

/* ========== 步骤进度条 ========== */
.step-progress {
  position: relative;
  height: 40rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 60rpx;
}

.progress-line {
  position: absolute;
  left: 60rpx;
  right: 60rpx;
  height: 4rpx;
  background: var(--border-color);
  top: 50%;
  transform: translateY(-50%);
}

.progress-dot {
  width: 20rpx;
  height: 20rpx;
  background: var(--border-color);
  border-radius: 50%;
  position: relative;
  z-index: 1;
  border: 4rpx solid var(--card-bg);
}

.progress-dot.active {
  background: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.2);
}

/* ========== 步骤列表 ========== */
.step-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.step-item {
  display: flex;
  gap: 20rpx;
}

.step-number {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  opacity: 0.3;
  line-height: 1;
  flex-shrink: 0;
  width: 60rpx;
}

.step-content {
  flex: 1;
}

.step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--title-color);
  display: block;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 26rpx;
  color: var(--text-color);
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

/* ========== 图片包装器 ========== */
.image-wrapper {
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--bg-color);
  cursor: pointer;
}

.step-image {
  width: 100%;
  display: block;
  border-radius: var(--radius-md);
}

.image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
  display: flex;
  justify-content: center;
  align-items: center;
}

.image-hint {
  font-size: 24rpx;
  color: #ffffff;
  background: rgba(0, 0, 0, 0.4);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  backdrop-filter: blur(4rpx);
}

/* ========== 项目介绍区块 ========== */
.about-section {
  background: linear-gradient(135deg, #fff9f5 0%, #ffffff 100%);
}

.about-card {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 24rpx;
  border: 2rpx solid var(--border-color);
}

.about-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.about-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.about-item:first-child {
  padding-top: 0;
}

.about-icon-small {
  font-size: 32rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.about-text {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.7;
  flex: 1;
}

/* ========== 返回顶部按钮 ========== */
.back-to-top {
  position: fixed;
  right: 32rpx;
  bottom: 48rpx;
  width: 88rpx;
  height: 88rpx;
  background: var(--card-bg);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.3s ease;
  z-index: 100;
  border: 2rpx solid var(--border-color);
}

.back-to-top.visible {
  opacity: 1;
  transform: translateY(0);
}

.back-to-top:active {
  transform: scale(0.9);
  background: var(--bg-color);
}

.back-to-top-icon {
  font-size: 40rpx;
  color: var(--primary-color);
  font-weight: bold;
}

/* ========== 响应式适配 ========== */
@media (max-width: 375px) {
  .quick-nav-list {
    gap: 12rpx;
  }
  
  .quick-nav-item {
    padding: 16rpx 8rpx;
  }
  
  .nav-text {
    font-size: 20rpx;
  }
  
  .section {
    padding: 24rpx;
  }
  
  .section-title {
    font-size: 30rpx;
  }
  
  .guide-text,
  .about-text {
    font-size: 26rpx;
  }
}

@media (min-width: 768px) {
  .container {
    max-width: 750rpx;
    margin: 0 auto;
  }
  
  .quick-nav-list {
    justify-content: space-between;
    gap: 16rpx;
  }
  
  .quick-nav-item {
    flex: 1;
    padding: 24rpx 20rpx;
  }
}

/* ========== 动画效果 ========== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.section {
  animation: fadeInUp 0.4s ease-out;
}

.section:nth-child(1) { animation-delay: 0.05s; }
.section:nth-child(2) { animation-delay: 0.1s; }
.section:nth-child(3) { animation-delay: 0.15s; }
.section:nth-child(4) { animation-delay: 0.2s; }
