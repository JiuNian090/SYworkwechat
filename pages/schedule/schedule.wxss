/* pages/schedule/schedule.wxss */
/* 主色变量和统一按钮样式 */
.main-color {
  color: #07c160;
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(7,193,96,0.08);
}
.btn-primary:active {
  background: #059e4d;
}
.modal {
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12);
}
.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 20rpx 0;
}

.view-switch {
  display: flex;
  margin: 20rpx 0;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  background: #f5f5f5;
  padding: 4rpx;
  width: 100%;
}

.switch-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  background: #fff;
  color: #666;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
  border-radius: 26rpx;
  margin: 0 4rpx;
}

.switch-item:first-child {
  margin-left: 0;
}

.switch-item:last-child {
  margin-right: 0;
}

.switch-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #07c160;
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: -1;
  border-radius: 26rpx;
}

.switch-item.active {
  color: #fff;
  font-weight: 600;
}

.switch-item.active::before {
  opacity: 1;
}

.switch-item:not(.active):active {
  background: #f0f0f0;
  color: #333;
}

.week-header, .month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.month-header {
  width: 100%;
  display: flex;
  align-items: center;
}

.week-header {
  justify-content: space-between;
  gap: 20rpx;
}

.nav-btn {
  background: #fff;
  border: 1rpx solid #e0e0e0;
  padding: 2rpx 16rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  flex-shrink: 0;
  width: auto;
}

.month-header .nav-btn:first-child {
  /* 上一月按钮靠左 */
  margin-right: auto;
}

.month-header .nav-btn:last-child {
  /* 下一月按钮靠右 */
  margin-left: auto;
}

.month-title-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  min-width: 0;
  margin: 0 10rpx;
}

.month-header .current-month {
  flex: none;
  text-align: center;
}

.nav-btn:active {
  background: #f5f5f5;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
  transform: translateY(1rpx);
}

.current-week, .current-month {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  padding: 0 20rpx;
  text-align: center;
  letter-spacing: 2rpx; /* 增加字间距 */
  white-space: nowrap;
}

.month-header .current-month {
  flex: none;
  text-align: center;
}

.week-title-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  min-width: 0;
}

.current-week-highlight {
  color: #fff;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  box-shadow: 0 4rpx 8rpx rgba(7, 193, 96, 0.2);
  display: inline-block;
  min-width: auto;
  text-align: center;
  white-space: nowrap;
}

.current-month-highlight {
  color: #fff;
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  display: inline-block;
  min-width: auto;
  width: auto;
  text-align: center;
  white-space: nowrap;
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin: 0 auto;
}

.weekdays {
  display: flex;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #666;
}

/* 周视图 */
.week-view {
  border-radius: 30rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
  background: #fff;
  padding: 20rpx;
}

.week-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.week-grid {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.day-cell {
  width: 100%;
  min-height: 110rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
  display: flex;
  margin-bottom: 8rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: all 0.3s ease;
}

.day-cell:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.day-cell.today {
  box-shadow: 0 2rpx 12rpx rgba(7, 193, 96, 0.15);
}

.day-cell.today .day-header {
  color: #fff;
  background: #34d399;
  text-shadow: 0 0 2rpx rgba(0, 0, 0, 0.5);
}

.day-cell.today .weekday-text {
  font-weight: bold;
  color: #fff;
  text-shadow: 0 0 4rpx rgba(0, 0, 0, 0.7);
}

.day-cell.today .day-number {
  color: #fff;
  font-weight: bold;
  text-shadow: 0 0 2rpx rgba(0, 0, 0, 0.5);
}

.day-header {
  width: 80rpx;
  padding: 12rpx 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #e0e0e0;
  background: #fafafa;
  border-top-left-radius: 16rpx;
  border-bottom-left-radius: 16rpx;
}

.weekday-text {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.day-number {
  font-size: 20rpx;
  font-weight: normal;
  color: #666;
}

.day-content {
  flex: 1;
  padding: 8rpx;
  display: flex;
  flex-direction: column;
  height: 100%;
  box-sizing: border-box;
  align-items: stretch;
  justify-content: center;
}

.no-shift-text {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ccc;
  text-align: center;
  font-style: italic;
}

.shift-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin: 8rpx 4rpx;
  box-sizing: border-box;
  min-height: 110rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.shift-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.shift-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  text-align: left;
  padding-right: 10rpx;
}

.shift-time {
  font-size: 26rpx;
  color: #666;
  flex: 1;
  text-align: center;
}

.shift-hours {
  font-size: 28rpx;
  color: #000;
  flex: 1;
  text-align: right;
  font-weight: bold;
}

/* 月视图 */
.month-view {
  border-radius: 30rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
  background: #fff;
  padding: 20rpx;
}

.month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.month-grid {
  border: none;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.week-row {
  display: flex;
}

.month-view .day-cell {
  position: relative;
  height: 140rpx;
  padding: 0;
  display: block;
  transition: all 0.3s ease;
  border-radius: 12rpx;
  overflow: hidden;
}

.month-view .day-cell:active {
  transform: scale(0.95);
}

.month-view .day-cell.today {
  background: #e6f4ea;
  border: 3rpx solid #07c160;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
}

.month-view .day-number {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  z-index: 2;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  text-shadow: 0 0 4rpx rgba(255, 255, 255, 0.8);
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.month-view .day-cell.today .day-number {
  background: #07c160;
  color: #fff;
  font-weight: bold;
  width: 36rpx;
  height: 36rpx;
  font-size: 30rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.25);
  text-shadow: 0 0 2rpx rgba(0, 0, 0, 0.5);
}

.month-view .shift-info {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
  border-radius: 12rpx;
}

.month-view .shift-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: center;
  padding: 0 4rpx;
}

.month-view .overtime-tag {
  font-size: 14rpx;
  padding: 1rpx 4rpx;
  background: #ff4d4f;
  color: white;
  border-radius: 6rpx;
  margin-left: 4rpx;
}

.month-view .no-shift {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #ccc;
  font-style: italic;
  border-radius: 12rpx;
  border: 1rpx dashed #e0e0e0;
}

.day-cell.other-month {
  background: #f8f8f8;
  color: #ccc;
}

.month-view .day-cell.other-month .day-number {
  color: #ccc;
}

.shift-dot {
  width: 10rpx;
  height: 10rpx;
  background: #07c160;
  border-radius: 50%;
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  width: 80%;
  border-radius: 12rpx;
  padding: 20rpx;
  max-height: 70vh;
  overflow-y: auto;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.shift-list {
  max-height: 50vh;
  overflow-y: auto;
}

.shift-picker-container {
  text-align: center;
  margin-bottom: 20rpx;
  padding: 10rpx;
  background: #f8f8f8;
  border-radius: 10rpx;
}

.shift-picker-container picker-view {
  width: 100%;
  height: 200rpx !important;
}

.shift-picker-container picker-view-column {
  font-size: 32rpx;
  font-weight: bold;
}

.shift-picker-container button {
  margin-top: 20rpx;
  padding: 12rpx 20rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
}

.shift-item {
  padding: 12rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.shift-item:last-child {
  margin-bottom: 0;
}

.shift-detail {
  display: flex;
  justify-content: space-between;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.current-shift {
  margin-top: 20rpx;
  padding: 15rpx;
  background: #fff0f0;
  border-radius: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
}

.current-shift text {
  flex: 1;
  text-align: left;
}

.remove-btn {
  background: #ff4d4f;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-left: 10rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 30rpx 0;
}