/* pages/schedule/schedule.wxss */

/* CSS Variables - 统一设计系统 */
page {
  --primary-color: #07c160;
  --primary-light: #10b981;
  --primary-dark: #059669;
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #e5e5e5;
  --shadow-color: rgba(0, 0, 0, 0.08);
  --day-shift-color: #ff9500;
  --night-shift-color: #576b95;
  --off-day-color: #999999;
  --success-color: #07c160;
  --warning-color: #ff9500;
  --error-color: #fa5151;
  
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

/* 页面容器 */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 页面标题区 */
.page-header {
  position: relative;
  padding: 60rpx 30rpx 80rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 卡片基础样式 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
  animation: fadeInUp 0.5s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  width: 48rpx;
  height: 48rpx;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 视图切换卡片 */
.view-switch-card {
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
  padding: 20rpx;
}

.view-switch {
  display: flex;
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 6rpx;
}

.switch-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.switch-item:active {
  transform: scale(0.98);
}

.switch-item.active {
  background: var(--primary-color);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.switch-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.switch-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.switch-item.active .switch-text {
  color: #ffffff;
}

/* 导航卡片 */
.nav-card {
  padding: 20rpx;
}

.week-header, .month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.nav-btn:active {
  background: #e8e8e8;
  transform: scale(0.95);
}

.nav-icon {
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.nav-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin: 0 8rpx;
}

.week-title-container, .month-title-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.week-title-badge, .month-title-badge {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--bg-color);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.week-title-badge.current, .month-title-badge.current {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.week-title, .month-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.week-title-badge.current .week-title,
.month-title-badge.current .month-title {
  color: #ffffff;
}

.current-tag {
  font-size: 20rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.3);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
}

/* 周排班列表卡片 */
.week-list-card {
  padding: 20rpx;
}

.week-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.day-item {
  display: flex;
  border-radius: 16rpx;
  overflow: hidden;
  background: var(--bg-color);
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.day-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.day-item.today {
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.2);
}

.day-left {
  width: 100rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  border-right: 1rpx solid var(--border-color);
}

.day-item.today .day-left {
  background: var(--primary-color);
}

.day-weekday {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.day-item.today .day-weekday {
  color: #ffffff;
}

.day-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.day-item.today .day-date {
  color: rgba(255, 255, 255, 0.9);
}

.today-dot {
  width: 8rpx;
  height: 8rpx;
  background: #ffffff;
  border-radius: 50%;
  margin-top: 8rpx;
}

.day-right {
  flex: 1;
  padding: 16rpx;
  display: flex;
  align-items: center;
}

/* 班次信息卡片 */
.shift-info-card {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid;
}

.shift-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.shift-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.shift-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.shift-hours-badge {
  display: flex;
  align-items: baseline;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  margin-left: 16rpx;
}

.hours-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.hours-unit {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 4rpx;
}

/* 无排班 */
.no-shift {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.no-shift-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.no-shift-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 工时统计卡片 */
.stats-card {
  padding: 24rpx;
}

.stats-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stat-row {
  display: flex;
  align-items: center;
}

.stat-row.primary {
  justify-content: center;
  padding: 16rpx 0;
}

.stat-avatar {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-color);
  border-radius: 50%;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.stat-main {
  display: flex;
  align-items: baseline;
}

.stat-value {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.stat-unit {
  font-size: 28rpx;
  color: var(--primary-color);
  margin-left: 4rpx;
}

.stat-divider {
  font-size: 36rpx;
  color: var(--border-color);
  margin: 0 16rpx;
}

.stat-standard {
  font-size: 36rpx;
  color: var(--text-secondary);
}

/* 进度条 */
.progress-bar-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar-bg {
  flex: 1;
  height: 12rpx;
  background: var(--bg-color);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-bar-fill.under {
  background: linear-gradient(90deg, var(--primary-color) 0%, var(--primary-light) 100%);
}

.progress-bar-fill.over {
  background: linear-gradient(90deg, var(--warning-color) 0%, #ffb84d 100%);
}

.progress-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  white-space: nowrap;
}

/* 差额显示 */
.stat-row.secondary {
  justify-content: center;
  padding: 12rpx 24rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
}

.diff-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-right: 16rpx;
}

.diff-value {
  font-size: 32rpx;
  font-weight: 600;
}

.diff-value.over {
  color: var(--warning-color);
}

.diff-value.under {
  color: var(--error-color);
}

/* 图片管理卡片 */
.images-card {
  padding: 24rpx;
}

.images-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.images-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.image-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.image-item:active {
  background: #e8e8e8;
}

.image-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.image-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.image-name {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.image-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  transition: all 0.2s ease;
}

.action-btn.view {
  background: #e6f7ff;
  color: #1890ff;
}

.action-btn.view:active {
  background: #bae7ff;
}

.action-btn.delete {
  background: #fff2f0;
  color: #ff4d4f;
}

.action-btn.delete:active {
  background: #ffccc7;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 40rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
}

.empty-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 添加图片按钮 */
.add-image-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.add-image-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.add-image-btn .btn-icon {
  font-size: 32rpx;
  color: #ffffff;
  margin-right: 8rpx;
}

.add-image-btn .btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 月历卡片 */
.calendar-card {
  padding: 20rpx;
}

.weekdays-header {
  display: flex;
  margin-bottom: 16rpx;
}

.weekday-label {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.month-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.week-row {
  display: flex;
  gap: 12rpx;
}

.calendar-day {
  flex: 1;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: var(--bg-color);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.calendar-day:active {
  transform: scale(0.95);
}

.calendar-day.today {
  background: #e6f4ea;
  border: 2rpx solid var(--primary-color);
}

.calendar-day.other-month {
  opacity: 0.5;
}

.day-number-wrapper {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
}

.day-number {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.day-number.today-num {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-color);
  color: #ffffff;
  border-radius: 50%;
  font-size: 22rpx;
}

.day-shift-tag {
  position: absolute;
  bottom: 8rpx;
  left: 4rpx;
  right: 4rpx;
  padding: 6rpx 4rpx;
  border-radius: 8rpx;
  text-align: center;
}

.day-shift-tag.empty {
  background: transparent;
}

.shift-tag-name {
  font-size: 18rpx;
  color: #ffffff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.day-shift-tag.empty .shift-tag-name {
  color: var(--text-tertiary);
  font-size: 16rpx;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  min-height: 40rpx;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 85%;
  max-width: 640rpx;
  background: var(--card-bg);
  border-radius: 24rpx;
  z-index: 1001;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-content.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.modal-close:active {
  background: rgba(255, 255, 255, 0.3);
}

.close-icon {
  font-size: 28rpx;
  color: #ffffff;
}

.modal-body {
  padding: 30rpx;
  overflow-y: auto;
  flex: 1;
}

.modal-section {
  margin-bottom: 30rpx;
}

.modal-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 班次选择器 */
.shift-picker-container {
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
}

.picker-shift {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
  border: 2rpx solid;
  border-radius: 12rpx;
  background: #ffffff;
}

.picker-shift-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.picker-shift-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 当前排班卡片 */
.current-shift-card {
  padding: 30rpx;
  border-radius: 16rpx;
  border: 2rpx solid;
  margin-bottom: 20rpx;
}

.current-shift-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.current-shift-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.current-shift-time {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.current-shift-hours {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 模态框按钮 */
.modal-btn {
  width: 100%;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
}

.modal-btn.confirm-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
}

.modal-btn.confirm-btn:active {
  transform: scale(0.98);
}

.modal-btn.confirm-btn.disabled {
  background: #e0e0e0;
  color: #999;
}

.modal-btn.remove-btn {
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
  color: #ffffff;
}

.modal-btn.remove-btn:active {
  transform: scale(0.98);
}

.modal-btn.cancel-btn {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.modal-btn.cancel-btn:active {
  background: #e0e0e0;
}

/* 空状态提示 */
.empty-tip {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-tip .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-tip .empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.empty-tip .empty-subtext {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
}

/* 输入框 */
.input-group {
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  font-weight: 500;
  position: relative;
  z-index: 1;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  background: #ffffff;
  box-sizing: border-box;
  transition: all 0.2s ease;
  position: relative;
  z-index: 2;
}

.modal-input:focus {
  border-color: var(--primary-color);
  background: #ffffff;
}

/* 上传区域 */
.upload-section {
  margin-bottom: 30rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background: var(--bg-color);
  border: 2rpx dashed var(--border-color);
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.upload-placeholder:active {
  background: #e8e8e8;
  border-color: var(--primary-color);
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.upload-preview {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: all 0.2s ease;
}

.upload-preview:active .preview-overlay {
  opacity: 1;
}

.overlay-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
}

/* 模态框底部 */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding-top: 20rpx;
}

.modal-footer .modal-btn {
  flex: 1;
}

/* 操作菜单样式 */
.action-menu-content {
  max-height: 50vh;
}

.action-menu-body {
  padding: 20rpx 30rpx 40rpx;
}

.action-menu {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: var(--bg-color);
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.action-item:active {
  transform: scale(0.98);
  background: #e8e8e8;
}

.action-item.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.action-item.add {
  background: linear-gradient(145deg, #e6f7ff 0%, #f0f9ff 100%);
  border: 2rpx solid rgba(24, 144, 255, 0.2);
}

.action-item.add:active {
  background: linear-gradient(145deg, #bae7ff 0%, #e6f7ff 100%);
}

.action-item.delete {
  background: linear-gradient(145deg, #fff2f0 0%, #fff5f5 100%);
  border: 2rpx solid rgba(255, 77, 79, 0.2);
}

.action-item.delete:active {
  background: linear-gradient(145deg, #ffccc7 0%, #fff2f0 100%);
}

.action-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.action-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.action-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.action-item.add .action-title {
  color: #1890ff;
}

.action-item.delete .action-title {
  color: #ff4d4f;
}

.action-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.action-arrow {
  font-size: 40rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

/* 文件夹名称显示 - 始终在最上层 */
.image-modal-body {
  position: relative;
}

.folder-name-display {
  position: sticky;
  top: 0;
  z-index: 100;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.folder-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.folder-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .day-left {
    width: 80rpx;
    padding: 16rpx 8rpx;
  }
  
  .day-weekday {
    font-size: 24rpx;
  }
  
  .day-date {
    font-size: 20rpx;
  }
  
  .shift-name {
    font-size: 28rpx;
  }
  
  .shift-time {
    font-size: 22rpx;
  }
  
  .calendar-day {
    border-radius: 8rpx;
  }
  
  .shift-tag-name {
    font-size: 16rpx;
  }
}

@media (min-width: 768px) {
  .card {
    margin: 0 60rpx 40rpx;
  }
  
  .day-left {
    width: 120rpx;
  }
}
