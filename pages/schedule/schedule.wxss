/* pages/schedule/schedule.wxss */
/* 主色变量和统一按钮样式 */
.main-color {
  color: #07c160;
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(7,193,96,0.08);
}
.btn-primary:active {
  background: #059e4d;
}
.modal {
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12);
}
.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 20rpx 0;
}

.view-switch {
  display: flex;
  margin: 20rpx 0;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  background: #f5f5f5;
  padding: 4rpx;
  width: 100%;
}

.switch-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  background: #fff;
  color: #666;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
  border-radius: 26rpx;
  margin: 0 4rpx;
}

.switch-item:first-child {
  margin-left: 0;
}

.switch-item:last-child {
  margin-right: 0;
}

.switch-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #07c160;
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: -1;
  border-radius: 26rpx;
}

.switch-item.active {
  color: #fff;
  font-weight: 600;
}

.switch-item.active::before {
  opacity: 1;
}

.switch-item:not(.active):active {
  background: #f0f0f0;
  color: #333;
}

.week-header, .month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.month-header {
  width: 100%;
  display: flex;
  align-items: center;
}

.week-header {
  justify-content: space-between;
  gap: 20rpx;
}

.nav-btn {
  background: #fff;
  border: 1rpx solid #e0e0e0;
  padding: 2rpx 16rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  flex-shrink: 0;
  width: auto;
}

.month-header .nav-btn:first-child {
  /* 上一月按钮靠左 */
  margin-right: auto;
}

.month-header .nav-btn:last-child {
  /* 下一月按钮靠右 */
  margin-left: auto;
}

.month-title-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  min-width: 0;
  margin: 0 10rpx;
}

.month-header .current-month {
  flex: none;
  text-align: center;
}

.nav-btn:active {
  background: #f5f5f5;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
  transform: translateY(1rpx);
}

.current-week, .current-month {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  padding: 0 20rpx;
  text-align: center;
  letter-spacing: 2rpx; /* 增加字间距 */
  white-space: nowrap;
}

.month-header .current-month {
  flex: none;
  text-align: center;
}

.week-title-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  min-width: 0;
}

.current-week-highlight {
  color: #fff;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  box-shadow: 0 4rpx 8rpx rgba(7, 193, 96, 0.2);
  display: inline-block;
  min-width: auto;
  text-align: center;
  white-space: nowrap;
}

.current-month-highlight {
  color: #fff;
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  display: inline-block;
  min-width: auto;
  width: auto;
  text-align: center;
  white-space: nowrap;
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin: 0 auto;
}

.weekdays {
  display: flex;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #666;
}

/* 周视图 */
.week-view {
  border-radius: 30rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
  background: #fff;
  padding: 20rpx;
}

.week-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.week-grid {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.day-cell {
  width: 100%;
  min-height: 110rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
  display: flex;
  margin-bottom: 8rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: all 0.3s ease;
}

.day-cell:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.day-cell.today {
  box-shadow: 0 2rpx 12rpx rgba(7, 193, 96, 0.15);
}

.day-cell.today .day-header {
  color: #fff;
  background: #34d399;
  text-shadow: 0 0 2rpx rgba(0, 0, 0, 0.5);
}

.day-cell.today .weekday-text {
  font-weight: bold;
  color: #fff;
  text-shadow: 0 0 4rpx rgba(0, 0, 0, 0.7);
}

.day-cell.today .day-number {
  color: #fff;
  font-weight: bold;
  text-shadow: 0 0 2rpx rgba(0, 0, 0, 0.5);
}

.day-header {
  width: 80rpx;
  padding: 12rpx 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #e0e0e0;
  background: #fafafa;
  border-top-left-radius: 16rpx;
  border-bottom-left-radius: 16rpx;
}

.weekday-text {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.day-number {
  font-size: 20rpx;
  font-weight: normal;
  color: #666;
}

.day-content {
  flex: 1;
  padding: 8rpx;
  display: flex;
  flex-direction: column;
  height: 100%;
  box-sizing: border-box;
  align-items: stretch;
  justify-content: center;
}

.no-shift-text {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ccc;
  text-align: center;
  font-style: italic;
}

.shift-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin: 8rpx 4rpx;
  box-sizing: border-box;
  min-height: 110rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.shift-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.shift-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  text-align: left;
  padding-right: 10rpx;
}

.shift-time {
  font-size: 26rpx;
  color: #666;
  flex: 1;
  text-align: center;
}

.shift-hours {
  font-size: 28rpx;
  color: #000;
  flex: 1;
  text-align: right;
  font-weight: bold;
}

/* 月视图 */
.month-view {
  border-radius: 30rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
  background: #fff;
  padding: 20rpx;
}

.month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.month-grid {
  border: none;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.week-row {
  display: flex;
}

.month-view .day-cell {
  position: relative;
  height: 140rpx;
  padding: 0;
  display: block;
  transition: all 0.3s ease;
  border-radius: 12rpx;
  overflow: hidden;
}

.month-view .day-cell:active {
  transform: scale(0.95);
}

.month-view .day-cell.today {
  background: #e6f4ea;
  border: 3rpx solid #07c160;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
}

.month-view .day-number {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  z-index: 2;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  text-shadow: 0 0 4rpx rgba(255, 255, 255, 0.8);
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.month-view .day-cell.today .day-number {
  background: #07c160;
  color: #fff;
  font-weight: bold;
  width: 36rpx;
  height: 36rpx;
  font-size: 30rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.25);
  text-shadow: 0 0 2rpx rgba(0, 0, 0, 0.5);
}

.month-view .shift-info {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
  border-radius: 12rpx;
}

.month-view .shift-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: center;
  padding: 0 4rpx;
}

.month-view .overtime-tag {
  font-size: 14rpx;
  padding: 1rpx 4rpx;
  background: #ff4d4f;
  color: white;
  border-radius: 6rpx;
  margin-left: 4rpx;
}

.month-view .no-shift {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #ccc;
  font-style: italic;
  border-radius: 12rpx;
  border: 1rpx dashed #e0e0e0;
}

.day-cell.other-month {
  background: #f8f8f8;
  color: #ccc;
}

.month-view .day-cell.other-month .day-number {
  color: #ccc;
}

.shift-dot {
  width: 10rpx;
  height: 10rpx;
  background: #07c160;
  border-radius: 50%;
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  backdrop-filter: blur(10rpx);
  animation: modalBackdropFadeIn 0.3s ease-out;
}

.modal-content {
  background: #fff;
  width: 85%;
  max-width: 600rpx;
  border-radius: 24rpx;
  padding: 48rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
  animation: modalSlideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
  transform-origin: center center;
}

/* 遮罩层淡入动画 */
@keyframes modalBackdropFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 弹窗滑入动画 */
@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translateY(40rpx) scale(0.92);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* 弹窗滑出动画 */
@keyframes modalSlideOut {
  from {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  to {
    opacity: 0;
    transform: translateY(40rpx) scale(0.92);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
}

/* 关闭按钮样式优化 */
.modal-header icon {
  font-size: 36rpx;
  color: #999;
  transition: all 0.2s ease;
  padding: 8rpx;
  border-radius: 8rpx;
}

.modal-header icon:active {
  background-color: #f5f5f5;
  color: #666;
  transform: scale(0.9);
}

.shift-list {
  max-height: 50vh;
  overflow-y: auto;
}

.shift-picker-container {
  text-align: center;
  margin-bottom: 36rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 20rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
  border: 1rpx solid #e2e8f0;
}

/* 删除绿色径向渐变背景 */
.shift-picker-container::before {
  display: none;
}

.shift-picker-container picker-view {
  width: 100%;
  height: 240rpx !important;
  mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 80%, transparent 100%);
  -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 80%, transparent 100%);
  transition: all 0.3s ease;
  margin: 16rpx 0;
}

.shift-picker-container picker-view-column {
  font-size: 38rpx;
  font-weight: 600;
  color: #07c160;
  text-shadow: 0 2rpx 4rpx rgba(7, 193, 96, 0.15);
}

.shift-picker-container picker-view-column view[selected] {
  color: #059e4d;
  text-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
  font-weight: 700;
  transform: scale(1.05);
  transition: all 0.2s ease;
}

.shift-picker-container picker-view-column view {
  transition: all 0.3s ease;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 60rpx;
}

.shift-picker-container picker-view-column view:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* 删除淡淡的绿色指示器 */
.shift-picker-indicator {
  display: none;
}

.shift-picker-btn {
  background: linear-gradient(135deg, #07c160 0%, #059e4d 100%);
  color: #fff;
  font-size: 34rpx;
  border-radius: 16rpx;
  padding: 22rpx 0;
  font-weight: 600;
  box-shadow: 0 8rpx 16rpx rgba(7, 193, 96, 0.3);
  transition: all 0.3s ease;
  border: none;
  margin-top: 24rpx;
  letter-spacing: 1rpx;
}

.shift-picker-btn:active {
  background: #059e4d;
  box-shadow: 0 6rpx 12rpx rgba(7, 193, 96, 0.25);
  transform: translateY(3rpx);
}

.shift-picker-btn:hover {
  box-shadow: 0 10rpx 20rpx rgba(7, 193, 96, 0.4);
  transform: translateY(-3rpx);
}

.shift-item {
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.shift-item:hover {
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-2rpx);
}

.shift-item:last-child {
  margin-bottom: 0;
}

.shift-detail {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.current-shift {
  margin-top: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff0f0 0%, #ffe6e6 100%);
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.1);
  border: 1rpx solid #ffccc7;
}

.current-shift text {
  flex: 1;
  text-align: left;
  font-weight: 600;
  color: #333;
}

.remove-btn {
  background: #ff4d4f;
  color: #fff;
  font-size: 28rpx;
  padding: 14rpx 28rpx;
  border-radius: 14rpx;
  margin-left: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.3);
  transition: all 0.3s ease;
  font-weight: 600;
  border: none;
  white-space: nowrap;
}

.remove-btn:active {
  background: #f5222d;
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.25);
  transform: translateY(2rpx);
}

.remove-btn:hover {
  box-shadow: 0 6rpx 16rpx rgba(255, 77, 79, 0.4);
  transform: translateY(-2rpx);
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 30rpx;
  padding: 80rpx 40rpx;
  background: #fafafa;
  border-radius: 16rpx;
  border: 1rpx dashed #e0e0e0;
  margin: 24rpx 0;
  line-height: 1.5;
}

.empty-tip::before {
  content: "📅";
  display: block;
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

/* 表单样式优化 */
.form-group {
  margin-bottom: 36rpx;
  transition: all 0.3s ease;
}

.form-group:focus-within {
  transform: translateX(8rpx);
}

.label {
  display: block;
  font-size: 30rpx;
  margin-bottom: 16rpx;
  color: #333;
  font-weight: 600;
}

.input {
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  transition: all 0.3s ease;
  background: #fafafa;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.input:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.15);
  outline: none;
  background: #fff;
  transform: translateY(-1rpx);
}

.picker {
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #666;
  transition: all 0.3s ease;
  background: #fafafa;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  position: relative;
  overflow: hidden;
}

.picker::after {
  content: '>';
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #999;
  font-weight: bold;
}

.picker:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.15);
  outline: none;
  background: #fff;
  transform: translateY(-1rpx);
}

/* 按钮组样式 */
.modal-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  border-radius: 16rpx;
  font-size: 32rpx;
  padding: 22rpx 0;
  text-align: center;
  transition: all 0.3s ease;
  font-weight: 600;
  border: none;
  letter-spacing: 1rpx;
}

.cancel-btn {
  background: #f1f5f9;
  color: #64748b;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.cancel-btn:active {
  background: #e2e8f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
  transform: translateY(2rpx);
}

.cancel-btn:hover {
  background: #e2e8f0;
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.1);
}

.confirm-btn {
  background: linear-gradient(135deg, #07c160 0%, #059e4d 100%);
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(7, 193, 96, 0.3);
}

.confirm-btn:active {
  background: #059e4d;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.25);
  transform: translateY(2rpx);
}

.confirm-btn:hover {
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.4);
  transform: translateY(-2rpx);
}

.confirm-btn:disabled {
  background: #a7f3d0;
  color: #dcfce7;
  box-shadow: none;
  cursor: not-allowed;
  transform: none;
}

/* 颜色选择器样式优化 */
.color-bar-container {
  padding: 24rpx 0;
}

.label-container {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.color-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-left: 0;
  border: 3rpx solid #e2e8f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
  cursor: pointer;
}

.color-circle:active {
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.25);
}

.color-bar {
  position: relative;
  height: 64rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  cursor: pointer;
}

.color-slider {
  width: 100%;
  height: 100%;
  transition: all 0.3s ease;
}

.color-bar:active .color-slider {
  transform: scale(1.02);
}

.slider-indicator {
  position: absolute;
  top: 50%;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #ffffff;
  border: 4rpx solid #ffffff;
  box-shadow: 0 0 12rpx rgba(0, 0, 0, 0.5), 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 2;
  transition: all 0.2s ease;
}

.slider-indicator:active {
  transform: translate(-50%, -50%) scale(1.2);
  box-shadow: 0 0 16rpx rgba(0, 0, 0, 0.6), 0 6rpx 20rpx rgba(0, 0, 0, 0.4);
}

/* 时间选择器容器样式 */
.time-input-container,
.time-range-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.time-picker {
  flex: 1;
}

.time-separator {
  font-size: 32rpx;
  color: #94a3b8;
  font-weight: 600;
  width: 40rpx;
  text-align: center;
}

.work-hours-display {
  font-size: 30rpx;
  color: #64748b;
  margin-top: 16rpx;
  text-align: right;
  font-weight: 500;
  background: #f8fafc;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e2e8f0;
}

/* 滚动条样式优化 */
.modal-content::-webkit-scrollbar {
  width: 8rpx;
}

.modal-content::-webkit-scrollbar-track {
  background: #f1f5f9;
  border-radius: 4rpx;
}

.modal-content::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 4rpx;
}

.modal-content::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .modal-content {
    width: 92%;
    padding: 36rpx;
    border-radius: 20rpx;
  }
  
  .modal-title {
    font-size: 34rpx;
  }
  
  .shift-picker-container picker-view {
    height: 200rpx !important;
  }
  
  .shift-picker-container picker-view-column {
    font-size: 32rpx;
  }
}

/* 本周工时统计样式 */
.week-statistics {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: white;
  border-radius: 16rpx;
  padding: 15rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid #eee;
  flex-wrap: nowrap;
  width: 100%;
  box-sizing: border-box;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-avatar {
  font-size: 32rpx;
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
  white-space: nowrap;
}

.stat-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  background: #f0fff0;
  white-space: nowrap;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #d0f0d0;
}

.stat-value.overtime {
  color: #ff4d4f;
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
}

.stat-value.shortage {
  color: #1890ff;
  background: #e6f7ff;
  border: 1rpx solid #91d5ff;
}