/* pages/schedule/schedule.wxss */
/* 主色变量和统一按钮样式 */
.main-color {
  color: #07c160;
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(7,193,96,0.08);
}
.btn-primary:active {
  background: #059e4d;
}
.modal {
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12);
}
.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 20rpx 0;
}

.view-switch {
  display: flex;
  margin: 20rpx 0;
  border: 1rpx solid #07c160;
  border-radius: 10rpx;
  overflow: hidden;
}

.switch-item {
  flex: 1;
  text-align: center;
  padding: 15rpx;
  background: #fff;
  color: #07c160;
  font-size: 28rpx;
}

.switch-item.active {
  background: #07c160;
  color: #fff;
}

.week-header, .month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.week-header {
  justify-content: center;
  gap: 40rpx;
}

.nav-btn {
  background: #f0f0f0;
  border: none;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.current-week, .current-month {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.weekdays {
  display: flex;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #666;
}

/* 周视图 */
.week-grid {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.day-cell {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
  display: flex;
  margin-bottom: 4rpx;
  border-radius: 12rpx;
}

.day-cell.today {
  background: #e6f4ea;
  border-color: #07c160;
}

.day-header {
  width: 80rpx;
  padding: 8rpx 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #e0e0e0;
  background: #f8f8f8;
  border-top-left-radius: 12rpx;
  border-bottom-left-radius: 12rpx;
}

.weekday-text {
  font-size: 18rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.day-number {
  position: relative;
  top: auto;
  left: auto;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.day-content {
  flex: 1;
  padding: 8rpx;
  display: flex;
  flex-direction: column;
  height: 100%;
  box-sizing: border-box;
  align-items: stretch;
  justify-content: center;
}

.no-shift-text {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
  text-align: center;
}

.shift-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin: 4rpx;
  box-sizing: border-box;
  min-height: 100rpx;
}

.shift-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  text-align: left;
  padding-right: 10rpx;
}

.shift-time {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  text-align: center;
}

.shift-hours {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  text-align: right;
  font-weight: bold;
}

/* 月视图 */
.month-grid {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  overflow: hidden;
}

.week-row {
  display: flex;
}

.month-view .day-cell {
  position: relative;
  height: 80rpx;
  padding: 4rpx;
  display: block;
}

.month-view .day-number {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  z-index: 1;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  text-shadow: 0 0 2rpx rgba(255, 255, 255, 0.8);
}

.month-view .shift-info {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
}

.month-view .shift-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: center;
}

.month-view .overtime-tag {
  font-size: 14rpx;
  padding: 1rpx 4rpx;
  background: #ff4d4f;
  color: white;
  border-radius: 6rpx;
  margin-left: 4rpx;
}

.month-view .no-shift {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #999;
}

.day-cell.other-month {
  background: #f8f8f8;
  color: #ccc;
}

.month-view .day-cell.other-month .day-number {
  color: #ccc;
}

.shift-dot {
  width: 10rpx;
  height: 10rpx;
  background: #07c160;
  border-radius: 50%;
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  width: 80%;
  border-radius: 12rpx;
  padding: 30rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.shift-list {
  max-height: 50vh;
  overflow-y: auto;
}

.shift-picker-container {
  text-align: center;
  margin-bottom: 30rpx;
}

.shift-picker-container button {
  margin-top: 30rpx;
}

.shift-item {
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.shift-item:last-child {
  margin-bottom: 0;
}

.shift-detail {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.current-shift {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #fff0f0;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.remove-btn {
  background: #ff4d4f;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 30rpx 0;
}