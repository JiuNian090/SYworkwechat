<!-- pages/schedule/schedule.wxml -->
<view class="container">
  <!-- 页面标题区 -->
  <view class="page-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <text class="header-title">📅 排班管理</text>
      <text class="header-subtitle">查看和管理您的排班信息</text>
    </view>
  </view>

  <!-- 视图切换卡片 -->
  <view class="card view-switch-card">
    <view class="view-switch">
      <view class="switch-item {{currentView === 'week' ? 'active' : ''}}" data-view="week" bindtap="switchView">
        <text class="switch-icon">📊</text>
        <text class="switch-text">周视图</text>
      </view>
      <view class="switch-item {{currentView === 'month' ? 'active' : ''}}" data-view="month" bindtap="switchView">
        <text class="switch-icon">📅</text>
        <text class="switch-text">月视图</text>
      </view>
    </view>
  </view>

  <!-- 周视图 -->
  <view wx:if="{{currentView === 'week'}}" class="week-view-container">
    <!-- 周导航卡片 -->
    <view class="card nav-card">
      <view class="week-header">
        <view class="nav-btn" bindtap="prevWeek">
          <text class="nav-icon">‹</text>
          <text class="nav-text">上周</text>
        </view>
        <view class="week-title-container" bindtap="goToToday">
          <view class="week-title-badge {{isCurrentWeek ? 'current' : ''}}" style="{{isCurrentWeek ? 'background-color:' + currentWeekShiftColor + ';' : ''}}">
            <text class="week-title">{{currentWeekTitle}}</text>
          </view>
        </view>
        <view class="nav-btn" bindtap="nextWeek">
          <text class="nav-text">下周</text>
          <text class="nav-icon">›</text>
        </view>
      </view>
    </view>

    <!-- 周排班列表 -->
    <view class="card week-list-card">
      <view class="week-list">
        <view class="day-item {{item.isToday ? 'today' : ''}} {{item.shift ? 'has-shift' : ''}}"
            wx:for="{{weekDates}}"
            wx:key="date"
            bindtap="showShiftSelector"
            bindlongpress="onDeleteShiftClick"
            data-date="{{item.date}}">
          <view class="day-left" style="{{item.isToday ? (item.shift ? 'background:' + item.shift.color + ';' : 'background:#07c160;') : ''}}">
            <text class="day-weekday">{{item.weekday}}</text>
            <text class="day-date">{{item.month}}/{{item.day}}</text>
            <view wx:if="{{item.isToday}}" class="today-dot"></view>
          </view>
          <view class="day-right">
            <block wx:if="{{item.shift}}">
              <view class="shift-info-card" style="background:{{item.shift.color}}4D; border-color:{{item.shift.color}}4D;">
                <text class="shift-name"> {{item.shift.name}}</text>
                <text class="shift-time">{{item.shift.startTime}} - {{item.shift.endTime}}</text>
                <view class="shift-hours-badge" style="background:{{item.shift.color}};">
                  <text class="hours-num">{{item.shift.workHours}}</text>
                  <text class="hours-unit">h</text>
                </view>
              </view>
            </block>
            <block wx:else>
              <view class="no-shift">
                <text class="no-shift-icon">😴</text>
                <text class="no-shift-text">休息</text>
              </view>
            </block>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 本周工时统计卡片 -->
    <view class="card stats-card">
      <view class="card-header">
        <view class="card-icon">⏱️</view>
        <text class="card-title">本周工时</text>
      </view>
      <view class="stats-content">
        <view class="stat-row primary">
          <view class="stat-avatar">
            <text wx:if="{{avatarType === 'text'}}">{{avatarText}}</text>
            <text wx:else>{{avatarEmoji}}</text>
          </view>
          <view class="stat-main">
            <text class="stat-value">{{weekTotalHours}}</text>
            <text class="stat-unit">h</text>
            <text class="stat-divider">/</text>
            <text class="stat-standard">{{customWeeklyHours}}h</text>
          </view>
        </view>
        <view class="progress-bar-container">
          <view class="progress-bar-bg">
            <view class="progress-bar-fill {{weekDifference >= 0 ? 'over' : 'under'}}" style="width: {{(weekTotalHours / customWeeklyHours * 100) > 100 ? 100 : (weekTotalHours / customWeeklyHours * 100)}}%"></view>
          </view>
          <text class="progress-text">{{weekTotalHours >= customWeeklyHours ? '已完成' : '进行中'}}</text>
        </view>
        <view class="stat-row secondary">
          <text class="diff-label">{{differenceType}}</text>
          <text class="diff-value {{differenceType === '超额' ? 'over' : 'under'}}">{{differenceValue}}h</text>
        </view>
      </view>
    </view>
    
    <!-- 本周排班图片卡片 -->
    <view class="card images-card">
      <view class="card-header">
        <view class="card-icon">🖼️</view>
        <text class="card-title">本周排班图片</text>
        <text class="card-subtitle">{{weekImages.length}} 张</text>
      </view>
      
      <view class="images-content">
        <view class="images-list" wx:if="{{weekImages.length > 0}}">
          <view class="image-item" wx:for="{{weekImages}}" wx:key="id">
            <view class="image-info">
              <text class="image-icon">📷</text>
              <text class="image-name">{{item.name}}</text>
            </view>
            <view class="image-actions">
              <view class="action-btn view" bindtap="viewImage" data-index="{{index}}">查看</view>
              <view class="action-btn delete" bindtap="deleteImage" data-index="{{index}}">删除</view>
            </view>
          </view>
        </view>
        
        <view class="empty-state" wx:else>
          <text class="empty-icon">🖼️</text>
          <text class="empty-text">暂无排班图片</text>
        </view>
        
        <view class="add-image-btn" bindtap="onAddImageBtnTap">
          <text class="btn-icon">+</text>
          <text class="btn-text">添加图片</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 月视图 -->
  <view wx:if="{{currentView === 'month'}}" class="month-view-container">
    <!-- 月导航卡片 -->
    <view class="card nav-card">
      <view class="month-header">
        <view class="nav-btn" bindtap="prevMonth">
          <text class="nav-icon">‹</text>
          <text class="nav-text">上月</text>
        </view>
        <view class="month-title-container" bindtap="goToToday">
          <view class="month-title-badge {{isCurrentMonth ? 'current' : ''}}" style="{{isCurrentMonth ? 'background-color:' + currentMonthShiftColor + ';' : ''}}">
            <text class="month-title">{{currentMonthTitle}}</text>
          </view>
        </view>
        <view class="nav-btn" bindtap="nextMonth">
          <text class="nav-text">下月</text>
          <text class="nav-icon">›</text>
        </view>
      </view>
    </view>

    <!-- 月历卡片 -->
    <view class="card calendar-card">
      <view class="weekdays-header">
        <view class="weekday-label" wx:for="{{['一', '二', '三', '四', '五', '六', '日']}}" wx:key="index">
          {{item}}
        </view>
      </view>

      <view class="month-grid">
        <view class="week-row" wx:for="{{monthDates}}" wx:key="index">
          <view class="calendar-day {{item.isToday ? 'today' : ''}} {{item.isCurrentMonth ? 'current-month' : 'other-month'}} {{item.shift ? 'has-shift' : ''}}"
                wx:for="{{item}}"
                wx:key="date"
                bindtap="showActionMenu"
                bindlongpress="onDeleteShiftClick"
                data-date="{{item.date}}"
                style="{{item.shift ? 'background:' + item.shift.color + '4D;' : ''}}">
            <view class="day-number-wrapper">
              <text class="day-number {{item.isToday ? 'today-num' : ''}}">{{item.day}}</text>
            </view>
            <view wx:if="{{item.shift}}" class="day-shift-tag">
              <text class="shift-tag-name">{{item.shift.name}}</text>
            </view>
            <view wx:else class="day-shift-tag empty">
              <text class="shift-tag-name">休息</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 当月工时统计卡片 -->
    <view class="card stats-card">
      <view class="card-header">
        <view class="card-icon">⏱️</view>
        <text class="card-title">当月工时</text>
      </view>
      <view class="stats-content">
        <view class="stat-row primary">
          <view class="stat-avatar">
            <text wx:if="{{avatarType === 'text'}}">{{avatarText}}</text>
            <text wx:else>{{avatarEmoji}}</text>
          </view>
          <view class="stat-main">
            <text class="stat-value">{{monthTotalHours}}</text>
            <text class="stat-unit">h</text>
          </view>
        </view>
        <view class="stat-row secondary">
          <text class="diff-label">{{monthDifferenceType}}</text>
          <text class="diff-value {{monthDifferenceType === '超额' ? 'over' : 'under'}}">{{monthDifferenceValue}}h</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>



<!-- 底部滚动班次选择器 -->
<view class="bottom-picker-mask {{showShiftSelectorModal ? 'show' : ''}}" bindtap="hideShiftSelectorModal"></view>
<view class="bottom-picker-container {{showShiftSelectorModal ? 'show' : ''}}">
  <!-- 标题栏 -->
  <view class="bottom-picker-header">
    <text class="bottom-picker-title">选择班次</text>
    <view class="bottom-picker-close" bindtap="hideShiftSelectorModal">
      <text class="close-icon">✕</text>
    </view>
  </view>
  
  <!-- 滚动选择区域 -->
  <view class="bottom-picker-content">
    <picker-view 
      class="shift-picker-view" 
      indicator-style="height: 90rpx;" 
      value="{{pickerValue}}" 
      bindchange="onPickerChange"
    >
      <picker-view-column>
        <view 
          wx:for="{{shiftTemplates}}" 
          wx:key="index"
          class="picker-item"
        >
          <view class="picker-item-color" style="background: {{item.color}};"></view>
          <text class="picker-item-name">{{item.name}}</text>
        </view>
      </picker-view-column>
    </picker-view>
  </view>
  
  <!-- 确认按钮 -->
  <view class="bottom-picker-footer">
    <button class="confirm-button" bindtap="confirmShiftSelection">确认</button>
  </view>
</view>

<!-- 图片管理弹窗 -->
<view class="modal-mask {{showAddImageModal ? 'show' : ''}}" bindtap="hideAddImageModal"></view>
<view class="modal-content {{showAddImageModal ? 'show' : ''}}">
  <view class="modal-header">
    <text class="modal-title">添加排班图片</text>
    <view class="modal-close" bindtap="hideAddImageModal">
      <text class="close-icon">✕</text>
    </view>
  </view>
  <view class="modal-body" catchtap="stopPropagation">
    <view class="input-group">
      <text class="input-label">图片名称</text>
      <input class="modal-input" placeholder="请输入图片名称" value="{{imageName || ''}}" bindinput="onImageNameInput"/>
    </view>

    <view class="upload-section">
      <view wx:if="{{!selectedImagePath}}" class="upload-placeholder" bindtap="chooseImage">
        <text class="upload-icon">📷</text>
        <text class="upload-text">点击选择图片</text>
        <text class="upload-hint">支持从相册或相机选择</text>
      </view>
      <view wx:else class="upload-preview">
        <image class="preview-image" src="{{selectedImagePath}}" mode="aspectFill"/>
        <view class="preview-overlay" bindtap="chooseImage">
          <text class="overlay-text">更换图片</text>
        </view>
      </view>
    </view>

    <view class="modal-footer">
      <view class="modal-btn cancel-btn" bindtap="hideAddImageModal">取消</view>
      <view class="modal-btn confirm-btn {{!selectedImagePath || !imageName ? 'disabled' : ''}}" bindtap="addImage">确定添加</view>
    </view>
  </view>
</view>
