<!-- pages/schedule/schedule.wxml -->
<view class="container">
  <view class="header">
    <text class="title">жҺ’зҸӯз®ЎзҗҶ</text>
  </view>

  <!-- и§ҶеӣҫеҲҮжҚў -->
  <view class="view-switch">
    <view class="switch-item {{currentView === 'week' ? 'active' : ''}}" data-view="week" bindtap="switchView">
      е‘Ёи§Ҷеӣҫ
    </view>
    <view class="switch-item {{currentView === 'month' ? 'active' : ''}}" data-view="month" bindtap="switchView">
      жңҲи§Ҷеӣҫ
    </view>
  </view>

  <!-- е‘Ёи§Ҷеӣҫ -->
  <view wx:if="{{currentView === 'week'}}" class="week-view">
    <view class="week-header">
      <button class="nav-btn" bindtap="prevWeek">дёҠдёҖе‘Ё</button>
      <view class="week-title-container">
        <text class="current-week {{isCurrentWeek ? 'current-week-highlight' : 'other-week'}}" style="{{isCurrentWeek ? 'background-color:' + currentWeekShiftColor + ';' : 'color: #000;'}}">{{currentWeekTitle}}</text>
      </view>
      <button class="nav-btn" bindtap="nextWeek">дёӢдёҖе‘Ё</button>
    </view>

    <!-- йҡҗи—Ҹе‘Ёи§Ҷеӣҫзҡ„жҳҹжңҹеҮ жҳҫзӨә -->
    <view class="weekdays" style="display:none;">
      <view class="weekday" wx:for="{{['дёҖ', 'дәҢ', 'дёү', 'еӣӣ', 'дә”', 'е…ӯ', 'ж—Ҙ']}}" wx:key="index">
        {{item}}
      </view>
    </view>

    <view class="week-grid">
      <view class="day-cell {{item.isToday ? 'today' : ''}}" wx:for="{{weekDates}}" wx:key="date" bindtap="selectDate" data-date="{{item.date}}" style="{{item.isToday ? (item.shift ? 'background:' + item.shift.color + '30;' : 'background:#f0fdf4;') : ''}}">
        <view class="day-header" style="{{item.isToday ? (item.shift ? 'background:' + item.shift.color + 'B0;' : 'background:#34d399;') : ''}}">
          <text class="weekday-text">{{item.weekday}}</text>
          <text class="day-number">{{item.month}}/{{item.day}}</text>
        </view>
        <view class="day-content">
          <text wx:if="{{!item.shift}}" class="no-shift-text">жңӘжҺ’зҸӯ</text>
          <view wx:if="{{item.shift}}" class="shift-card" style="background-color:{{item.shift.color}}40;">
            <text class="shift-name">{{item.shift.name}}</text>
            <text class="shift-time">{{item.shift.startTime}}-{{item.shift.endTime}}</text>
            <text class="shift-hours">{{item.shift.workHours}}е°Ҹж—¶</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- жң¬е‘Ёе·Ҙж—¶з»ҹи®Ў -->
    <view class="week-statistics">
      <view class="stat-item">
        <text class="stat-label">жң¬е‘Ёе·Ҙж—¶пјҡ</text>
        <text class="stat-value">{{weekTotalHours}} е°Ҹж—¶</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">{{differenceType}}пјҡ</text>
        <text class="stat-value {{differenceType === 'и¶…йўқ' ? 'overtime' : 'shortage'}}">{{differenceValue}} е°Ҹж—¶</text>
      </view>
    </view>

  </view>

  <!-- жңҲи§Ҷеӣҫ -->
  <view wx:if="{{currentView === 'month'}}" class="month-view">
    <view class="month-header">
      <button class="nav-btn" bindtap="prevMonth">дёҠдёҖжңҲ</button>
      <view class="month-title-container">
        <text class="current-month {{isCurrentMonth ? 'current-month-highlight' : ''}}" style="{{isCurrentMonth ? 'background-color:' + currentMonthShiftColor + '; color: #fff;' : ''}}">{{currentMonthTitle}}</text>
      </view>
      <button class="nav-btn" bindtap="nextMonth">дёӢдёҖжңҲ</button>
    </view>

    <view class="weekdays">
      <view class="weekday" wx:for="{{['дёҖ', 'дәҢ', 'дёү', 'еӣӣ', 'дә”', 'е…ӯ', 'ж—Ҙ']}}" wx:key="index">
        {{item}}
      </view>
    </view>

    <view class="month-grid">
        <view class="week-row" wx:for="{{monthDates}}" wx:key="index">
          <view class="day-cell {{item.isToday ? 'today' : ''}} {{item.isCurrentMonth ? '' : 'other-month'}}" 
                wx:for="{{item}}" wx:key="date" bindtap="selectDate" data-date="{{item.date}}">
            <text class="day-number">{{item.day}}</text>
            <view wx:if="{{item.shift}}" class="shift-info" style="background:{{item.shift.color}}40;">
              <text class="shift-name">{{item.shift.name}}</text>
            </view>
            <view wx:elif="{{!item.shift}}" class="no-shift">
              <text>жңӘжҺ’зҸӯ</text>
            </view>
          </view>
      </view>
    </view>
    

  </view>

  <!-- жҺ’зҸӯйҖүжӢ©еј№зӘ— -->
  <view class="modal" wx:if="{{showShiftModal}}" bindtap="hideShiftModal">
    <view class="modal-content" bindtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">дёә {{selectedDate}} жҺ’зҸӯ</text>
        <icon type="clear" size="24" color="#999" bindtap="hideShiftModal" />
      </view>
      
      <view wx:if="{{shiftTemplates.length > 0}}" class="shift-picker-container">
        <view class="shift-picker-indicator"></view>
        <picker-view indicator-style="height: 50px;" style="width: 100%; height: 220px;" value="{{pickerValue}}" bindchange="bindPickerChange">
          <picker-view-column>
            <view wx:for="{{shiftTemplates}}" wx:key="index" style="line-height: 50px; text-align: center; font-size: 36rpx; font-weight: 600; padding: 0 20rpx;">
              <text>{{item.name}}</text>
            </view>
          </picker-view-column>
        </picker-view>
        <button class="shift-picker-btn" bindtap="assignShiftFromPicker">зЎ®е®ҡжҺ’зҸӯ</button>
      </view>
      
      <view wx:if="{{selectedShift}}" class="current-shift">
        <text>еҪ“еүҚжҺ’зҸӯ: {{selectedShift.name}}</text>
        <button class="remove-btn" bindtap="removeShift" data-date="{{selectedDate}}">з§»йҷӨжҺ’зҸӯ</button>
      </view>
      
      <view wx:if="{{shiftTemplates.length === 0}}" class="empty-tip">
        жҡӮж— зҸӯж¬ЎжЁЎжқҝпјҢиҜ·е…ҲеҲ°"и®ЎеҲ’"йЎөйқўж·»еҠ 
      </view>
    </view>
  </view>
</view>