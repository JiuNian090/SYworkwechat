<!-- pages/schedule/schedule.wxml -->
<view class="container">
  <view class="header">
    <text class="title">排班管理</text>
  </view>

  <!-- 视图切换 -->
  <view class="view-switch">
    <view class="switch-item {{currentView === 'week' ? 'active' : ''}}" data-view="week" bindtap="switchView">
      周视图
    </view>
    <view class="switch-item {{currentView === 'month' ? 'active' : ''}}" data-view="month" bindtap="switchView">
      月视图
    </view>
  </view>

  <!-- 周视图 -->
  <view wx:if="{{currentView === 'week'}}" class="week-view">
    <view class="week-header">
      <button class="nav-btn" bindtap="prevWeek" hover-class="nav-btn-hover">上一周</button>
      <view class="week-title-container">
        <text class="current-week {{isCurrentWeek ? 'current-week-highlight' : 'other-week'}}" style="{{isCurrentWeek ? 'background-color:' + currentWeekShiftColor + ';' : 'color: #000;'}}" bindtap="goToToday">{{currentWeekTitle}}</text>
      </view>
      <button class="nav-btn" bindtap="nextWeek" hover-class="nav-btn-hover">下一周</button>
    </view>

    <!-- 隐藏周视图的星期几显示 -->
    <view class="weekdays" style="display:none;">
      <view class="weekday" wx:for="{{['一', '二', '三', '四', '五', '六', '日']}}" wx:key="index">
        {{item}}
      </view>
    </view>

    <view class="week-grid">
      <view class="day-cell {{item.isToday ? 'today' : ''}}" wx:for="{{weekDates}}" wx:key="date" bindtap="selectDate" data-date="{{item.date}}" style="{{item.isToday ? (item.shift ? 'background:' + item.shift.color + '30;' : 'background:#f0fdf4;') : ''}}">
        <view class="day-header" style="{{item.isToday ? (item.shift ? 'background:' + item.shift.color + 'B0;' : 'background:#34d399;') : ''}}">
          <text class="weekday-text">{{item.weekday}}</text>
          <text class="day-number">{{item.month}}/{{item.day}}</text>
        </view>
        <view class="day-content">
          <text wx:if="{{!item.shift}}" class="no-shift-text">未排班</text>
          <view wx:if="{{item.shift}}" class="shift-card" style="background-color:{{item.shift.color}}40;">
            <text class="shift-name">{{item.shift.name}}</text>
            <text class="shift-time">{{item.shift.startTime}}-{{item.shift.endTime}}</text>
            <text class="shift-hours">{{item.shift.workHours}}小时</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 本周工时统计 -->
    <view class="week-statistics">
      <view class="stat-item">
        <text class="stat-avatar">
          <text wx:if="{{avatarType === 'text'}}">{{avatarText}}</text>
          <text wx:else>{{avatarEmoji}}</text>
        </text>
        <text class="stat-label">本周工时：</text>
        <text class="stat-value">{{weekTotalHours}} 小时</text>
      </view>
      <view class="stat-item">
        <text class="stat-avatar"></text>
        <text class="stat-label">{{differenceType}}：</text>
        <text class="stat-value {{differenceType === '超额' ? 'overtime' : 'shortage'}}">{{differenceValue}} 小时</text>
      </view>
    </view>
    
    <!-- 本周排班管理板块 -->
    <view class="week-images">
      <view class="images-header">
        <text class="images-title">本周排班</text>
      </view>
      
      <view class="images-list" wx:if="{{weekImages.length > 0}}">
        <view class="image-item" wx:for="{{weekImages}}" wx:key="id">
          <text class="image-name">{{item.name}}</text>
          <view class="image-actions">
            <button class="image-action-btn view-btn" bindtap="viewImage" data-index="{{index}}">查看</button>
            <button class="image-action-btn delete-btn" bindtap="deleteImage" data-index="{{index}}">删除</button>
          </view>
        </view>
      </view>
      
      <view class="empty-images" wx:else>
        <text>暂无图片</text>
      </view>
      
      <view class="add-image-section">
        <button class="add-image-btn" bindtap="showAddImageModal">+ 添加图片</button>
      </view>
    </view>

  </view>

  <!-- 月视图 -->
  <view wx:if="{{currentView === 'month'}}" class="month-view">
    <view class="month-header">
      <button class="nav-btn" bindtap="prevMonth" hover-class="nav-btn-hover">上一月</button>
      <view class="month-title-container">
        <text class="current-month {{isCurrentMonth ? 'current-month-highlight' : ''}}" style="{{isCurrentMonth ? 'background-color:' + currentMonthShiftColor + '; color: #fff;' : ''}}" bindtap="goToToday">{{currentMonthTitle}}</text>
      </view>
      <button class="nav-btn" bindtap="nextMonth" hover-class="nav-btn-hover">下一月</button>
    </view>

    <view class="weekdays">
      <view class="weekday" wx:for="{{['一', '二', '三', '四', '五', '六', '日']}}" wx:key="index">
        {{item}}
      </view>
    </view>

    <view class="month-grid">
        <view class="week-row" wx:for="{{monthDates}}" wx:key="index">
          <view class="day-cell {{item.isToday ? 'today' : ''}} {{item.isCurrentMonth ? '' : 'other-month'}}" 
                wx:for="{{item}}" wx:key="date" bindtap="selectDate" data-date="{{item.date}}">
            <text class="day-number">{{item.day}}</text>
            <view wx:if="{{item.shift}}" class="shift-info" style="background:{{item.shift.color}}40;">
              <text class="shift-name">{{item.shift.name}}</text>
            </view>
            <view wx:elif="{{!item.shift}}" class="no-shift">
              <text>未排班</text>
            </view>
          </view>
      </view>
    </view>
    
    <!-- 当月工时统计 -->
    <view class="week-statistics">
      <view class="stat-item">
        <text class="stat-avatar">
          <text wx:if="{{avatarType === 'text'}}">{{avatarText}}</text>
          <text wx:else>{{avatarEmoji}}</text>
        </text>
        <text class="stat-label">当月工时：</text>
        <text class="stat-value">{{monthTotalHours}} 小时</text>
      </view>
      <view class="stat-item">
        <text class="stat-avatar"></text>
        <text class="stat-label">{{monthDifferenceType}}：</text>
        <text class="stat-value {{monthDifferenceType === '超额' ? 'overtime' : 'shortage'}}">{{monthDifferenceValue}} 小时</text>
      </view>
    </view>

  </view>

  <!-- 排班选择弹窗 -->
  <view class="modal-mask" wx:if="{{showShiftModal}}" bindtap="hideShiftModal"></view>
  <view class="modal-container" wx:if="{{showShiftModal}}">
    <view class="modal-header">
      <text class="modal-title">为 {{selectedDate}} 排班</text>
      <button class="modal-close-btn" bindtap="hideShiftModal">×</button>
    </view>
    <view class="modal-content" bindtap="stopPropagation">
      <!-- 第一个板块：选择器和确认排班按钮 -->
      <view wx:if="{{shiftTemplates.length > 0}}" class="modal-section">
        <view class="shift-picker-container">
          <view class="shift-picker-indicator"></view>
          <picker-view indicator-style="height: 50px;" style="width: 100%; height: 220px;" value="{{pickerValue}}" bindchange="bindPickerChange">
            <picker-view-column>
              <view wx:for="{{shiftTemplates}}" wx:key="index" style="line-height: 50px; text-align: center; font-size: 36rpx; font-weight: 600; padding: 0 20rpx;">
                <text>{{item.name}}</text>
              </view>
            </picker-view-column>
          </picker-view>
        </view>
        <button class="modal-btn confirm-btn section-btn" bindtap="assignShiftFromPicker">确定排班</button>
      </view>
      
      <!-- 第二个板块：当前排班和移除排班按钮 -->
      <view wx:if="{{selectedShift}}" class="modal-section">
        <view class="current-shift">
          <text>当前排班: {{selectedShift.name}}</text>
        </view>
        <button class="modal-btn remove-btn section-btn" bindtap="removeShift" data-date="{{selectedDate}}">移除排班</button>
      </view>
      
      <view wx:if="{{shiftTemplates.length === 0}}" class="empty-tip">
        暂无班次模板，请先到"计划"页面添加
      </view>
    </view>
    <!-- 移除了取消按钮，可通过点击遮罩层或关闭按钮关闭弹窗 -->
  </view>
  
  <!-- 图片管理弹窗 -->
    <view class="modal-mask" wx:if="{{showAddImageModal}}" bindtap="hideAddImageModal"></view>
    <view class="modal-container" wx:if="{{showAddImageModal}}">
      <view class="modal-header">
        <text class="modal-title">添加图片</text>
        <button class="modal-close-btn" bindtap="hideAddImageModal">×</button>
      </view>
      <view class="modal-content" bindtap="stopPropagation">
        <view class="image-name-section">
          <text class="image-name-label">图片名称：</text>
          <input class="image-name-input" placeholder="请输入图片名称" value="{{imageName}}" bindinput="onImageNameInput"></input>
        </view>
        
        <view class="image-upload-section">
          <button class="image-upload-btn" bindtap="chooseImage">选择图片</button>
          <text class="image-upload-hint" wx:if="{{selectedImagePath}}">已选择图片</text>
        </view>
        
        <view class="modal-footer">
          <button class="modal-btn cancel-btn" bindtap="hideAddImageModal">取消</button>
          <button class="modal-btn confirm-btn" bindtap="addImage" disabled="{{!selectedImagePath || !imageName}}">确定添加</button>
        </view>
      </view>
    </view>
</view>