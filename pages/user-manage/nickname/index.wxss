page {
  --primary-color: #34d399;
  --primary-dark: #10b981;
  --primary-light: #d1fae5;
  --danger-color: #f87171;
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #e8e8e8;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.form-card {
  margin: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: var(--radius-lg);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-group {
  margin-bottom: 28rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 84rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.password-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #f0f0f0;
}

.password-input {
  flex: 1;
  background: transparent;
  border: none;
  height: 84rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.password-toggle {
  padding: 10rpx 16rpx;
  border-left: 2rpx solid var(--border-color);
  flex-shrink: 0;
}

.toggle-text {
  font-size: 24rpx;
  color: #60a5fa;
}

.remember-password {
  margin-top: 16rpx;
}

.checkbox-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.checkbox.checked {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  border-color: var(--primary-color);
}

.checkbox-icon {
  color: white;
  font-size: 22rpx;
  font-weight: bold;
}

.checkbox-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.warning-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 32rpx 28rpx;
  margin: 24rpx;
  background: linear-gradient(135deg, #fff7e6 0%, #fff9f0 100%);
  border-radius: var(--radius-lg);
  border: 1rpx solid #ffd591;
}

.warning-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #faad14, #ffc53d);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.warning-icon {
  font-size: 40rpx;
  line-height: 1;
}

.warning-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #d46b08;
  margin-bottom: 8rpx;
}

.warning-content {
  font-size: 26rpx;
  color: #d46b08;
  line-height: 1.6;
}

.btn-area {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
}

.btn-area button {
  flex: 1;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
}

.modal-btn::after {
  border: none;
}

.btn-cancel {
  background: #f3f4f6;
  color: var(--text-secondary);
}

.btn-confirm {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
}

.btn-delete-confirm {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  color: #ffffff;
}

.switch-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  margin: 0 24rpx 20rpx;
  background: rgba(52, 211, 153, 0.08);
  border: 1rpx solid rgba(52, 211, 153, 0.2);
  border-radius: 12rpx;
}

.switch-tip-icon {
  font-size: 28rpx;
}

.switch-tip-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.account-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  margin: 0 24rpx 20rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #f0f0f0;
}

.account-item:active {
  transform: scale(0.98);
  border-color: var(--primary-light);
  background: #f0fdf4;
}

.account-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid #f0f0f0;
}

.account-avatar .avatar-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.account-avatar .avatar-emoji {
  font-size: 52rpx;
}

.account-info {
  flex: 1;
  min-width: 0;
}

.account-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.account-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
  flex-shrink: 0;
}

.auto-restore-checkbox {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #d1d5db;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.auto-restore-checkbox.checked {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  border-color: var(--primary-color);
}

.checkmark {
  color: white;
  font-size: 26rpx;
  font-weight: bold;
}

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn:active {
  background-color: #fee2e2;
}

.delete-icon {
  font-size: 26rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  background: #f9fafb;
  margin: 24rpx;
  border-radius: 20rpx;
  border: 2rpx dashed #e0e0e0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

@media (min-width: 768px) {
  .page-container {
    max-width: 750rpx;
    margin: 0 auto;
  }
  .form-input {
    height: 96rpx;
    font-size: 32rpx;
  }
  .modal-btn {
    height: 96rpx;
    line-height: 96rpx;
    font-size: 32rpx;
  }
}
