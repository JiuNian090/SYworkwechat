<scroll-view class="container" scroll-y enhanced show-scrollbar="false">
  <view class="user-page-main">
    <view class="user-info-section">
      <view class="user-info-header">
        <view class="user-avatar">
          <text class="user-avatar-text" wx:if="{{avatarType === 'text'}}">{{avatarText}}</text>
          <text class="user-avatar-emoji" wx:else>{{avatarEmoji || '😊'}}</text>
        </view>
        <view class="user-info-details">
          <text class="user-nickname">{{cloudUserInfo.nickname || cloudUserInfo.account}}</text>
          <view class="user-status">
            <view class="status-dot"></view>
            <text class="status-text">在线</text>
          </view>
        </view>
        <text class="header-arrow">›</text>
      </view>
      <view class="user-info-list">
        <view class="user-info-item">
          <view class="info-item-left">
            <view class="info-icon-wrapper account-icon">
              <text class="info-icon">👤</text>
            </view>
            <text class="info-label">账号</text>
          </view>
          <view class="info-value-row">
            <text class="info-value">{{cloudUserInfo.account}}</text>
          </view>
        </view>
        <view class="user-info-item" bindtap="showModal" data-page="updateNickname">
          <view class="info-item-left">
            <view class="info-icon-wrapper nickname-icon">
              <text class="info-icon">🏷️</text>
            </view>
            <text class="info-label">昵称</text>
          </view>
          <view class="info-value-row">
            <text class="info-value">{{cloudUserInfo.nickname || cloudUserInfo.account}}</text>
            <text class="arrow-icon">›</text>
          </view>
        </view>
        <view class="user-info-item" bindtap="showModal" data-page="updatePassword">
          <view class="info-item-left">
            <view class="info-icon-wrapper password-icon">
              <text class="info-icon">🔒</text>
            </view>
            <text class="info-label">密码</text>
          </view>
          <view class="info-value-row">
            <text class="info-value">••••••</text>
            <text class="arrow-icon">›</text>
          </view>
        </view>
        <view class="user-info-item" bindtap="showModal" data-page="avatar">
          <view class="info-item-left">
            <view class="info-icon-wrapper avatar-icon">
              <text class="info-icon">🎭</text>
            </view>
            <text class="info-label">头像</text>
          </view>
          <view class="info-value-row">
            <text class="info-value">{{avatarType === 'text' ? avatarText : avatarEmoji}}</text>
            <text class="arrow-icon">›</text>
          </view>
        </view>
      </view>

      <view class="action-list">
        <view class="user-info-item action-item" bindtap="showModal" data-page="switchAccount">
          <view class="info-item-left">
            <view class="info-icon-wrapper switch-icon">
              <text class="info-icon">🔄</text>
            </view>
            <text class="info-label">切换账号</text>
          </view>
          <view class="info-value-row">
            <text class="arrow-icon">›</text>
          </view>
        </view>
        <view class="user-info-item action-item" bindtap="showModal" data-page="deleteAccount">
          <view class="info-item-left">
            <view class="info-icon-wrapper delete-icon">
              <text class="info-icon">🗑️</text>
            </view>
            <text class="info-label warn-label">删除账户</text>
          </view>
          <view class="info-value-row">
            <text class="arrow-icon">›</text>
          </view>
        </view>
      </view>
      <view class="logout-section">
        <view class="user-info-item logout-item" bindtap="confirmLogout">
          <text class="logout-label">退出登录</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<!-- WeUI 半屏弹窗遮罩 -->
<view class="modal-mask {{currentModal ? 'show' : ''}}" bindtap="hideModal"></view>

<!-- WeUI 半屏弹窗容器 -->
<view class="modal-container {{currentModal ? 'show' : ''}}">
  <view class="modal-header">
    <view class="modal-title-wrapper">
      <text class="modal-title-icon" wx:if="{{currentModal === 'updateNickname'}}">🏷️</text>
      <text class="modal-title-icon" wx:elif="{{currentModal === 'updatePassword'}}">🔐</text>
      <text class="modal-title-icon" wx:elif="{{currentModal === 'avatar'}}">🎭</text>
      <text class="modal-title-icon" wx:elif="{{currentModal === 'switchAccount'}}">🔄</text>
      <text class="modal-title-icon" wx:elif="{{currentModal === 'login'}}">🔑</text>
      <text class="modal-title-icon" wx:else>🗑️</text>
      <text class="modal-title" wx:if="{{currentModal === 'updateNickname'}}">修改昵称</text>
      <text class="modal-title" wx:elif="{{currentModal === 'updatePassword'}}">修改密码</text>
      <text class="modal-title" wx:elif="{{currentModal === 'avatar'}}">选择头像</text>
      <text class="modal-title" wx:elif="{{currentModal === 'switchAccount'}}">切换账号</text>
      <text class="modal-title" wx:elif="{{currentModal === 'login'}}">账号登录</text>
      <text class="modal-title" wx:else>删除账户</text>
    </view>
    <view class="modal-close" bindtap="hideModal">
      <text class="close-icon">✕</text>
    </view>
  </view>

  <scroll-view class="modal-body" scroll-y enhanced show-scrollbar="false">
    <!-- 修改昵称 -->
    <view class="modal-content" wx:if="{{currentModal === 'updateNickname'}}">
      <view class="form-card">
        <view class="form-group">
          <text class="form-label">新昵称</text>
          <input class="form-input" placeholder="请输入新昵称" value="{{newNickname}}" bindinput="onNicknameInput" maxlength="20" />
        </view>
      </view>
    </view>

    <!-- 修改密码 -->
    <view class="modal-content" wx:if="{{currentModal === 'updatePassword'}}">
      <view class="form-card">
        <view class="form-group">
          <text class="form-label">原密码</text>
          <input class="form-input" type="password" placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onOldPasswordInput" />
        </view>
        <view class="form-group">
          <text class="form-label">新密码</text>
          <input class="form-input" type="password" placeholder="请输入新密码（至少 6 位）" value="{{newPassword}}" bindinput="onNewPasswordInput" />
        </view>
        <view class="form-group">
          <text class="form-label">确认新密码</text>
          <input class="form-input" type="password" placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
        </view>
      </view>
    </view>

    <!-- 删除账户 -->
    <view class="modal-content" wx:if="{{currentModal === 'deleteAccount'}}">
      <view class="warning-card">
        <view class="warning-icon-wrapper">
          <text class="warning-icon">⚠️</text>
        </view>
        <text class="warning-title">危险操作</text>
        <text class="warning-content">删除账户将同时删除所有云端备份数据，此操作不可恢复！</text>
      </view>
      <view class="form-card">
        <view class="form-group">
          <text class="form-label">请输入密码确认</text>
          <input class="form-input" type="password" placeholder="请输入密码" value="{{deleteAccountPassword}}" bindinput="onDeleteAccountPasswordInput" />
        </view>
      </view>
    </view>

    <!-- 头像选择 -->
    <view class="modal-content" wx:if="{{currentModal === 'avatar'}}">
      <view class="avatar-selector">
        <view class="avatar-preview-section">
          <view class="avatar-preview-ring">
            <view class="preview-avatar-circle">
              <text wx:if="{{avatarMode === 'emoji'}}" class="preview-emoji">{{avatarModeEmoji || '😊'}}</text>
              <text wx:else class="preview-text">{{avatarModeText || '用'}}</text>
            </view>
          </view>
          <text class="preview-label">{{avatarMode === 'emoji' ? (avatarModeEmoji ? getEmojiDesc(avatarModeEmoji) : '请选择表情') : (avatarModeText ? avatarModeText + '（文字头像）' : '请输入文字')}}</text>
        </view>

        <view class="avatar-mode-tabs">
          <view class="avatar-mode-tab {{avatarMode === 'emoji' ? 'active' : ''}}" data-mode="emoji" catchtap="onAvatarModeSwitch">
            <text class="mode-tab-icon">😊</text>
            <text class="mode-tab-text">表情头像</text>
          </view>
          <view class="avatar-mode-tab {{avatarMode === 'text' ? 'active' : ''}}" data-mode="text" catchtap="onAvatarModeSwitch">
            <text class="mode-tab-icon">🔤</text>
            <text class="mode-tab-text">文字头像</text>
          </view>
        </view>

        <view wx:if="{{avatarMode === 'text'}}" class="text-avatar-section">
          <view class="text-avatar-content">
            <view class="text-avatar-input-wrap">
              <text class="text-avatar-hint">输入 1~2 个字符作为头像</text>
              <input class="text-avatar-input" placeholder="例如：乐、用、我" value="{{avatarModeTextInput}}" maxlength="2" bindinput="onAvatarTextInput" bindconfirm="onAvatarTextConfirm" />
            </view>
            <view class="text-avatar-preview-box">
              <text class="preview-box-label">预览</text>
              <view class="preview-box-circle">
                <text class="preview-box-char">{{avatarModeText || '用'}}</text>
              </view>
            </view>
          </view>
        </view>

        <view wx:elif="{{avatarMode === 'emoji'}}" class="emoji-select-section">
          <view class="emoji-categories">
            <view class="emoji-cat-item {{avatarModeCategory === item.id ? 'active' : ''}}" wx:for="{{emojiCategories}}" wx:key="id" catchtap="onAvatarCategorySwitch" data-category="{{item.id}}">
              <text class="emoji-cat-icon">{{item.icon}}</text>
            </view>
          </view>
          <scroll-view class="emoji-grid-scroll" scroll-y enhanced show-scrollbar="false">
            <view class="emoji-grid-content">
              <view class="emoji-grid-item {{avatarModeEmoji === item ? 'selected' : ''}}" wx:for="{{avatarModeEmojis}}" wx:key="index" catchtap="onAvatarEmojiPick" data-emoji="{{item}}">
                <text class="emoji-grid-char">{{item}}</text>
              </view>
            </view>
          </scroll-view>
        </view>
      </view>
    </view>

    <!-- 切换账号 -->
    <view class="modal-content" wx:if="{{currentModal === 'switchAccount'}}">
      <view class="switch-tip" wx:if="{{savedAccounts.length > 0}}">
        <text class="switch-tip-icon">☑️</text>
        <text class="switch-tip-text">勾选后下次登录自动恢复数据</text>
      </view>
      <view wx:if="{{savedAccounts.length > 0}}">
        <view class="account-item" wx:for="{{savedAccounts}}" wx:key="account" bindtap="selectAccount" data-index="{{index}}">
          <view class="account-avatar">
            <text wx:if="{{item.avatarType === 'text'}}" class="avatar-text">{{item.avatarText || (item.account ? item.account.charAt(0).toUpperCase() : 'U')}}</text>
            <text wx:else class="avatar-emoji">{{item.avatarEmoji || '😊'}}</text>
          </view>
          <view class="account-info">
            <text class="account-name">{{item.account}}</text>
          </view>
          <view class="account-actions">
            <view class="auto-restore-checkbox {{autoRestoreMap[item.account] ? 'checked' : ''}}" catchtap="toggleAutoRestore" data-account="{{item.account}}">
              <text wx:if="{{autoRestoreMap[item.account]}}" class="checkmark">✓</text>
            </view>
            <view class="delete-btn" catchtap="deleteSavedAccount" data-account="{{item.account}}">
              <text class="delete-icon">🗑️</text>
            </view>
          </view>
        </view>
      </view>
      <view class="empty-state" wx:else>
        <text class="empty-icon">🔑</text>
        <text class="empty-text">暂无保存的账号</text>
        <text class="empty-hint">登录时选择"记住密码"可保存账号</text>
      </view>
    </view>

    <!-- 登录 -->
    <view class="modal-content" wx:if="{{currentModal === 'login'}}">
      <view class="form-card">
        <view class="form-group">
          <text class="form-label">账号</text>
          <input class="form-input" placeholder="请输入账号" value="{{cloudAccountInput}}" bindinput="onCloudAccountInput"></input>
        </view>
        <view class="form-group">
          <text class="form-label">密码</text>
          <view class="password-wrapper">
            <input class="form-input password-input" placeholder="请输入密码" value="{{cloudPasswordInput}}" bindinput="onCloudPasswordInput" password="{{!showCloudPassword}}"></input>
            <view class="password-toggle" bindtap="toggleCloudPasswordVisibility">
              <text class="toggle-text">{{showCloudPassword ? '隐藏' : '显示'}}</text>
            </view>
          </view>
        </view>
        <view class="form-group remember-password">
          <view class="checkbox-wrapper" bindtap="toggleRememberPassword">
            <view class="checkbox {{rememberPassword ? 'checked' : ''}}">
              <text class="checkbox-icon" wx:if="{{rememberPassword}}">✓</text>
            </view>
            <text class="checkbox-label">记住密码</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="modal-footer">
    <!-- 修改昵称按钮 -->
    <view wx:if="{{currentModal === 'updateNickname'}}">
      <button class="modal-btn btn-cancel" bindtap="hideModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="confirmUpdateNickname">确定</button>
    </view>

    <!-- 修改密码按钮 -->
    <view wx:if="{{currentModal === 'updatePassword'}}">
      <button class="modal-btn btn-cancel" bindtap="hideModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="confirmUpdatePassword">确定</button>
    </view>

    <!-- 删除账户按钮 -->
    <view wx:if="{{currentModal === 'deleteAccount'}}">
      <button class="modal-btn btn-cancel" bindtap="hideModal">取消</button>
      <button class="modal-btn btn-delete-confirm" bindtap="confirmDeleteAccount">确认删除</button>
    </view>

    <!-- 头像选择按钮 -->
    <view wx:if="{{currentModal === 'avatar'}}">
      <button class="modal-btn btn-cancel" bindtap="hideModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="onAvatarConfirm">确定</button>
    </view>

    <!-- 切换账号按钮 -->
    <view wx:if="{{currentModal === 'switchAccount'}}">
      <button class="modal-btn btn-cancel" bindtap="hideModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="showLoginModal">登录新账号</button>
    </view>

    <!-- 登录按钮 -->
    <view wx:if="{{currentModal === 'login'}}">
      <button class="modal-btn btn-cancel" bindtap="hideModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="loginToCloud">登录</button>
    </view>
  </view>
</view>