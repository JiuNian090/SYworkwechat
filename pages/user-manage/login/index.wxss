@import "../nickname/index.wxss";

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-left {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: var(--text-secondary);
}

.header-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 36rpx;
}

.title-text {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.header-right {
  width: 80rpx;
  height: 80rpx;
}

.login-form {
  padding-top: 24rpx;
}