/* 添加快速选择按钮样式 */
.quick-select-buttons {
  display: flex;
  justify-content: space-between;
  margin: 10rpx 0;
  gap: 10rpx;
}

.quick-btn {
  flex: 1;
  background: #ffffff;
  border: 1rpx solid #e0e0e0;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #000000;
  font-weight: bold;
  text-align: center;
  transition: all 0.3s ease;
  position: relative;
  padding: 2rpx 0;
}

.quick-btn::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #07c160;
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: -1;
}

.quick-btn:first-child {
  border-top-left-radius: 30rpx;
  border-bottom-left-radius: 30rpx;
}

.quick-btn:last-child {
  border-top-right-radius: 30rpx;
  border-bottom-right-radius: 30rpx;
}

.quick-btn-selected {
  background: #07c160;
  color: #ffffff;
  border-color: #07c160;
  transform: scale(1);
  transition: all 0.3s ease;
}

/* 按钮按下状态样式 */
.quick-btn-pressed {
  background: #059e4d;
  color: #ffffff;
  border-color: #059e4d;
  transform: scale(0.98);
  transition: all 0.1s ease;
}

/* 按钮 hover 状态样式 */
.quick-btn-hover {
  background: #07c160;
  color: #ffffff;
  border-color: #07c160;
  transform: scale(0.98);
  transition: all 0.1s ease;
}

/* 自定义每周标准工时样式 */
.custom-hours-setting {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 25rpx;
  margin: 20rpx 0;
  border: 1rpx solid #eee;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.custom-hours-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
}

.custom-hours-label::before {
  content: "⚙️";
  margin-right: 10rpx;
  font-size: 30rpx;
}

.custom-hours-input-group {
  display: flex;
  align-items: center;
  width: 100%;
  max-width: 400rpx;
}

.custom-hours-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #07c160;
  border-radius: 16rpx 0 0 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 80rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.1);
  transition: all 0.3s ease;
  text-align: center;
  font-weight: bold;
  color: #333;
}

.custom-hours-input:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.3);
  outline: none;
}

.custom-hours-unit {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  background: #07c160;
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 0 16rpx 16rpx 0;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.1);
}

