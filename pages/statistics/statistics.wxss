/* CSS Variables - 统一设计系统 */
page {
  --primary-color: #34d399;
  --primary-light: #6ee7b7;
  --primary-dark: #10b981;
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #e5e5e5;
  --shadow-color: rgba(0, 0, 0, 0.08);
  --day-shift-color: #fbbf24;
  --night-shift-color: #6366f1;
  --off-day-color: #999999;
  --success-color: #34d399;
  --warning-color: #fbbf24;
  --error-color: #f87171;
  
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

/* 页面容器 */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 页面标题区 - 与profile页面头像标题区一致 */
.page-header {
  position: relative;
  margin: 30rpx 30rpx 30rpx;
  padding: 65rpx 30rpx 65rpx;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  border-bottom: 2rpx solid var(--border-color);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border-radius: 24rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* 卡片基础样式 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
  animation: fadeInUp 0.5s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  width: 48rpx;
  height: 48rpx;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 日期选择卡片 */
.date-card {
  margin: 30rpx 30rpx 30rpx;
  position: relative;
  z-index: 2;
}

.date-picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.date-picker {
  flex: 1;
}

.date-display {
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.date-display:active {
  background: #e8e8e8;
  transform: scale(0.98);
}

.date-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.date-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.date-separator {
  font-size: 32rpx;
  color: var(--text-tertiary);
  margin: 0 20rpx;
  font-weight: 300;
}

/* 快捷按钮 */
.quick-buttons {
  display: flex;
  gap: 16rpx;
}

.quick-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: var(--bg-color);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.quick-btn:active {
  transform: scale(0.95);
  background: #e8e8e8;
}

.quick-btn.active {
  background: var(--primary-color);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.quick-btn.active:active {
  background: var(--primary-dark);
  transform: scale(0.95);
}

/* 点击波纹效果 */
.quick-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.quick-btn:active::after {
  width: 300rpx;
  height: 300rpx;
}

/* 连续点击动画 */
@keyframes pulse {
  0% {
    box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.5);
    transform: scale(1.02);
  }
  100% {
    box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
    transform: scale(1);
  }
}

.quick-btn.active.pulse {
  animation: pulse 0.5s ease-in-out;
}

/* 班次统计卡片 */
.shift-stats-grid {
  display: flex;
  gap: 20rpx;
}

.shift-stat-item {
  flex: 1;
  background: linear-gradient(145deg, #fafafa 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.shift-stat-item:active {
  transform: translateY(-4rpx);
}

.shift-stat-item.day-shift {
  background: linear-gradient(145deg, #ffeedd 0%, #ffd4a8 100%);
  border-color: rgba(255, 149, 0, 0.3);
}

.shift-stat-item.night-shift {
  background: linear-gradient(145deg, #9ca3af 0%, #6b7280 100%);
  border-color: rgba(107, 114, 128, 0.3);
}

.shift-stat-item.off-day {
  background: linear-gradient(145deg, #f3e8ff 0%, #e9d5ff 100%);
  border-color: rgba(168, 85, 247, 0.3);
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.shift-stat-item.night-shift .stat-icon {
  filter: brightness(1.5);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.shift-stat-item.day-shift .stat-value {
  color: var(--day-shift-color);
}

.shift-stat-item.night-shift .stat-value {
  color: #ffffff;
}

.shift-stat-item.night-shift .stat-label {
  color: rgba(255, 255, 255, 0.8);
}

.shift-stat-item.off-day .stat-value {
  color: #9333ea;
}

.shift-stat-item.off-day .stat-label {
  color: #7c3aed;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 工时统计卡片 */
.hours-stats {
  padding: 10rpx 0;
}

.hours-main {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.hours-item {
  text-align: center;
  flex: 1;
}

.hours-value {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.hours-value.standard {
  color: var(--text-secondary);
}

.hours-value.over {
  color: var(--error-color);
}

.hours-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.hours-divider {
  font-size: 40rpx;
  color: var(--border-color);
  margin: 0 20rpx;
  font-weight: 300;
}

/* 进度条 */
.hours-progress {
  margin-bottom: 24rpx;
}

.progress-bar-bg {
  height: 16rpx;
  background: var(--bg-color);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.progress-bar-fill.under {
  background: linear-gradient(90deg, var(--primary-color) 0%, var(--primary-light) 100%);
}

.progress-bar-fill.over {
  background: linear-gradient(90deg, var(--warning-color) 0%, #ffb84d 100%);
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 工时差额 */
.hours-difference {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  background: var(--bg-color);
}

.hours-difference.positive {
  background: rgba(7, 193, 96, 0.1);
}

.hours-difference.negative {
  background: rgba(250, 81, 81, 0.1);
}

.diff-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-right: 16rpx;
}

.diff-value {
  font-size: 32rpx;
  font-weight: 600;
}

.hours-difference.positive .diff-value {
  color: var(--error-color);
}

.hours-difference.negative .diff-value {
  color: var(--success-color);
}

/* 设置按钮 */
.help-icon-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-color);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.help-icon-btn:active {
  background: #e8e8e8;
  transform: scale(0.9);
}

.help-icon {
  font-size: 28rpx;
}

/* 帮助按钮 - 与profile页面一致 */
.help-btn {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.25);
}

.help-btn:active {
  transform: scale(0.95);
}

.help-btn .help-icon {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

/* 快捷操作按钮 */
.action-buttons {
  display: flex;
  gap: 24rpx;
  margin: 0 30rpx 30rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 12rpx var(--shadow-color);
}

.action-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx var(--shadow-color);
}

.export-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
}

.share-btn {
  background: linear-gradient(135deg, #576b95 0%, #7b8eb8 100%);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 班次明细列表 */
.list-card {
  margin-bottom: 40rpx;
}

.schedule-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  transition: background 0.2s ease;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-item:active {
  background: rgba(0, 0, 0, 0.02);
}

.schedule-date {
  width: 120rpx;
  text-align: center;
}

.date-day {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.date-weekday {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.schedule-type {
  flex: 1;
  display: flex;
  justify-content: center;
}

.type-tag {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.type-tag.day {
  background: linear-gradient(145deg, #ffeedd 0%, #ffd4a8 100%);
  color: #d97706;
}

.type-tag.night {
  background: linear-gradient(145deg, #9ca3af 0%, #6b7280 100%);
  color: #ffffff;
}

.type-tag.off {
  background: linear-gradient(145deg, #f3e8ff 0%, #e9d5ff 100%);
  color: #9333ea;
}

.schedule-time {
  width: 120rpx;
  text-align: right;
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 底部安全区域 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  min-height: 40rpx;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 80%;
  max-width: 600rpx;
  background: var(--card-bg);
  border-radius: 24rpx;
  z-index: 1001;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.modal-content.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.modal-close:active {
  background: var(--bg-color);
}

.close-icon {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.modal-body {
  padding: 30rpx;
}

.input-group {
  margin-bottom: 20rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  background: var(--bg-color);
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.modal-input:focus {
  border-color: var(--primary-color);
  background: #ffffff;
}

.input-hint {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 12rpx;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.modal-btn:active {
  transform: scale(0.98);
}

.modal-btn.cancel {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.modal-btn.cancel:active {
  background: #e8e8e8;
}

.modal-btn.confirm {
  background: var(--primary-color);
  color: #ffffff;
}

.modal-btn.confirm:active {
  background: var(--primary-dark);
}

/* 响应式适配 */
@media (max-width: 320px) {
  .shift-stats-grid {
    gap: 12rpx;
  }
  
  .shift-stat-item {
    padding: 20rpx 10rpx;
  }
  
  .stat-value {
    font-size: 40rpx;
  }
  
  .stat-label {
    font-size: 20rpx;
  }
  
  .quick-buttons {
    gap: 10rpx;
  }
  
  .quick-btn {
    font-size: 22rpx;
    padding: 12rpx 0;
  }
}

@media (min-width: 768px) {
  .card {
    margin: 0 60rpx 40rpx;
  }
  
  .action-buttons {
    margin: 0 60rpx 40rpx;
  }
  
  .shift-stats-grid {
    gap: 30rpx;
  }
  
  .shift-stat-item {
    padding: 30rpx 20rpx;
  }
}
