}

.modal-close-btn:hover {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(1.05);
}

.modal-close-btn:active {
  background: rgba(255, 255, 255, 0.4);
  transform: scale(0.95);
}

/* 弹窗内容区域 */
.modal-content {
  padding: 40rpx 30rpx 20rpx 30rpx;
  background: white;
  width: 100%;
  box-sizing: border-box;
}

