/* CSS Variables - 统一设计系统 */
page {
  --primary-color: #34d399;
  --primary-light: #6ee7b7;
  --primary-dark: #10b981;
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #e5e5e5;
  --shadow-color: rgba(0, 0, 0, 0.08);
  --day-shift-color: #fbbf24;
  --night-shift-color: #6366f1;
  --off-day-color: #999999;
  --success-color: #34d399;
  --warning-color: #fbbf24;
  --error-color: #f87171;
  
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

/* 页面容器 */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
  opacity: 1;
  transition: opacity 0.2s ease-in-out;
}

/* 页面标题区 - 与profile页面头像标题区一致 */
.page-header {
  position: relative;
  margin: 30rpx 30rpx 30rpx;
  padding: 65rpx 30rpx 65rpx;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  border-bottom: 2rpx solid var(--border-color);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border-radius: 24rpx;
  opacity: 1;
  transform: translateY(0);
  transition: all 0.3s ease-in-out;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* 卡片基础样式 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
  transform: translateY(0);
  opacity: 1;
  transition: all 0.3s ease;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.card-icon {
  width: 48rpx;
  height: 48rpx;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 日期选择卡片 */
.date-card {
  margin: 30rpx 30rpx 30rpx;
  position: relative;
  z-index: 2;
}

.date-picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.date-picker {
  flex: 1;
}

.date-display {
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.date-display:active {
  background: #e8e8e8;
  transform: scale(0.98);
}

.date-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.date-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.date-separator {
  font-size: 32rpx;
  color: var(--text-tertiary);
  margin: 0 20rpx;
  font-weight: 300;
}

/* 快捷按钮 */
.quick-buttons {
  display: flex;
  gap: 16rpx;
}

.quick-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: var(--bg-color);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.quick-btn:active {
  transform: scale(0.95);
  background: #e8e8e8;
}

.quick-btn.active {
  background: var(--primary-color);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.quick-btn.active:active {
  background: var(--primary-dark);
  transform: scale(0.95);
}

/* 点击波纹效果 */
.quick-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.quick-btn:active::after {
  width: 300rpx;
  height: 300rpx;
}

/* 连续点击动画 */
@keyframes pulse {
  0% {
    box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.5);
    transform: scale(1.02);
  }
  100% {
    box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
    transform: scale(1);
  }
}

.quick-btn.active.pulse {
  animation: pulse 0.5s ease-in-out;
}

/* 班次统计卡片 - 饼图 */
.pie-chart-wrapper {
  display: flex;
  justify-content: center;
  margin: 10rpx 0;
}

.pie-canvas {
  width: 280rpx;
  height: 280rpx;
}

.pie-legend {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.pie-legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.pie-legend .legend-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 累计工时里程碑 */
.cumulative-card {
  margin-bottom: 30rpx;
}

.cumulative-body {
  display: flex;
  align-items: baseline;
  justify-content: center;
  padding: 16rpx 0 12rpx;
}

.cumulative-number {
  font-size: 88rpx;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -2rpx;
  background: linear-gradient(135deg, #34d399 0%, #059669 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.cumulative-unit {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-left: 10rpx;
}

.cumulative-divider {
  height: 2rpx;
  margin: 0 20rpx 20rpx;
  background: repeating-linear-gradient(
    90deg,
    #d1fae5 0rpx,
    #d1fae5 8rpx,
    transparent 8rpx,
    transparent 16rpx
  );
}

.cumulative-info {
  background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
  border-radius: 16rpx;
  padding: 20rpx;
}

.cumulative-info-item {
  margin-bottom: 12rpx;
}

.cumulative-info-item:last-child {
  margin-bottom: 0;
}

.cumulative-info-row {
  display: flex;
  gap: 20rpx;
}

.cumulative-info-row .cumulative-info-item {
  flex: 1;
  margin-bottom: 0;
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 4rpx;
}

.info-value {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 图表卡片 */
.chart-card {
  margin-bottom: 30rpx;
}

.chart-controls {
  display: flex;
  gap: 12rpx;
  margin-left: auto;
  align-items: center;
}

/* 图表类型选择器 */
.chart-type-selector {
  margin-left: auto;
  display: flex;
  justify-content: flex-end;
}

.chart-type-container {
  display: flex;
  background: var(--bg-color);
  border-radius: 20rpx;
  padding: 4rpx;
  box-shadow: 0 2rpx 8rpx var(--shadow-color);
}

.chart-type-option {
  flex: 1;
  padding: 8rpx 20rpx;
  text-align: center;
  font-size: 20rpx;
  color: var(--text-secondary);
  border-radius: 16rpx;
  transition: all 0.3s ease;
  position: relative;
}

.chart-type-option.active {
  background: #07c160;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
}

.chart-type-divider {
  width: 2rpx;
  background: var(--border-color);
  margin: 6rpx 0;
  border-radius: 1rpx;
}

.chart-control-btn {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  background: var(--bg-color);
  color: var(--text-secondary);
  transition: all 0.3s ease;
}

.chart-control-btn.active {
  background: var(--primary-color);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
}

.chart-container {
  position: relative;
  width: 100%;
  min-height: 60rpx;
  margin-top: 16rpx;
}

/* 工时热力图 */
.heatmap-card {
  overflow: hidden;
}

.heatmap-blur-card {
  background: rgba(245, 245, 245, 0.65);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border-radius: 20rpx;
  padding: 24rpx 20rpx 20rpx;
  border: 1rpx solid rgba(230, 230, 230, 0.6);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.heatmap-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.heatmap-header {
  display: flex;
  gap: inherit;
  margin-bottom: 8rpx;
  padding: 0 4rpx;
}

.heatmap-header-label {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.heatmap-body {
  display: flex;
  flex-direction: column;
  gap: inherit;
}

.heatmap-row {
  display: flex;
  gap: inherit;
}

.heatmap-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  position: relative;
  overflow: hidden;
}

.heatmap-cell:active {
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  z-index: 1;
}

.heatmap-cell-blur {
  background-color: #f5f5f5 !important;
  pointer-events: none;
  border-radius: 6rpx;
}

.heatmap-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.legend-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin: 0 4rpx;
}

.legend-item {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

/* 工时统计卡片 */
.hours-stats {
  padding: 10rpx 0;
}

.hours-main {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.hours-item {
  text-align: center;
  flex: 1;
}

.hours-value {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.hours-value.standard {
  color: var(--text-secondary);
}

.hours-value.over {
  color: var(--error-color);
}

.hours-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.hours-divider {
  font-size: 40rpx;
  color: var(--border-color);
  margin: 0 20rpx;
  font-weight: 300;
}

/* 进度条 */
.hours-progress {
  margin-bottom: 24rpx;
}

.progress-bar-bg {
  height: 16rpx;
  background: var(--bg-color);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.progress-bar-fill.under {
  background: linear-gradient(90deg, var(--primary-color) 0%, var(--primary-light) 100%);
}

.progress-bar-fill.over {
  background: linear-gradient(90deg, var(--warning-color) 0%, #ffb84d 100%);
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 工时差额 */
.hours-difference {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  background: var(--bg-color);
}

.hours-difference.positive {
  background: rgba(7, 193, 96, 0.1);
}

.hours-difference.negative {
  background: rgba(250, 81, 81, 0.1);
}

.diff-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-right: 16rpx;
}

.diff-value {
  font-size: 32rpx;
  font-weight: 600;
}

.hours-difference.positive .diff-value {
  color: var(--error-color);
}

.hours-difference.negative .diff-value {
  color: var(--success-color);
}

/* 设置按钮 */
.help-icon-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-color);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.help-icon-btn:active {
  background: #e8e8e8;
  transform: scale(0.9);
}

.help-icon {
  font-size: 28rpx;
}

/* 帮助按钮 - 与profile页面一致 */
.help-btn {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.25);
}

.help-btn:active {
  transform: scale(0.95);
}

.help-btn .help-icon {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

/* 快捷操作按钮 */
.action-buttons {
  display: flex;
  gap: 24rpx;
  margin: 0 30rpx 30rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 12rpx var(--shadow-color);
}

.action-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx var(--shadow-color);
}

.export-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
}

.share-btn {
  background: linear-gradient(135deg, #576b95 0%, #7b8eb8 100%);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 班次明细列表 */
.list-card {
  margin-bottom: 40rpx;
}

.schedule-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  transition: background 0.2s ease;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-item:active {
  background: rgba(0, 0, 0, 0.02);
}

.schedule-date {
  width: 120rpx;
  text-align: center;
}

.date-day {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.date-weekday {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.schedule-type {
  flex: 1;
  display: flex;
  justify-content: center;
}

.type-tag {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.type-tag.day {
  background: linear-gradient(145deg, #ffeedd 0%, #ffd4a8 100%);
  color: #d97706;
}

.type-tag.night {
  background: linear-gradient(145deg, #9ca3af 0%, #6b7280 100%);
  color: #ffffff;
}

.type-tag.off {
  background: linear-gradient(145deg, #f3e8ff 0%, #e9d5ff 100%);
  color: #9333ea;
}

.schedule-time {
  width: 120rpx;
  text-align: right;
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.empty-text.small {
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  min-height: 40rpx;
}

/* 模态框（WeUI 半屏样式） */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
  max-height: 75vh;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.modal-container.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.modal-title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.modal-close:active {
  background: #f5f5f5;
  transform: scale(0.9);
}

.close-icon {
  font-size: 32rpx;
  color: #999;
  font-weight: 300;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 0;
  max-height: calc(75vh - 160rpx);
}

.input-group {
  margin-bottom: 20rpx;
  padding: 0 24rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  background: var(--bg-color);
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.modal-input:focus {
  border-color: var(--primary-color);
  background: #ffffff;
}

.input-hint {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 12rpx;
}

/* 表单卡片 */
.form-card {
  margin: 8rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.form-group {
  padding: 28rpx 28rpx 24rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.form-label-ext {
  font-size: 22rpx;
  color: var(--text-tertiary);
  background: var(--bg-color);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 14rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  background: #f8f9fa;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: var(--primary-color);
  background: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(52, 211, 153, 0.1);
}

.input-suffix-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.input-suffix {
  padding-right: 100rpx;
}

.input-suffix-label {
  position: absolute;
  right: 24rpx;
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  pointer-events: none;
}

.form-hint {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
}

.form-hint-highlight {
  color: var(--primary-dark);
  font-weight: 600;
}

.modal-footer {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #ffffff;
  flex-shrink: 0;
  display: flex;
  gap: 16rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  margin: 0;
  transition: all 0.2s ease;
}

.modal-btn::after {
  border: none;
}

.modal-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-cancel {
  background: #f3f4f6;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.3);
}

/* 响应式适配 */
@media (max-width: 320px) {
  .pie-canvas {
    width: 220rpx;
    height: 220rpx;
  }

  .pie-legend {
    gap: 20rpx;
  }

  .pie-legend .legend-label {
    font-size: 20rpx;
  }
  
  .quick-buttons {
    gap: 10rpx;
  }
  
  .quick-btn {
    font-size: 22rpx;
    padding: 12rpx 0;
  }
  
  .hours-value {
    font-size: 48rpx;
  }
  
  .action-btn {
    padding: 24rpx 0;
  }
  
  .btn-text {
    font-size: 28rpx;
  }
}

/* 平板设备适配 */
@media (min-width: 768px) {
  .card {
    margin: 0 60rpx 40rpx;
    padding: 40rpx;
  }
  
  .date-card {
    margin: 40rpx 60rpx 40rpx;
  }
  
  .action-buttons {
    margin: 0 60rpx 40rpx;
  }
  
  .pie-canvas {
    width: 340rpx;
    height: 340rpx;
  }

  .pie-legend .legend-label {
    font-size: 28rpx;
  }

  .header-title {
    font-size: 56rpx;
  }

  .header-subtitle {
    font-size: 32rpx;
  }

  .card-title {
    font-size: 36rpx;
  }
  
  .hours-value {
    font-size: 64rpx;
  }
  
  .hours-label {
    font-size: 28rpx;
  }
  
  .btn-text {
    font-size: 32rpx;
  }
  
  .modal-title {
    font-size: 36rpx;
  }
  
  .input-label {
    font-size: 32rpx;
  }
  
  .modal-input {
    font-size: 36rpx;
    height: 100rpx;
  }
  
  .modal-btn {
    font-size: 32rpx;
    padding: 28rpx 0;
  }
}

/* 横屏适配 */
@media (orientation: landscape) {
  .container {
    padding-bottom: 20rpx;
  }
  
  .page-header {
    margin: 20rpx 20rpx 20rpx;
    padding: 40rpx 30rpx 40rpx;
  }
  
  .card {
    margin: 0 20rpx 20rpx;
  }
  
  .date-card {
    margin: 20rpx 20rpx 20rpx;
  }
  
  .action-buttons {
    margin: 0 20rpx 20rpx;
  }
  
  /* 横屏时的布局调整 */
  .stats-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20rpx;
  }
  
  .hours-card {
    grid-column: 1;
  }
  
  .chart-card {
    grid-column: 2;
  }
  
  .stats-card {
    grid-column: 1 / 3;
  }
  
  .list-card {
    grid-column: 1 / 3;
  }

  /* 工时统计横屏布局 */
  .hours-stats {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
  }
  
  .hours-main {
    margin-bottom: 0;
  }
  
  /* 班次明细列表横屏布局 */
  .schedule-list {
    max-height: 400rpx;
  }
  
  .schedule-item {
    padding: 20rpx 0;
  }
  
  .schedule-date {
    width: 100rpx;
  }
  
  .schedule-time {
    width: 100rpx;
  }
}

/* 选择器样式 */
.selector-wrapper {
  position: relative;
  margin-left: 12rpx;
  z-index: 99999;
}

.dropdown-selector {
  position: absolute;
  top: 100%;
  right: 0;
  margin-top: 8rpx;
  background: var(--card-bg);
  border-radius: 12rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
  z-index: 99999;
  min-width: 200rpx;
  max-width: 300rpx;
  max-height: 400rpx;
  overflow-y: auto;
  opacity: 1;
  background-color: #ffffff;
  pointer-events: auto;
}

.chart-control-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  background: var(--bg-color);
  color: var(--text-secondary);
  transition: all 0.3s ease;
  cursor: pointer;
  opacity: 1;
  z-index: 9999;
}

.picker-content {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.chart-control-btn.active {
  background: var(--primary-color);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
}

.selector-arrow {
  font-size: 16rpx;
  transition: transform 0.3s ease;
}

.selector-arrow.active {
  transform: rotate(180deg);
}

.dropdown-selector {
  position: absolute;
  top: 100%;
  right: 0;
  margin-top: 8rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
  z-index: 99999;
  min-width: 200rpx;
  max-width: 300rpx;
  max-height: 400rpx;
  overflow-y: auto;
  opacity: 1;
  pointer-events: auto;
}

.dropdown-item {
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: all 0.2s ease;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  background-color: #ffffff;
  opacity: 1;
}

.dropdown-item:last-child {
  border-bottom: none;
  border-radius: 0 0 12rpx 12rpx;
}

.dropdown-item:active {
  background: var(--bg-color);
}

.dropdown-item {
  font-size: 24rpx;
  color: var(--text-primary);
}

/* 平板横屏适配 */
@media (min-width: 768px) and (orientation: landscape) {
  .stats-container {
    grid-template-columns: 1fr 1fr;
    gap: 30rpx;
  }
  
  .hours-card {
    grid-column: 1;
  }
  
  .chart-card {
    grid-column: 2;
  }
  
  .stats-card {
    grid-column: 1 / 3;
  }

  .pie-canvas {
    width: 320rpx;
    height: 320rpx;
  }
  
  .hours-value {
    font-size: 56rpx;
  }
  
  .schedule-list {
    max-height: 500rpx;
  }
  
  .schedule-item {
    padding: 24rpx 0;
  }
  
  .schedule-date {
    width: 120rpx;
  }
  
  .schedule-time {
    width: 120rpx;
  }
  
  .type-tag {
    font-size: 28rpx;
    padding: 12rpx 32rpx;
  }
  
  .modal-body {
    padding: 40rpx;
  }
  
  .input-group {
    margin-bottom: 30rpx;
  }
  
  .input-label {
    font-size: 36rpx;
    margin-bottom: 20rpx;
  }
  
  .modal-input {
    font-size: 40rpx;
    height: 120rpx;
    padding: 0 32rpx;
  }
  
  .modal-footer {
    padding: 30rpx 40rpx 40rpx;
  }
  
  .modal-btn {
    font-size: 36rpx;
    padding: 32rpx 0;
  }
  
  /* 选择器平板适配 */
  .chart-control-btn {
    padding: 12rpx 24rpx;
    font-size: 28rpx;
  }
  
  .selector-arrow {
    font-size: 20rpx;
  }
  
  .dropdown-selector {
    min-width: 240rpx;
    max-width: 360rpx;
  }
  
  .dropdown-item {
    padding: 20rpx 24rpx;
    font-size: 28rpx;
  }
}

/* 周期选择器按钮 */
.period-selector-buttons {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 24rpx;
}

.period-selector-buttons picker {
  flex: 1;
  min-width: 0;
}

.period-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 18rpx 12rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.period-btn:active {
  transform: scale(0.95);
  background: #e8e8e8;
}

.period-btn.active {
  background: var(--primary-color);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.period-btn-text {
  font-size: 28rpx;
  font-weight: 500;
}

.period-btn-arrow {
  font-size: 18rpx;
  transition: transform 0.3s ease;
}

.period-btn-arrow.active {
  transform: rotate(180deg);
}

/* 隐藏的 picker 触发器 */
.picker-trigger {
  position: absolute;
  width: 0;
  height: 0;
  opacity: 0;
}

/* 平板设备周期选择器适配 */
@media (min-width: 768px) {
  .period-btn {
    padding: 20rpx 0;
  }
  
  .period-btn-text {
    font-size: 30rpx;
  }
  
  .period-btn-arrow {
    font-size: 20rpx;
  }
}
