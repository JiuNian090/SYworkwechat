}

.usage-guide {
  margin-top: 20rpx;
  padding: 10rpx 0;
}

.usage-guide-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.4;
  text-align: justify;
  text-indent: 2em;
}

/* 工时差额样式 */
