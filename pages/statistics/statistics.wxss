/* pages/statistics/statistics.wxss */
/* 主色变量和统一按钮样式 */
.main-color {
  color: #07c160;
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(7,193,96,0.08);
}
.btn-primary:active {
  background: #059e4d;
}
.modal {
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12);
}
.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 20rpx 0;
}

.date-selector {
  display: flex;
  justify-content: space-between;
  margin: 30rpx 0;
  background: linear-gradient(180deg, #ffffff, #f8f8f8);
  padding: 25rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 1rpx solid #eee;
  position: relative;
}

.date-selector::before {
  content: "📅";
  position: absolute;
  top: -15rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #07c160;
  color: white;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.4);
}

.date-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.date-item:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 60rpx;
  background: #e0e0e0;
}

.label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  position: relative;
}

.label::before {
  content: "📅";
  margin-right: 10rpx;
}

.picker {
  font-size: 34rpx;
  font-weight: bold;
  color: #07c160;
  padding: 15rpx 20rpx;
  background: #f0fff0;
  border-radius: 12rpx;
  min-width: 180rpx;
  text-align: center;
  border: 2rpx solid #e0f0e0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  transition: all 0.3s ease;
}

.picker:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.1);
}

.summary {
  background: #f8f8f8;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.summary-item:last-child {
  margin-bottom: 0;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
}

.summary-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.summary-value.highlight {
  color: #07c160;
  font-size: 32rpx;
}

.shifts-list {
  margin: 30rpx 0;
}

.list-header {
  padding: 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.shift-item {
  display: flex;
  padding: 15rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
  background: #fff;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.05);
}

.shift-date {
  width: 140rpx;
  font-size: 24rpx;
  color: #07c160;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.shift-content {
  flex: 1;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 6rpx 15rpx;
  padding-left: 15rpx;
  border-left: 1rpx dashed #e0e0e0;
}

.shift-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1 1 100%;
}

.shift-time, .shift-hours, .shift-type {
  font-size: 20rpx;
  color: #666;
  flex: 1;
  min-width: 120rpx;
}

.shift-time, .shift-hours, .shift-type {
  font-size: 20rpx;
  color: #666;
}

.shift-time::before {
  content: "⏰ ";
}

.shift-hours::before {
  content: "⏱️ ";
}

.shift-type::before {
  content: "🏷️ ";
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 50rpx 0;
}

.export-section {
  padding: 30rpx;
  background-color: #f8f8f8;
  border-radius: 10rpx;
  margin: 20rpx 0;
}

.input-item {
  margin-bottom: 20rpx;
}

.filename-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 80rpx;
}

.button-group {
  display: flex;
  gap: 20rpx;
}

.export-btn, .share-btn {
  flex: 1;
  background-color: #007aff;
  color: white;
  border: none;
  padding: 15rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
}

.share-btn {
  background-color: #34c759;
}