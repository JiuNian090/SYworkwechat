}

/* 弹窗样式 */
/* 模态框通用样式 - 统一弹窗设计 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

/* 基础弹窗样式 - 与表情头像弹窗保持一致 */
.modal-container {
  width: 90%;
  max-width: 600rpx;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.18);
  overflow: hidden;
  background: white;
  animation: modalSlideIn 0.3s ease-out;
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1000;
}

/* 模态框滑入动画 */
@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) translateY(0);
  }
}

/* 弹窗头部样式 - 渐变背景 */
.modal-header {
  background: linear-gradient(135deg, #07c160 0%, #059e4d 100%);
  color: white;
  border: none;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 弹窗标题样式 */
.modal-title {
  color: white;
  font-size: 36rpx;
  font-weight: 600;
}

/* 关闭按钮样式 */
.modal-close-btn {
  width: 60rpx;
  height: 60rpx;
  padding: 0;
  margin: 0;
  background: rgba(255, 255, 255, 0.2);
  border: none;
  font-size: 36rpx;
