<view class="container">
  <!-- 页面标题区 -->
  <view class="page-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <text class="header-title">📊 统计概览</text>
      <text class="header-subtitle">班次与工时统计分析</text>
    </view>
  </view>

  <!-- 日期选择卡片 -->
  <view class="card date-card">
    <view class="card-header">
      <view class="card-icon">📅</view>
      <text class="card-title">日期范围</text>
      <view class="help-btn" bindtap="navigateToDocs" data-type="statistics">
        <text class="help-icon">?</text>
      </view>
    </view>
    <view class="date-picker-row">
      <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange" class="date-picker">
        <view class="date-display">
          <text class="date-label">开始</text>
          <text class="date-value">{{startDate}}</text>
        </view>
      </picker>
      <view class="date-separator">~</view>
      <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange" class="date-picker">
        <view class="date-display">
          <text class="date-label">结束</text>
          <text class="date-value">{{endDate}}</text>
        </view>
      </picker>
    </view>
    <view class="quick-buttons">
      <view class="quick-btn {{activeQuickBtn === 'lastWeek' ? 'active' : ''}}" bindtap="selectLastWeek">上周</view>
      <view class="quick-btn {{activeQuickBtn === 'thisWeek' ? 'active' : ''}}" bindtap="selectThisWeek">本周</view>
      <view class="quick-btn {{activeQuickBtn === 'nextWeek' ? 'active' : ''}}" bindtap="selectNextWeek">下周</view>
      <view class="quick-btn {{activeQuickBtn === 'thisMonth' ? 'active' : ''}}" bindtap="selectThisMonth">本月</view>
    </view>
    <view class="period-selector-buttons">
      <!-- 周选择器 -->
      <picker 
        mode="multiSelector" 
        range="{{weekPickerRange}}" 
        value="{{weekPickerValue}}" 
        bindchange="onWeekPickerChange"
        bindcolumnchange="onWeekPickerColumnChange"
      >
        <view class="period-btn {{activePeriodBtn === 'week' ? 'active' : ''}}">
          <text class="period-btn-text">指定周</text>
          <text class="period-btn-arrow">▼</text>
        </view>
      </picker>
      
      <!-- 月选择器 -->
      <picker 
        mode="multiSelector" 
        range="{{monthPickerRange}}" 
        value="{{monthPickerValue}}" 
        bindchange="onMonthPickerChange"
        bindcolumnchange="onMonthPickerColumnChange"
      >
        <view class="period-btn {{activePeriodBtn === 'month' ? 'active' : ''}}">
          <text class="period-btn-text">指定月</text>
          <text class="period-btn-arrow">▼</text>
        </view>
      </picker>
      
      <!-- 年选择器 -->
      <picker 
        mode="selector" 
        range="{{yearOptions}}" 
        value="{{yearPickerValue}}" 
        bindchange="onYearPickerChange"
      >
        <view class="period-btn {{activePeriodBtn === 'year' ? 'active' : ''}}">
          <text class="period-btn-text">指定年</text>
          <text class="period-btn-arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 统计卡片容器 -->
  <view class="stats-container">
    <!-- 工时统计卡片 -->
    <view class="card hours-card">
      <view class="card-header">
        <view class="card-icon">⏱️</view>
        <text class="card-title">工时统计</text>
        <view class="help-icon-btn" bindtap="showCustomHoursModal">
          <text class="help-icon">⚙️</text>
        </view>
      </view>
      <view class="hours-stats">
        <view class="hours-main">
          <view class="hours-item">
            <text class="hours-value {{totalHours >= standardHours ? 'over' : ''}}">{{totalHours}}</text>
            <text class="hours-label">实际工时</text>
          </view>
          <view class="hours-divider">/</view>
          <view class="hours-item">
            <text class="hours-value standard">{{standardHours}}</text>
            <text class="hours-label">标准工时</text>
          </view>
        </view>
        <view class="hours-progress">
          <view class="progress-bar-bg">
            <view class="progress-bar-fill {{totalHours >= standardHours ? 'over' : 'under'}}" style="width: {{(standardHours > 0 ? (totalHours / standardHours * 100) : 0) > 100 ? 100 : (standardHours > 0 ? (totalHours / standardHours * 100) : 0)}}% "></view>
          </view>
          <text class="progress-text">{{progressText}}</text>
        </view>
        <view class="hours-difference {{hourDifference >= 0 ? 'positive' : 'negative'}}">
          <text class="diff-label">{{hourDifference > 0 ? '工时超额' : '工时差额'}}</text>
          <text class="diff-value">{{hourDifferenceWithSign}}h</text>
        </view>
      </view>
    </view>

    <!-- 工时趋势图表 -->
    <view class="card chart-card">
      <view class="card-header">
        <view class="card-icon">📊</view>
        <text class="card-title">工时趋势</text>
        <!-- 图表类型选择 -->
        <view class="chart-type-selector">
          <view class="chart-type-container">
            <view class="chart-type-option {{chartType === 'line' ? 'active' : ''}}" bindtap="changeChartType" data-type="line">
              <text>折线图</text>
            </view>
            <view class="chart-type-divider"></view>
            <view class="chart-type-option {{chartType === 'bar' ? 'active' : ''}}" bindtap="changeChartType" data-type="bar">
              <text>柱状图</text>
            </view>
          </view>
        </view>
      </view>
      <view class="chart-container">
        <canvas type="2d" id="lineCanvas" style="width: 100%; height: 310px;"></canvas>
      </view>
    </view>

    <!-- 工时热力图 -->
    <view class="card heatmap-card" wx:if="{{heatmapWeeks.length > 0}}">
      <view class="card-header">
        <view class="card-icon">🔥</view>
        <text class="card-title">工时热力图</text>
        <text class="card-subtitle">{{statistics.totalDays}} 天</text>
      </view>
      <view class="heatmap-container" style="gap: {{heatmapGapRpx}}rpx;">
          <view wx:if="{{heatmapColumnsPerRow === 7}}" class="heatmap-header" style="gap: {{heatmapGapRpx}}rpx;">
            <text wx:for="{{heatmapWeekLabels}}" wx:key="index" class="heatmap-header-label" style="width: {{heatmapCellSizeRpx}}rpx;">{{item}}</text>
          </view>
          <view class="heatmap-body" style="gap: {{heatmapGapRpx}}rpx;">
            <view class="heatmap-row" wx:for="{{heatmapWeeks}}" wx:key="index" style="gap: {{heatmapGapRpx}}rpx;">
              <block wx:for="{{item}}" wx:for-item="cell" wx:key="index">
                <view wx:if="{{cell.isPlaceholder}}"
                  class="heatmap-cell heatmap-cell-blur"
                  style="width: {{heatmapCellSizeRpx}}rpx; height: {{heatmapCellSizeRpx}}rpx;"
                ></view>
                <view wx:else
                  class="heatmap-cell"
                  style="width: {{heatmapCellSizeRpx}}rpx; height: {{heatmapCellSizeRpx}}rpx; background-color: {{cell.color}};"
                  bindtap="onHeatmapCellTap"
                  data-date="{{cell.date}}"
                  data-hours="{{cell.workHours}}"
                  data-type="{{cell.shiftType}}"
                ></view>
              </block>
            </view>
          </view>
        </view>
      <view class="heatmap-legend">
        <text class="legend-label">0</text>
        <view class="legend-item" style="background-color: #ebedf0;"></view>
        <view class="legend-item" style="background-color: #c6e48b;"></view>
        <view class="legend-item" style="background-color: #7bc96f;"></view>
        <view class="legend-item" style="background-color: #5aad4a;"></view>
        <view class="legend-item" style="background-color: #3d8b37;"></view>
        <view class="legend-item" style="background-color: #2d6a2b;"></view>
        <text class="legend-label">≥9h</text>
      </view>
    </view>

    <!-- 班次统计卡片 -->
    <view class="card stats-card">
      <view class="card-header">
        <view class="card-icon">📈</view>
        <text class="card-title">班次统计</text>
        <text class="card-subtitle">共 {{statistics.totalDays}} 天</text>
      </view>
      <view class="pie-chart-wrapper">
        <canvas type="2d" id="pieCanvas" class="pie-canvas"></canvas>
      </view>
      <view class="pie-legend">
        <view class="pie-legend-item">
          <view class="legend-dot" style="background-color: #FCD34D;"></view>
          <text class="legend-label">白天班 {{statistics.dayShifts}} 天</text>
        </view>
        <view class="pie-legend-item">
          <view class="legend-dot" style="background-color: #93C5FD;"></view>
          <text class="legend-label">跨夜班 {{statistics.nightShifts}} 天</text>
        </view>
        <view class="pie-legend-item">
          <view class="legend-dot" style="background-color: #D8B4FE;"></view>
          <text class="legend-label">休息日 {{statistics.offDays}} 天</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷操作区 -->
  <view class="action-buttons">
    <view class="action-btn export-btn" bindtap="onExportBtnTap">
      <text class="btn-icon">📥</text>
      <text class="btn-text">导出CSV</text>
    </view>
    <view class="action-btn share-btn" bindtap="shareCSV">
      <text class="btn-icon">📤</text>
      <text class="btn-text">分享文件</text>
    </view>
  </view>

  <!-- 班次明细列表 -->
  <view class="card list-card">
    <view class="card-header">
      <view class="card-icon">📋</view>
      <text class="card-title">班次明细</text>
      <text class="card-subtitle">{{listTotalCount}} 条记录</text>
    </view>
    <scroll-view 
      class="schedule-list" 
      scroll-y="true" 
      enhanced="true" 
      show-scrollbar="false"
      enable-back-to-top="true"
      bindscroll="onScheduleScroll"
      wx:if="{{visibleSchedules.length > 0}}"
    >
      <view style="padding-top: {{listTopPadding}}px; padding-bottom: {{listBottomPadding}}px;">
        <view class="schedule-item" wx:for="{{visibleSchedules}}" wx:key="date">
          <view class="schedule-date">
            <text class="date-day">{{item.day}}</text>
            <text class="date-weekday">{{item.weekday}}</text>
          </view>
          <view class="schedule-type">
            <view class="type-tag {{item.shiftType === '白天班' ? 'day' : item.shiftType === '跨夜班' ? 'night' : 'off'}}">
              {{item.shiftType}}
            </view>
          </view>
          <view class="schedule-time">
            <text>{{item.workHours || '--:--'}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="schedule-list" wx:elif="{{listTotalCount === 0}}">
      <view class="empty-state">
        <text class="empty-icon">📭</text>
        <text class="empty-text">该时间段暂无班次记录</text>
      </view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>

<!-- 文件名设置模态框 -->
<block wx:if="{{showFilenameModal}}">
  <view class="modal-mask show" bindtap="hideFilenameModal">
    <view class="modal-content show" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">设置文件名</text>
        <view class="modal-close" bindtap="hideFilenameModal">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">CSV文件名</text>
          <input 
            type="text" 
            value="{{tempFilename}}" 
            bindinput="onFilenameInput"
            placeholder="请输入文件名"
            class="modal-input"
          />
          <text class="input-hint">将保存为 {{tempFilename || defaultFilenameHint}}.csv</text>
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="hideFilenameModal">取消</view>
        <view class="modal-btn confirm" bindtap="confirmExport">确认导出</view>
      </view>
    </view>
  </view>
</block>

<!-- 自定义工时设置模态框 -->
<block wx:if="{{showHoursModal}}">
  <view class="modal-mask show" bindtap="hideCustomHoursModal">
    <view class="modal-content show" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">设置标准工时</text>
        <view class="modal-close" bindtap="hideCustomHoursModal">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">每周标准工时（小时）</text>
          <input 
            type="digit" 
            value="{{tempCustomHours}}" 
            bindinput="onCustomHoursInput"
            placeholder="请输入标准工时"
            class="modal-input"
          />
          <text class="input-hint">默认值为 35 小时/周</text>
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="hideCustomHoursModal">取消</view>
        <view class="modal-btn confirm" bindtap="saveCustomHours">保存设置</view>
      </view>
    </view>
  </view>
</block>
