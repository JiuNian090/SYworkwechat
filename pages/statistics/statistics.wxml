<!-- pages/statistics/statistics.wxml -->
<view class="container">
  <view class="header">
    <text class="title">排班统计</text>
  </view>

  <view class="date-selector">
    <view class="date-item">
      <text class="label">开始日期</text>
      <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
        <view class="picker">
          {{startDate}}
        </view>
      </picker>
    </view>
    
    <view class="date-item">
      <text class="label">结束日期</text>
      <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
        <view class="picker">
          {{endDate}}
        </view>
      </picker>
    </view>
  </view>

  <!-- 添加快速选择按钮 -->
  <view class="quick-select-buttons">
    <button class="quick-btn {{selectedQuickBtn === 'lastWeek' ? 'quick-btn-selected' : ''}}" bindtap="selectLastWeek">上周</button>
    <button class="quick-btn {{selectedQuickBtn === 'thisWeek' ? 'quick-btn-selected' : ''}}" bindtap="selectThisWeek">本周</button>
    <button class="quick-btn {{selectedQuickBtn === 'nextWeek' ? 'quick-btn-selected' : ''}}" bindtap="selectNextWeek">下周</button>
    <button class="quick-btn {{selectedQuickBtn === 'thisMonth' ? 'quick-btn-selected' : ''}}" bindtap="selectThisMonth">本月</button>
  </view>

  <view class="summary">
    <view class="summary-item">
      <text class="summary-label">统计区间</text>
      <text class="summary-value">{{startDate}} 至 {{endDate}}</text>
    </view>
    
    <view class="summary-item">
      <text class="summary-label">总工时</text>
      <text class="summary-value highlight">{{totalHours}} 小时</text>
    </view>
    
    <!-- 新增统计项 -->
    <view class="summary-item">
      <text class="summary-label">排班天数</text>
      <text class="summary-value">{{statistics.totalDays}} 天</text>
    </view>
    
    <view class="summary-item">
        <text class="summary-label">工作班次</text>
        <text class="summary-value">{{statistics.workDays}}天</text>
      </view>
    
    <view class="summary-item">
      <text class="summary-label">休息日</text>
      <text class="summary-value">{{statistics.offDays}} 天</text>
    </view>
    
    
  </view>

  <view class="export-section">
    <view class="input-item">
      <input class="filename-input" placeholder="请输入导出文件名(不含扩展名)" value="{{exportFileName}}" bindinput="onFileNameInput"></input>
    </view>
    <view class="button-group">
      <button class="export-btn" bindtap="exportToCSV">导出为CSV文件</button>
      <button class="share-btn" bindtap="shareCSV">分享CSV文件</button>
    </view>
    <view class="usage-guide">
      <text class="usage-guide-text">使用说明：
        1. 输入文件名可以按照（姓名+日期范围），点击导出CSV文件;
        2. 出现导出成功提示后，点击分享，可以分享给自己;
        3. 在聊天界面点击CSV，选择用WPS打开，即可生成报表！
        4. 下面排班详情会显示选定日期内的所有排班!</text>
    </view>
  </view>

  <view class="shifts-list">
    <view class="list-header">
      <text>排班详情</text>
    </view>
    
    <view class="shift-item" wx:for="{{shifts}}" wx:key="date">
      <view class="shift-date">
        {{item.date}}
      </view>
      <view class="shift-content">
        <text class="shift-name">{{item.name}}</text>
        <text class="shift-time">{{item.startTime}}-{{item.endTime}}</text>
        <text class="shift-hours">{{item.workHours}}小时</text>
        <text class="shift-type">{{item.type}}</text>
      </view>
    </view>
    
    <view wx:if="{{shifts.length === 0}}" class="empty-tip">
      所选日期范围内无排班记录
    </view>
  </view>
</view>