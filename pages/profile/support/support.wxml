<!-- support.wxml - 支持页面结构 -->
<view class="support-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">{{title}}</text>
  </view>

  <!-- 联系信息卡片 -->
  <view class="contact-card">
    <view class="card-header">
      <text class="card-title">联系我们</text>
    </view>
    
    <!-- 电话联系 -->
    <view class="contact-item" bindtap="contactCustomerService">
      <view class="contact-icon">📞</view>
      <view class="contact-info">
        <text class="contact-label">客服电话</text>
        <text class="contact-value">{{contactInfo.phone}}</text>
      </view>
      <view class="contact-arrow">›</view>
    </view>

    <!-- 邮箱联系 -->
    <view class="contact-item" bindtap="copyEmail">
      <view class="contact-icon">✉️</view>
      <view class="contact-info">
        <text class="contact-label">电子邮箱</text>
        <text class="contact-value">{{contactInfo.email}}</text>
      </view>
      <view class="contact-arrow">›</view>
    </view>

    <!-- 微信联系 -->
    <view class="contact-item" bindtap="copyWechat">
      <view class="contact-icon">💬</view>
      <view class="contact-info">
        <text class="contact-label">微信客服</text>
        <text class="contact-value">{{contactInfo.wechat}}</text>
      </view>
      <view class="contact-arrow">›</view>
    </view>
  </view>

  <!-- 服务时间 -->
  <view class="service-time">
    <text class="time-title">服务时间</text>
    <text class="time-content">周一至周五 9:00-18:00</text>
  </view>

  <!-- 常见问题 -->
  <view class="faq-section">
    <text class="faq-title">常见问题</text>
    <view class="faq-item">
      <text class="faq-question">Q: 如何导出数据？</text>
      <text class="faq-answer">A: 在个人中心页面点击"导出数据"按钮即可。</text>
    </view>
    <view class="faq-item">
      <text class="faq-question">Q: 数据丢失怎么办？</text>
      <text class="faq-answer">A: 可以通过"导入数据"功能恢复备份。</text>
    </view>
  </view>
</view>