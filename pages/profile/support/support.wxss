/* pages/profile/support/support.wxss */
.container {
  padding: 20rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
  text-align: center;
  margin: 20rpx 0;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
  margin: 30rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #f0f0f0;
}

.content {
  text-align: center;
}

.description {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 40rpx;
  display: block;
}

.reward-section {
  margin: 50rpx 0;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
}

.reward-image {
  width: 80%;
  max-width: 500rpx;
  margin: 0 auto;
  display: block;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.image-tip {
  font-size: 24rpx;
  color: #666;
  margin-top: 20rpx;
  display: block;
}

.support-info {
  margin-top: 50rpx;
  padding: 30rpx;
  background: #f0f8ff;
  border-radius: 12rpx;
  border: 1rpx dashed #4a90e2;
}

.info-text {
  font-size: 28rpx;
  color: #4a90e2;
  line-height: 1.6;
  display: block;
}