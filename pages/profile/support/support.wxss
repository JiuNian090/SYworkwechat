/* pages/profile/support/support.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  padding: 40rpx 0;
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.content {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 40rpx;
  text-align: center;
}

.qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.qr-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.qr-image {
  width: 320rpx;
  height: 320rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}

.divider {
  height: 2rpx;
  background-color: #eee;
  margin: 40rpx 0;
}

.footer {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
}

.home-button {
  background-color: #007aff;
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.3);
}

.home-button:active {
  background-color: #0062cc;
}

.header-content {
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}

.icon-container {
  margin-right: 20rpx;
  padding: 10rpx;
}

.home-emoji {
  font-size: 36rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
  flex: 1;
  text-align: center;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
  margin: 30rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #f0f0f0;
}

.content {
  text-align: center;
}

.description {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 40rpx;
  display: block;
}

.reward-section {
  margin: 50rpx 0;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
}

.reward-image {
  width: 80%;
  max-width: 500rpx;
  margin: 0 auto;
  display: block;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.image-tip {
  font-size: 24rpx;
  color: #666;
  margin-top: 20rpx;
  display: block;
}

.support-info {
  margin-top: 50rpx;
  padding: 30rpx;
  background: #f0f8ff;
  border-radius: 12rpx;
  border: 1rpx dashed #4a90e2;
}

.info-text {
  font-size: 28rpx;
  color: #4a90e2;
  line-height: 1.6;
  display: block;
}

/* 操作按钮区域 */
.button-container {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
  margin-top: 30rpx;
}

.action-button::after {
  border: none;
}

.action-button:active {
  opacity: 0.8;
}