  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 3rpx solid rgba(255, 255, 255, 0.8);
  flex-shrink: 0;
}

.user-avatar-text {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.user-avatar-emoji {
  font-size: 72rpx;
  line-height: 1;
}

.user-info-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  justify-content: center;
  min-width: 0;
}

.user-nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-account {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-status {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--primary-color);
  box-shadow: 0 0 8rpx rgba(52, 211, 153, 0.6);
  animation: pulse-dot 2s infinite;
}

@keyframes pulse-dot {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(0.85);
  }
}

.status-text {
  font-size: 22rpx;
  color: var(--primary-dark);
  font-weight: 500;
}

.header-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  line-height: 1;
  margin-left: 8rpx;
}

/* ========== 头像选择界面 ========== */
.avatar-selector {
  display: flex;
  flex-direction: column;
  min-height: 0;
  width: 100%;
  max-width: 100%;
  margin: 0 auto;
  box-sizing: border-box;
  padding: 0 4rpx;
}

/* 预览区域 */
.avatar-preview-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 20rpx;
}

.avatar-preview-ring {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(52, 211, 153, 0.3);
  margin-bottom: 12rpx;
}

.preview-avatar-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-emoji {
  font-size: 56rpx;
  line-height: 1;
}

.preview-text {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary-color);
  line-height: 1;
}

.preview-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.3;
}

/* 模式切换标签 */
.avatar-mode-tabs {
  display: flex;
  background: var(--bg-color);
  border-radius: 12rpx;
  padding: 4rpx;
  margin-bottom: 16rpx;
}

.avatar-mode-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 14rpx 0;
  border-radius: 10rpx;
  background: transparent;
  transition: all 0.25s ease;
}

.avatar-mode-tab.active {
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.avatar-mode-tab:active {
  opacity: 0.7;
}

.mode-tab-icon {
  font-size: 28rpx;
  line-height: 1;
}

.mode-tab-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
  line-height: 1;
}

.avatar-mode-tab.active .mode-tab-text {
  color: var(--text-primary);
}

/* 文字头像模式 */
.text-avatar-section {
  flex: 1;
  width: 100%;
  max-width: 544rpx;
  margin: 0 auto;
}

.text-avatar-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  background: #ffffff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid var(--border-color);
}

.text-avatar-input-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.text-avatar-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.3;
}

.text-avatar-input {
  height: 80rpx;
  background: var(--bg-color);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: left;
  letter-spacing: 4rpx;
}

.text-avatar-input::-webkit-input-placeholder {
  font-size: 28rpx;
  font-weight: 400;
}

.text-avatar-preview-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.preview-box-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.preview-box-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light), #ecfdf5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-box-char {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-dark);
  line-height: 1;
}

/* 表情选择模式 */
.emoji-select-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  min-width: 0;
  width: 100%;
  box-sizing: border-box;
  padding: 0 4rpx;
}

.emoji-categories {
  display: flex;
  gap: 10rpx;
  padding: 0 0 16rpx;
  flex-shrink: 0;
  width: 100%;
  box-sizing: border-box;
}

.emoji-cat-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.emoji-cat-item.active {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.3);
}

.emoji-cat-item:active {
  transform: scale(0.92);
}

.emoji-cat-icon {
  font-size: 30rpx;
  line-height: 1;
}

.emoji-grid-scroll {
  flex: 1;
  overflow-y: auto;
  min-height: 0;
  background: #ffffff;
  border-radius: var(--radius-md);
  padding: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid var(--border-color);
  width: 100%;
  box-sizing: border-box;
}

.emoji-grid-content {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8rpx;
  padding-bottom: 8rpx;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.emoji-grid-item {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-color);
  border-radius: 12rpx;
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  width: 100%;
}

.emoji-grid-item:active {
  background: var(--primary-light);
  transform: scale(0.92);
}

.emoji-grid-item.selected {
  background: linear-gradient(135deg, var(--primary-light), #ecfdf5);
  border-color: var(--primary-color);
  box-shadow: 0 2rpx 8rpx rgba(52, 211, 153, 0.2);
}

.emoji-grid-char {
  font-size: 40rpx;
  line-height: 1;
}

.user-info-list {
  margin: 0 24rpx;
  background: #ffffff;
  border-radius: var(--radius-lg);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.user-info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s ease;
}

.user-info-item-hover {
  background-color: #f9fafb !important;
}

.user-info-item:last-child {
  border-bottom: none;
}

.info-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.info-icon-wrapper {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.account-icon {
  background: linear-gradient(135deg, #dcfce7, #f0fdf4);
}

.nickname-icon {
  background: linear-gradient(135deg, #e0f2fe, #f0f9ff);
}

.password-icon {
  background: linear-gradient(135deg, #fef3c7, #fffbeb);
}

.avatar-icon {
  background: linear-gradient(135deg, #fce7f3, #fdf2f8);
}

.info-icon {
  font-size: 26rpx;
  line-height: 1;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.arrow-icon {
  font-size: 36rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

/* ========== 表单卡片样式 ========== */
.form-card {
  margin: 0 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: var(--radius-lg);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ========== 表单样式 ========== */
.form-group {
  margin-bottom: 28rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 84rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.form-input:focus {
  background: #ffffff;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(52, 211, 153, 0.1);
}

.btn-danger {
  background: linear-gradient(135deg, var(--danger-color) 0%, #ef4444 100%);
  color: #ffffff;
}

.btn-danger:active {
  opacity: 0.9;
}

/* ========== 删除账户相关样式 ========== */
.warning-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 32rpx 28rpx;
  margin: 0 24rpx 20rpx;
  background: linear-gradient(135deg, #fff7e6 0%, #fff9f0 100%);
  border-radius: var(--radius-lg);
  border: 1rpx solid #ffd591;
  box-shadow: 0 2rpx 12rpx rgba(250, 173, 20, 0.08);
}

.warning-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #faad14, #ffc53d);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(250, 173, 20, 0.3);
}

.warning-icon {
  font-size: 40rpx;
  line-height: 1;
}

.warning-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #d46b08;
  margin-bottom: 8rpx;
}

.warning-content {
  font-size: 26rpx;
  color: #d46b08;
  line-height: 1.6;
}

.btn-delete-account {
  background: linear-gradient(135deg, #faad14 0%, #ffc53d 100%);
  color: #ffffff;
}

/* ========== 记住密码选项样式 ========== */
.remember-password {
  margin-top: 16rpx;
  margin-bottom: 4rpx;
}

.checkbox-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
  background: #ffffff;
}

.checkbox.checked {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  border-color: var(--primary-color);
}

.checkbox-icon {
  color: white;
  font-size: 22rpx;
  font-weight: bold;
}

.checkbox-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ========== 切换账号弹窗样式 ========== */
.account-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  margin: 0 24rpx 20rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #f0f0f0;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.account-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, var(--primary-color), var(--primary-dark));
  border-radius: 0 4rpx 4rpx 0;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.account-item:last-child {
  margin-bottom: 0;
}

.account-item-hover {
  transform: scale(0.98) !important;
  border-color: var(--primary-light) !important;
  box-shadow: 0 6rpx 24rpx rgba(52, 211, 153, 0.15) !important;
  background: linear-gradient(135deg, #f0fdf4 0%, #ffffff 100%) !important;
}

.account-item-hover::before {
  opacity: 1 !important;
}

.account-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  position: relative;
  border: 2rpx solid #f0f0f0;
}

.account-avatar::after {
  content: '';
  position: absolute;
  inset: -4rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(0, 0, 0, 0.03);
}

.avatar-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary-color);
  line-height: 1;
  z-index: 1;
}

.avatar-emoji {
  font-size: 52rpx;
  line-height: 1;
  z-index: 1;
}

.account-info {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.account-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.account-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.account-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  background-color: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  line-height: 1.3;
}

.account-password-status {
  font-size: 22rpx;
  color: var(--text-tertiary);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  display: inline-block;
  white-space: nowrap;
  line-height: 1;
  background-color: #f5f5f5;
}

.account-password-status.has-password {
  color: var(--primary-dark);
  background-color: rgba(52, 211, 153, 0.1);
}

.account-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.auto-restore-checkbox {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #d1d5db;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
  flex-shrink: 0;
  background: #ffffff;
  position: relative;
}

.auto-restore-checkbox.checked {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  border-color: var(--primary-color);
  box-shadow: 0 2rpx 8rpx rgba(52, 211, 153, 0.3);
}

.checkbox-hover {
  transform: scale(0.9) !important;
  opacity: 0.7 !important;
}

.checkmark {
  color: white;
  font-size: 26rpx;
  font-weight: bold;
  line-height: 1;
}

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

.delete-hover {
  background-color: #fee2e2 !important;
  transform: scale(1.15) !important;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.25) !important;
}

.delete-icon {
  font-size: 26rpx;
  line-height: 1;
  transition: all 0.25s ease;
}

.delete-hover .delete-icon {
  filter: brightness(1.2);
}

/* 账号列表容器 */
.user-page-switch-account {
  padding: 24rpx 0;
  overflow-y: auto;
  max-height: 50vh;
}

/* 复选框功能提示 */
.switch-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  margin: 0 24rpx 20rpx;
  background: rgba(52, 211, 153, 0.08);
  border: 1rpx solid rgba(52, 211, 153, 0.2);
  border-radius: 12rpx;
}

.switch-tip-icon {
  font-size: 28rpx;
  line-height: 1;
}

.switch-tip-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

/* 空状态美化 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
  background: #f9fafb;
  margin: 24rpx;
  border-radius: 20rpx;
  border: 2rpx dashed #e0e0e0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
  animation: bounce 2s infinite;
}

.empty-text {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 1.6;
  max-width: 80%;
}

/* 动画效果 */
@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-10rpx);
  }
  60% {
    transform: translateY(-5rpx);
  }
}

/* ========== 主按钮样式 ========== */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.3);
}

/* ========== 按钮容器布局 ========== */
.user-management-modal .modal-footer view {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  width: 100%;
}

.user-management-modal .modal-footer button {
  flex: 1;
  margin: 0;
}

.btn-delete-account {
  background: linear-gradient(135deg, #faad14 0%, #ffc53d 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(250, 173, 20, 0.25);
}

.btn-delete-confirm {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.25);
}

.btn-danger {
  background: linear-gradient(135deg, var(--danger-color) 0%, #ef4444 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(248, 113, 113, 0.25);
}

/* ========== 声明板块样式 ========== */
.policy-icon {
  background: linear-gradient(135deg, #f3f4f6 0%, #f9fafb 100%);
}

.policy-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.policy-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fafdfb 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(52, 211, 153, 0.12);
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(52, 211, 153, 0.08);
  position: relative;
  overflow: hidden;
}

.policy-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #34d399, #10b981);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.policy-item:active {
  transform: scale(0.97);
  background: linear-gradient(135deg, #f8fdfb 0%, #f0faf3 100%);
  box-shadow: 0 6rpx 20rpx rgba(52, 211, 153, 0.15);
}

.policy-item:active::before {
  opacity: 1;
}

.policy-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.2);
  border: 1rpx solid rgba(52, 211, 153, 0.15);
}

.policy-icon {
  font-size: 36rpx;
  line-height: 1;
}

.policy-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-left: 24rpx;
  min-width: 0;
}

.policy-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.3;
  letter-spacing: 0.5rpx;
}

.policy-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
  letter-spacing: 0.3rpx;
}

.policy-arrow {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.policy-arrow .arrow-icon {
  font-size: 44rpx;
  color: #d1d5db;
  line-height: 1;
  font-weight: 300;
}

/* ========== WeUI 半屏弹窗样式（政策声明） ========== */
.weui-half-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
  max-height: 75vh;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.weui-half-modal.show {
  transform: translateY(0);
}

.weui-half-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.weui-half-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.weui-half-title-icon {
  font-size: 36rpx;
}

.weui-half-title-text {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.weui-half-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.weui-half-close:active {
  background: #f5f5f5;
  transform: scale(0.9);
}

.weui-half-close-icon {
  font-size: 32rpx;
  color: #94a3b8;
  font-weight: 300;
}

.weui-half-body {
  flex: 1;
  overflow-y: auto;
  max-height: calc(75vh - 180rpx);
  background: #f8fafc;
}

.weui-half-content {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.weui-half-footer {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #ffffff;
  flex-shrink: 0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.weui-half-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  border: none;
  padding: 0;
  margin: 0;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.weui-half-btn::after {
  border: none;
}

.weui-half-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.policy-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.policy-section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.policy-section-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
  border: 2rpx solid;
}

.policy-section-title {
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.policy-section-body {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.policy-detail-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 12rpx;
}

.policy-item-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.policy-item-text {
  font-size: 27rpx;
  color: #475569;
  line-height: 1.7;
  flex: 1;
  letter-spacing: 0.3rpx;
}

@media (min-width: 768px) {
  .weui-half-modal {
    max-width: 750rpx;
    left: 50%;
    transform: translateX(-50%) translateY(100%);
    margin: 0 auto;
    border-radius: 32rpx;
    box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.2);
  }

  .weui-half-modal.show {
    transform: translateX(-50%) translateY(0);
  }

  .modal-mask {
    background: rgba(0, 0, 0, 0.4);
  }
}
