/* pages/profile/profile.wxss */
.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.profile-section {
  background: #fff;
  border-radius: 10rpx;
  padding: 40rpx;
  margin: 30rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.avatar-container {
  position: relative;
  display: inline-block;
}

.avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  border: 5rpx solid #f0f0f0;
}

.change-avatar {
  position: absolute;
  bottom: 0;
  right: 0;
  background: #07c160;
  color: #fff;
  font-size: 20rpx;
  padding: 5rpx 10rpx;
  border-radius: 20rpx;
}

.nickname-container {
  margin-top: 30rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.edit-nickname {
  background: #f0f0f0;
  color: #666;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  margin-top: 20rpx;
}

.section {
  background: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin: 30rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.intro-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.data-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx;
  border-radius: 10rpx;
}

.export-btn {
  background: #07c160;
  color: #fff;
}

.import-btn {
  background: #1890ff;
  color: #fff;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  width: 80%;
  border-radius: 10rpx;
  padding: 30rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
}

.form-group {
  margin-bottom: 30rpx;
}

.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  margin: 0 10rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.cancel-btn {
  background: #f0f0f0;
  color: #666;
}

.confirm-btn {
  background: #07c160;
  color: #fff;
}