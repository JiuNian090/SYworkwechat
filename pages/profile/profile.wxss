/* pages/profile/profile.wxss */

/* ========== CSS变量定义 ========== */
page {
  --primary-color: #07c160;
  --primary-dark: #059e4d;
  --primary-light: #e6f7e6;
  --danger-color: #ff4d4f;
  --warning-color: #fa8c16;
  --info-color: #1890ff;
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #e8e8e8;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-hover: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* ========== 容器 ========== */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 页面标题区 ========== */
.page-header {
  position: relative;
  padding: 60rpx 30rpx 80rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-user-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
}

.header-avatar-wrapper {
  position: relative;
  flex-shrink: 0;
}

.header-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.header-avatar-text {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.header-avatar-emoji {
  font-size: 80rpx;
  line-height: 1;
}

.header-avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: var(--primary-dark);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.header-edit-icon {
  font-size: 20rpx;
}

.header-user-details {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.header-username {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.header-user-status {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ========== 卡片基础样式 ========== */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  margin: -40rpx 24rpx 24rpx;
  padding: 30rpx;
  box-shadow: var(--shadow);
  position: relative;
  z-index: 2;
}

/* ========== 用户卡片 ========== */
.user-info-card {
  padding: 40rpx 30rpx;
}

.user-card {
  position: relative;
  margin: 0 -24rpx 24rpx;
  padding: 60rpx 24rpx 80rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  overflow: hidden;
}

.user-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -150rpx;
  right: -100rpx;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  bottom: -100rpx;
  left: -80rpx;
  background: rgba(255, 255, 255, 0.05);
}

.circle-3 {
  width: 200rpx;
  height: 200rpx;
  top: 50%;
  left: 60%;
  background: rgba(255, 255, 255, 0.03);
}

.user-info {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
  padding: 20rpx 0;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 24rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-text {
  font-size: 64rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.avatar-emoji {
  font-size: 110rpx;
  line-height: 1;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: var(--primary-dark);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.edit-icon {
  font-size: 24rpx;
}

.user-details {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.username {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.user-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ========== 区块卡片 ========== */
.section {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 20rpx;
  border-bottom: 2rpx solid var(--border-color);
  position: relative;
}

.section-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.data-icon {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.webdav-icon {
  background: linear-gradient(135deg, #f0f5ff 0%, #f5f8ff 100%);
}

.about-icon {
  background: linear-gradient(135deg, #fff7e6 0%, #fff9f0 100%);
}

.changelog-icon {
  background: linear-gradient(135deg, #f6ffed 0%, #f0fff0 100%);
}

.icon-text {
  font-size: 32rpx;
}

.section-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.help-btn {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.25);
}

.help-btn:active {
  transform: scale(0.95);
}

.help-icon {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

.section-body {
  padding: 24rpx;
}

/* ========== 按钮网格 ========== */
.btn-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.grid-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 20rpx;
  background: var(--bg-color);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.grid-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.btn-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 按钮颜色 */
.export-btn {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.share-btn {
  background: linear-gradient(135deg, #fff7e6 0%, #fff9f0 100%);
}

.import-btn {
  background: linear-gradient(135deg, #f6ffed 0%, #f0fff0 100%);
}

.clear-btn {
  background: linear-gradient(135deg, #fff2f0 0%, #fff5f5 100%);
}

.clear-btn .btn-text {
  color: var(--danger-color);
}

.config-btn {
  background: linear-gradient(135deg, #f0f5ff 0%, #f5f8ff 100%);
}

.test-btn {
  background: linear-gradient(135deg, #f9f0ff 0%, #faf5ff 100%);
}

.backup-btn {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.restore-btn {
  background: linear-gradient(135deg, #f6ffed 0%, #f0fff0 100%);
}

/* ========== 项目介绍 ========== */
.about-section {
  background: linear-gradient(135deg, #fff9f5 0%, #ffffff 100%);
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.about-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.about-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.about-dot {
  font-size: 32rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.about-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ========== 更新日志 ========== */
.changelog-wrapper {
  background: var(--bg-color);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.changelog-scroll {
  max-height: 400rpx;
  padding: 20rpx;
}

.changelog-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.changelog-item {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.changelog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.version-tag {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.version-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.changelog-content {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.changelog-text {
  white-space: pre-wrap;
}

.changelog-empty {
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* ========== 操作按钮行 ========== */
.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0;
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.contact-btn {
  background: linear-gradient(135deg, var(--info-color) 0%, #40a9ff 100%);
}

.donate-btn {
  background: linear-gradient(135deg, var(--warning-color) 0%, #ffc53d 100%);
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

/* ========== 弹窗样式 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 998;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
}

.modal-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 85%;
  max-width: 600rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  z-index: 999;
  opacity: 0;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
}

.modal-container.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg-color);
}

.modal-close:active {
  background: var(--border-color);
}

.close-icon {
  font-size: 36rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.modal-body {
  padding: 28rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 0 28rpx 28rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
}

.modal-btn::after {
  border: none;
}

.btn-cancel {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.btn-cancel:active {
  background: var(--border-color);
}

.btn-confirm {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
}

.btn-confirm:active {
  opacity: 0.9;
}

/* ========== 输入框样式 ========== */
.input-wrapper {
  background: var(--bg-color);
  border-radius: var(--radius-md);
  padding: 4rpx 20rpx;
}

.modal-input {
  height: 80rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.input-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ========== 表单样式 ========== */
.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.form-input {
  height: 80rpx;
  background: var(--bg-color);
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.password-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  background: var(--bg-color);
  border-radius: var(--radius-md);
  padding-right: 20rpx;
}

.password-input {
  flex: 1;
  background: transparent;
}

.password-toggle {
  padding: 10rpx 16rpx;
  border-left: 2rpx solid var(--border-color);
}

.toggle-text {
  font-size: 24rpx;
  color: var(--info-color);
}

/* ========== 复选框样式 ========== */
.checkbox-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--bg-color);
  border-radius: var(--radius-md);
}

.checkbox-wrapper {
  margin-right: 16rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--border-color);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--card-bg);
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

.check-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

.checkbox-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* ========== 表情选择弹窗 ========== */
.emoji-modal {
  max-height: 80vh;
}

.emoji-body {
  max-height: 60vh;
  overflow-y: auto;
}

.emoji-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
  padding-bottom: 20rpx;
}

.emoji-item {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-color);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.emoji-item:active {
  transform: scale(0.9);
}

.emoji-item.selected {
  background: var(--primary-light);
  border: 4rpx solid var(--primary-color);
}

.emoji-char {
  font-size: 48rpx;
  line-height: 1;
}

.emoji-preview {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--bg-color);
  border-radius: var(--radius-md);
  margin-top: 20rpx;
}

.preview-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.preview-emoji {
  font-size: 48rpx;
}

.preview-text {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* ========== 响应式适配 ========== */
@media (max-width: 375px) {
  .btn-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16rpx;
  }
  
  .grid-btn {
    padding: 24rpx 16rpx;
  }
  
  .btn-icon {
    font-size: 36rpx;
  }
  
  .btn-text {
    font-size: 24rpx;
  }
  
  .emoji-grid {
    grid-template-columns: repeat(5, 1fr);
  }
}

@media (min-width: 768px) {
  .container {
    max-width: 750rpx;
    margin: 0 auto;
  }
  
  .user-card {
    margin-left: -24rpx;
    margin-right: -24rpx;
  }
  
  .btn-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

/* ========== 动画效果 ========== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.section {
  animation: fadeInUp 0.4s ease-out;
}

.section:nth-child(1) { animation-delay: 0.05s; }
.section:nth-child(2) { animation-delay: 0.1s; }
.section:nth-child(3) { animation-delay: 0.15s; }
.section:nth-child(4) { animation-delay: 0.2s; }
