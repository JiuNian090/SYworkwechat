/* pages/profile/profile.wxss */

/* ========== CSS变量定义 ========== */
page {
  --primary-color: #34d399;
  --primary-dark: #10b981;
  --primary-light: #d1fae5;
  --danger-color: #f87171;
  --warning-color: #fbbf24;
  --info-color: #60a5fa;
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #e8e8e8;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-hover: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* ========== 今日心语卡片 ========== */
.daily-message-card {
  background: linear-gradient(135deg, #ffffff 0%, #f9fdfb 100%);
  border-radius: 24rpx;
  margin: 0 30rpx 16rpx;
  padding: 28rpx 32rpx 28rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(52, 211, 153, 0.12);
  animation: messageFadeIn 0.5s ease-out;
  border: 1rpx solid rgba(52, 211, 153, 0.1);
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.daily-message-icon {
  flex-shrink: 0;
  font-size: 48rpx;
  line-height: 1;
  padding-top: 4rpx;
}

.daily-message-content {
  flex: 1;
}

.daily-message-title {
  font-size: 24rpx;
  color: #34d399;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.daily-message-title-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #34d399, #10b981);
  animation: dotBreath 2s ease-in-out infinite;
  box-shadow: 0 0 8rpx rgba(52, 211, 153, 0.6);
}

.daily-message-title {
  font-size: 24rpx;
  color: #34d399;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

@keyframes dotBreath {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 8rpx rgba(52, 211, 153, 0.6);
    opacity: 1;
  }
  50% {
    transform: scale(1.3);
    box-shadow: 0 0 20rpx rgba(52, 211, 153, 0.9);
    opacity: 0.8;
  }
}

.daily-message-text {
  font-size: 29rpx;
  color: #4a5568;
  line-height: 1.7;
  word-wrap: break-word;
  letter-spacing: 0.5rpx;
}

@keyframes messageFadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== 容器 ========== */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
  opacity: 1;
  transition: opacity 0.2s ease-in-out;
}

/* ========== 页面标题区 - WeUI样式 ========== */
.page-header {
  position: relative;
  margin: 30rpx 30rpx 30rpx;
  padding: 60rpx 30rpx 60rpx;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  border-bottom: 2rpx solid var(--border-color);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border-radius: 24rpx;
  opacity: 1;
  transform: translateY(0);
  transition: all 0.3s ease-in-out;
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-user-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
}

.header-avatar-wrapper {
  position: relative;
  flex-shrink: 0;
}

.header-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f7f7f7;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid var(--border-color);
}

.header-avatar-text {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.header-avatar-emoji {
  font-size: 80rpx;
  line-height: 1;
}

.header-avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ffffff;
  animation: breathing 2s ease-in-out infinite;
}

@keyframes breathing {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.25);
  }
}

.header-edit-icon {
  font-size: 20rpx;
  color: #ffffff;
}

.header-user-details {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.header-username {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.header-user-status {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 400;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.9);
  color: var(--text-primary);
  display: inline-block;
  line-height: 1.3;
  text-shadow: none;
}

.header-user-status.emotion-positive {
  background: #f3e5f5;
  color: #7b1fa2;
}

.header-user-status.emotion-neutral {
  background: #e3f2fd;
  color: #1565c0;
}

.header-user-status.emotion-negative {
  background: #ffebee;
  color: #c62828;
}

/* ========== 卡片基础样式 ========== */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  margin: -40rpx 24rpx 24rpx;
  padding: 30rpx;
  box-shadow: var(--shadow);
  position: relative;
  z-index: 2;
}

/* ========== 用户卡片 ========== */
.user-info-card {
  padding: 40rpx 30rpx;
}

.user-card {
  position: relative;
  margin: 0 -24rpx 24rpx;
  padding: 60rpx 24rpx 80rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  overflow: hidden;
}

.user-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -150rpx;
  right: -100rpx;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  bottom: -100rpx;
  left: -80rpx;
  background: rgba(255, 255, 255, 0.05);
}

.circle-3 {
  width: 200rpx;
  height: 200rpx;
  top: 50%;
  left: 60%;
  background: rgba(255, 255, 255, 0.03);
}

.user-info {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
  padding: 20rpx 0;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 24rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-text {
  font-size: 64rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.avatar-emoji {
  font-size: 110rpx;
  line-height: 1;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: var(--primary-dark);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.edit-icon {
  font-size: 24rpx;
}

.user-details {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.username {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.user-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ========== 区块卡片 ========== */
.section {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  position: relative;
  justify-content: space-between;
}

.section-header-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  justify-content: flex-start;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  font-size: 36rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.data-icon {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.cloud-icon {
  background: linear-gradient(135deg, #f0f5ff 0%, #f5f8ff 100%);
}

.about-icon {
  background: linear-gradient(135deg, #fff7e6 0%, #fff9f0 100%);
}

.changelog-icon {
  background: linear-gradient(135deg, #f6ffed 0%, #f0fff0 100%);
}

.icon-text {
  font-size: 32rpx;
}

.section-header-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.section-title {
  flex-shrink: 0;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: left;
}

.help-btn {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.25);
  transition: all 0.2s ease;
}

.help-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 1rpx 4rpx rgba(7, 193, 96, 0.2);
}

.help-icon {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

/* ========== 云备份状态指示器 ========== */
.cloud-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-right: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  background: transparent;
  transition: background 0.2s ease;
}

.cloud-status-logged-in:active {
  background: rgba(0, 0, 0, 0.04);
}

.status-breath {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-label {
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1;
  white-space: nowrap;
}

/* 绿色呼吸灯 - 已同步 */
.status-breath.status-synced {
  background: #34d399;
  animation: breath-green 2s ease-in-out infinite;
}

@keyframes breath-green {
  0%, 100% {
    opacity: 1;
    box-shadow: 0 0 8rpx rgba(52, 211, 153, 0.8);
  }
  50% {
    opacity: 0.3;
    box-shadow: 0 0 2rpx rgba(52, 211, 153, 0.2);
  }
}

/* 红色呼吸灯 - 本地最新 / 云端最新 */
.status-breath.status-local_newer,
.status-breath.status-cloud_newer {
  background: #f87171;
  animation: breath-red 2s ease-in-out infinite;
}

@keyframes breath-red {
  0%, 100% {
    opacity: 1;
    box-shadow: 0 0 8rpx rgba(248, 113, 113, 0.8);
  }
  50% {
    opacity: 0.3;
    box-shadow: 0 0 2rpx rgba(248, 113, 113, 0.2);
  }
}

/* 灰色脉冲灯 - 检查中 */
.status-breath.status-checking {
  background: #d1d5db;
  animation: pulse-gray 1.5s ease-in-out infinite;
}

@keyframes pulse-gray {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 0.2; }
}

/* 灰色常亮灯 - 未备份 / 未登录 */
.status-breath.status-unbacked {
  background: #d1d5db;
  opacity: 0.4;
}

/* 检查失败 */
.status-breath.status-error {
  background: #fbbf24;
  opacity: 0.7;
}

.section-body {
  padding: 0 30rpx 30rpx;
}

/* ========== 按钮网格 ========== */
.btn-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.grid-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 20rpx;
  background: var(--bg-color);
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.grid-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.btn-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 按钮颜色 */
.export-btn {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.share-btn {
  background: linear-gradient(135deg, #f6ffed 0%, #f0fff0 100%);
}

.section-right {
  display: flex;
  align-items: center;
}

.manual-btn {
  position: relative !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 8rpx !important;
  padding: 0 20rpx !important;
  margin: 0 !important;
  border-radius: 12rpx !important;
  font-size: 24rpx !important;
  font-weight: 500 !important;
  line-height: 1 !important;
  transition: all 0.2s ease;
  overflow: hidden !important;
  height: 64rpx !important;
  min-height: 64rpx !important;
  max-height: 64rpx !important;
  box-sizing: border-box !important;
  vertical-align: middle !important;
  top: 0 !important;
  bottom: 0 !important;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.25);
}

.manual-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 1rpx 4rpx rgba(7, 193, 96, 0.2);
}

.manual-btn .btn-text {
  color: #ffffff !important;
}

.import-btn {
  background: linear-gradient(135deg, #f6ffed 0%, #f0fff0 100%);
}

.clear-btn {
  background: linear-gradient(135deg, #fff2f0 0%, #fff5f5 100%);
}

.clear-btn .btn-text {
  color: var(--danger-color);
}

.config-btn {
  background: linear-gradient(135deg, #f0f5ff 0%, #f5f8ff 100%);
}

.test-btn {
  background: linear-gradient(135deg, #f9f0ff 0%, #faf5ff 100%);
}

.backup-btn {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.restore-btn {
  background: linear-gradient(135deg, #f6ffed 0%, #f0fff0 100%);
}

/* ========== 项目介绍 ========== */
.about-section {
  background: var(--card-bg);
  margin: 30rpx;
  position: relative;
  z-index: 2;
}

.about-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.about-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--bg-color);
  border-radius: 16rpx;
}

.about-dot {
  font-size: 32rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.about-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ==========================================
   WeUI 风格更新日志样式
   ========================================== */

/* WeUI 面板 */
.weui-panel {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.weui-panel_access {
  position: relative;
}

/* 滚动视图 */
.changelog-scroll {
  max-height: 60vh;
  width: 100%;
  box-sizing: border-box;
}

/* WeUI 单元格标题 */
.weui-cells__title {
  padding: 24rpx 30rpx 16rpx;
  color: #999999;
  font-size: 28rpx;
  line-height: 1.4;
}

.weui-cells__title-text {
  font-size: 28rpx;
  color: #999999;
}

/* WeUI 单元格组 */
.weui-cells {
  background-color: #ffffff;
  line-height: 1.47058824;
  font-size: 34rpx;
  position: relative;
}

.weui-cells:before,
.weui-cells:after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  height: 1px;
  color: #e5e5e5;
  background-color: #e5e5e5;
}

.weui-cells:before {
  top: 0;
}

.weui-cells:after {
  bottom: 0;
}

/* WeUI 单元格 */
.weui-cell {
  padding: 30rpx;
  position: relative;
  display: flex;
  align-items: flex-start;
  transition: background-color 0.2s;
}

.weui-cell:before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 1px;
  border-top: 1rpx solid #e5e5e5;
  color: #e5e5e5;
  left: 30rpx;
}

.weui-cell:first-child:before {
  display: none;
}

.weui-cell:active {
  background-color: #ececec;
}

.weui-cell_access {
  -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
}

.weui-cell_active {
  background-color: #f7f7f7;
}

/* 单元格左侧 */
.weui-cell__hd {
  display: flex;
  flex-shrink: 0;
}

.weui-cell__icon-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  position: relative;
  padding-top: 12rpx;
}

.weui-cell__icon {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #c9c9c9;
  position: relative;
  z-index: 2;
}

.weui-cell__icon_latest {
  background-color: #07c160;
  box-shadow: 0 0 0 6rpx rgba(7, 193, 96, 0.2);
}

.weui-cell__line {
  width: 2rpx;
  flex: 1;
  min-height: 80rpx;
  background-color: #e5e5e5;
  margin-top: 12rpx;
}

/* 单元格主体 */
.weui-cell__bd {
  flex: 1;
  min-width: 0;
}

.weui-cell__version {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.weui-cell__version-tag {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
}

/* WeUI 徽章 */
.weui-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 24rpx;
  line-height: 1.4;
  border-radius: 8rpx;
  background-color: #07c160;
  color: #ffffff;
}

.weui-badge_dot {
  background-color: #07c160;
}

.weui-badge__text {
  font-size: 24rpx;
  color: #ffffff;
}

.weui-cell__date {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.weui-cell__content {
  line-height: 1.6;
}

.weui-cell__text {
  font-size: 28rpx;
  color: #576b95;
  white-space: pre-wrap;
  word-break: break-word;
  overflow-wrap: break-word;
  line-height: 1.6;
}

/* 单元格右侧 */
.weui-cell__ft {
  text-align: right;
  color: #999999;
  padding-left: 20rpx;
}

/* WeUI 消息（空状态） */
.weui-msg {
  padding: 80rpx 60rpx;
  text-align: center;
}

.weui-msg__icon-area {
  margin-bottom: 30rpx;
}

.weui-msg__icon {
  font-size: 96rpx;
  opacity: 0.4;
}

.weui-msg__text-area {
  margin-bottom: 30rpx;
}

.weui-msg__title {
  font-weight: 400;
  font-size: 36rpx;
  color: #000000;
  margin-bottom: 12rpx;
}

.weui-msg__desc {
  font-size: 28rpx;
  color: #999999;
  line-height: 1.4;
}

/* WeUI 按钮区域 */
.weui-btn-area {
  margin: 30rpx 0 0;
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.weui-btn {
  position: relative;
  display: block;
  margin-left: auto;
  margin-right: auto;
  padding-left: 28rpx;
  padding-right: 28rpx;
  box-sizing: border-box;
  font-size: 34rpx;
  text-align: center;
  text-decoration: none;
  line-height: 2.55555556;
  border-radius: 8rpx;
  overflow: hidden;
  border: none;
  appearance: none;
}

.weui-btn::after {
  border-width: 0;
}

.weui-btn_primary {
  background-color: #07c160;
  color: #ffffff;
}

.weui-btn_primary:active {
  background-color: #06ad56;
}

.weui-btn_default {
  background-color: #f7f7f7;
  color: #000000;
}

.weui-btn_default:active {
  background-color: #dedede;
}

.weui-btn_mini {
  display: inline-block;
  padding: 0 1.5em;
  line-height: 2.3;
  font-size: 28rpx;
  flex: 1;
}

/* WeUI 按钮区域 */
.weui-btn-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-top: 30rpx !important;
  padding: 0 30rpx !important;
}

/* WeUI 按钮 - 强制统一样式 */
.weui-btn {
  position: relative !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 12rpx !important;
  padding: 0 24rpx !important;
  margin: 0 !important;
  border-radius: 16rpx !important;
  font-size: 26rpx !important;
  font-weight: 500 !important;
  line-height: 1 !important;
  transition: all 0.2s ease;
  flex: 1 !important;
  overflow: hidden !important;
  height: 88rpx !important;
  min-height: 88rpx !important;
  max-height: 88rpx !important;
  box-sizing: border-box !important;
  vertical-align: middle !important;
  top: 0 !important;
  bottom: 0 !important;
}

/* 确保两个按钮宽度一致 */
.weui-btn_default,
.weui-btn_primary {
  flex: 1 !important;
  width: 50% !important;
  max-width: 300rpx !important;
}

/* 按钮内部元素对齐 */
.weui-btn__icon,
.weui-btn__text {
  display: inline-block !important;
  vertical-align: middle !important;
  line-height: 1 !important;
  margin: 0 !important;
  padding: 0 !important;
}

.weui-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* WeUI 默认按钮 */
.weui-btn_default {
  background: linear-gradient(135deg, #f0f0f0 0%, #e5e5e5 100%);
  color: #333333;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.weui-btn_default:active {
  background: linear-gradient(135deg, #e5e5e5 0%, #d9d9d9 100%);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

/* WeUI 主要按钮 */
.weui-btn_primary {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.25);
}

.weui-btn_primary:active {
  background: linear-gradient(135deg, #06ad56 0%, #059a4c 100%);
  box-shadow: 0 1rpx 4rpx rgba(7, 193, 96, 0.2);
}

/* WeUI 按钮图标 */
.weui-btn__icon {
  font-size: 32rpx;
  line-height: 1;
}

/* WeUI 按钮文字 */
.weui-btn__text {
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1;
}

/* ========== 弹窗样式（WeUI 半屏样式） ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 998;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 999;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
  max-height: 75vh;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.modal-container.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.modal-title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.modal-title-icon {
  font-size: 32rpx;
  line-height: 1;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 1rpx;
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.modal-close:active {
  background: #f5f5f5;
  transform: scale(0.9);
}

.close-icon {
  font-size: 32rpx;
  color: #999;
  font-weight: 300;
}

.modal-header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.modal-header .help-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #4CAF50;
  border: 2rpx solid #45a049;
}

.modal-header .help-btn:active {
  background: #45a049;
}

.modal-header .help-icon {
  font-size: 20rpx;
  color: white;
  font-weight: bold;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 0;
  max-height: calc(75vh - 160rpx);
}

.modal-footer {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #ffffff;
  flex-shrink: 0;
  display: flex;
  gap: 16rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
  transition: all 0.2s ease;
}

.modal-btn::after {
  border: none;
}

.modal-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-cancel {
  background: #f3f4f6;
  color: var(--text-secondary);
}

.btn-confirm {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.3);
}

/* ========== 输入框样式 ========== */
.input-wrapper {
  background: var(--bg-color);
  border-radius: var(--radius-md);
  padding: 4rpx 20rpx;
}

.modal-input {
  height: 80rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.input-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ========== 表单样式 ========== */
.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.form-input {
  height: 80rpx;
  background: var(--bg-color);
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.password-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  background: var(--bg-color);
  border-radius: var(--radius-md);
  padding-right: 20rpx;
}

.password-input {
  flex: 1;
  background: transparent;
}

.password-toggle {
  padding: 10rpx 16rpx;
  border-left: 2rpx solid var(--border-color);
}

.toggle-text {
  font-size: 24rpx;
  color: var(--info-color);
}

/* ========== 复选框样式 ========== */
.checkbox-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--bg-color);
  border-radius: var(--radius-md);
}

.checkbox-wrapper {
  margin-right: 16rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--border-color);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--card-bg);
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

.check-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

.checkbox-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

