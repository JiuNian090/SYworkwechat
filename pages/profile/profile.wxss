/* pages/profile/profile.wxss */
/* 主色变量和统一按钮样式 */
.main-color {
  color: #07c160;
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(7,193,96,0.08);
  transition: all 0.3s ease;
}
.btn-primary:active {
  background: #059e4d;
  transform: translateY(2rpx);
}
.modal {
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12);
}
.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
  text-align: center;
  margin: 20rpx 0;
}

.profile-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
  margin: 30rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  border: 1rpx solid #f0f0f0;
}

.profile-section:hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transform: translateY(-4rpx);
}







.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 10rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  border: 1rpx solid #f0f0f0;
  overflow: hidden;
}

.section:first-child {
  margin-top: 0;
}

.section:last-child {
  margin-bottom: 0;
}

.section:hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transform: translateY(-4rpx);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title::before {
  content: "";
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160, #1890ff);
  margin-right: 12rpx;
}

.intro-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 1rpx solid #f0f0f0;
}

.data-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  font-size: 30rpx;
  padding: 5rpx;
  border-radius: 30rpx;
  transition: all 0.3s ease;
  text-align: center;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: none;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.export-btn {
  background: #1890ff;
  color: #fff;
}

.import-btn {
  background: #52c41a;
  color: #fff;
}

.share-btn {
  background: #fa8c16;
  color: #fff;
}

.clear-btn {
  background: #ff4d4f;
  color: #fff;
}

.contact-btn {
  background: #1890ff;
  color: #fff;
}

.donate-btn {
  background: #fa8c16;
  color: #fff;
}



.input-item {
  margin-bottom: 20rpx;
}

.filename-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #07c160;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 80rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.1);
  transition: all 0.3s ease;
}

.filename-input:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.3);
  outline: none;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  width: 80%;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 10rpx;
  color: #333;
}

.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.input:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 2rpx rgba(7, 193, 96, 0.2);
  outline: none;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  margin: 0 10rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
  transition: all 0.3s ease;
  font-weight: 500;
}

.cancel-btn {
  background: #f0f0f0;
  color: #666;
}

.cancel-btn:active {
  background: #e0e0e0;
  transform: translateY(2rpx);
}

.confirm-btn {
  background: #07c160;
  color: #fff;
}

.confirm-btn:active {
  background: #059e4d;
  transform: translateY(2rpx);
}

/* 使用说明样式 */
.usage-guide {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.guide-item {
  margin-bottom: 10rpx;
  display: flex;
  flex-direction: column;
}

.highlight {
  color: #fa8c16;
  font-weight: bold;
  margin-top: 5rpx;
}

/* 用户板块样式 */
.user-section {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 20rpx 30rpx;
}

.user-info {
  display: flex;
  align-items: flex-start;
  gap: 40rpx;
  cursor: pointer;
  padding: 20rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.user-info:hover {
  background: #f0fff0;
  transform: translateY(-2rpx);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160 0%, #059e4d 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.2);
}

.avatar-text {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.username-display {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  letter-spacing: 2rpx;
}

.username-display:empty::before {
  content: '点击自定义用户名';
  color: #999;
  font-weight: normal;
}

/* 头像选项样式 */
.avatar-options {
  margin-top: 10rpx;
  display: flex;
  gap: 20rpx;
}

.avatar-option {
  font-size: 24rpx;
  color: #07c160;
  cursor: pointer;
  padding: 5rpx 10rpx;
  border-radius: 10rpx;
  transition: all 0.3s ease;
}

.avatar-option:active {
  background: #f0fff0;
  transform: translateY(2rpx);
}

/* 表情文字样式 */
.avatar-emoji-text {
  font-size: 24rpx;
  color: #666;
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
  font-weight: 500;
  align-self: flex-start;
  margin-top: 10rpx;
}

/* 积极情绪背景 */
.emoji-emotion-positive {
  background: #f0fff0;
  color: #07c160;
}

/* 中性情绪背景 */
.emoji-emotion-neutral {
  background: #f0f0f0;
  color: #666;
}

/* 消极情绪背景 */
.emoji-emotion-negative {
  background: #fff0f0;
  color: #ff4d4f;
}

/* 表情头像样式 */
.avatar-emoji {
  font-size: 60rpx;
  line-height: 120rpx;
  text-align: center;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 表情选择弹窗样式 */
.emoji-modal {
  width: 90%;
  max-width: 600rpx;
}

.emoji-content {
  max-height: 500rpx;
  overflow-y: auto;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 10rpx;
}

.emoji-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  background: #f9f9f9;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.emoji-item:hover {
  background: #f0f0f0;
  transform: scale(1.1);
}

.emoji-item:active {
  background: #e0e0e0;
  transform: scale(0.95);
}

/* 选中表情项样式 */
.emoji-item-selected {
  background: #e6f7ff;
  border: 2rpx solid #1890ff;
  box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.1);
}

.emoji-icon {
  font-size: 48rpx;
}

.selected-emoji {
  margin-top: 20rpx;
  padding: 15rpx;
  background: #f0fff0;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.selected-emoji-label {
  font-size: 28rpx;
  color: #666;
}

.selected-emoji-icon {
  font-size: 40rpx;
}

/* 用户名设置弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.modal-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: white;
  border-radius: 20rpx;
  width: 80%;
  max-width: 500rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  z-index: 1000;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
  background: #f8f8f8;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close-btn {
  width: 60rpx;
  height: 60rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  font-size: 40rpx;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.modal-close-btn:active {
  background: #f0f0f0;
  color: #333;
}

.modal-content {
  padding: 40rpx 30rpx;
}

.modal-input-group {
  display: flex;
  align-items: center;
  width: 100%;
  margin-bottom: 20rpx;
}

.modal-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #07c160;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 80rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.1);
  transition: all 0.3s ease;
}

.modal-input:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.3);
  outline: none;
}

.modal-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
  background: #f8f8f8;
}

.modal-btn {
  padding: 15rpx 30rpx;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s ease;
  min-width: 120rpx;
}

.cancel-btn {
  background: #f0f0f0;
  color: #666;
}

.cancel-btn:active {
  background: #e0e0e0;
}

.confirm-btn {
  background: #07c160;
  color: white;
}

.confirm-btn:active {
  background: #059e4d;
}

/* 更新日志样式 */
.changelog-container {
  background: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #f0f0f0;
}

.changelog-scroll {
  height: 400rpx; /* 只显示一个日志的高度，可根据需要调整 */
  overflow-y: auto;
  padding: 20rpx;
}

/* 自定义滚动条样式 */
.changelog-scroll::-webkit-scrollbar {
  width: 6rpx;
}

.changelog-scroll::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 3rpx;
}

.changelog-scroll::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 3rpx;
}

.changelog-scroll::-webkit-scrollbar-thumb:hover {
  background: #a1a1a1;
}

.changelog-item {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.changelog-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.changelog-version {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 10rpx 15rpx;
  background: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.version-number {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.version-date {
  font-size: 24rpx;
  color: #999;
}

.changelog-content {
  background: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.changelog-category {
  margin-bottom: 20rpx;
}

.changelog-category:last-child {
  margin-bottom: 0;
}

.category-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 15rpx;
  display: block;
}

.changelog-features {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.feature-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  display: block;
  padding-left: 10rpx;
}

.changelog-empty {
  height: 400rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
  font-size: 28rpx;
}

/* 确保滚动条在iOS设备上也能正常显示 */
@media screen and (-webkit-min-device-pixel-ratio: 0) {
  .changelog-scroll {
    -webkit-overflow-scrolling: touch;
  }
}