/* pages/profile/profile.wxss */
/* 主色变量和统一按钮样式 */
.main-color {
  color: #07c160;
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(7,193,96,0.08);
  transition: all 0.3s ease;
}
.btn-primary:active {
  background: #059e4d;
  transform: translateY(2rpx);
}
.modal {
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12);
}
.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
  text-align: center;
  margin: 20rpx 0;
}

.profile-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
  margin: 30rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  border: 1rpx solid #f0f0f0;
}

.profile-section:hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transform: translateY(-4rpx);
}







.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 10rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  border: 1rpx solid #f0f0f0;
  overflow: hidden;
}

.section:first-child {
  margin-top: 0;
}

.section:last-child {
  margin-bottom: 0;
}

.section:hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transform: translateY(-4rpx);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title::before {
  content: "";
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160, #1890ff);
  margin-right: 12rpx;
}

.intro-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 1rpx solid #f0f0f0;
}

.data-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  font-size: 30rpx;
  padding: 5rpx;
  border-radius: 30rpx;
  transition: all 0.3s ease;
  text-align: center;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: none;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.export-btn {
  background: #1890ff;
  color: #fff;
}

.import-btn {
  background: #52c41a;
  color: #fff;
}

.share-btn {
  background: #fa8c16;
  color: #fff;
}

.clear-btn {
  background: #ff4d4f;
  color: #fff;
}

.contact-btn {
  background: #1890ff;
  color: #fff;
}

.donate-btn {
  background: #fa8c16;
  color: #fff;
}



.input-item {
  margin-bottom: 20rpx;
}

.filename-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #07c160;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 80rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.1);
  transition: all 0.3s ease;
}

.filename-input:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.3);
  outline: none;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  width: 80%;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 10rpx;
  color: #333;
}

.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.input:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 2rpx rgba(7, 193, 96, 0.2);
  outline: none;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  margin: 0 10rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
  transition: all 0.3s ease;
  font-weight: 500;
}

.cancel-btn {
  background: #f0f0f0;
  color: #666;
}

.cancel-btn:active {
  background: #e0e0e0;
  transform: translateY(2rpx);
}

.confirm-btn {
  background: #07c160;
  color: #fff;
}

.confirm-btn:active {
  background: #059e4d;
  transform: translateY(2rpx);
}

/* 使用说明样式 */
.usage-guide {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.guide-item {
  margin-bottom: 10rpx;
  display: flex;
  flex-direction: column;
}

.highlight {
  color: #fa8c16;
  font-weight: bold;
  margin-top: 5rpx;
}

/* 用户板块样式 */
.user-section {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 20rpx 30rpx;
  position: relative;
  overflow: hidden;
}

.user-info {
  display: flex;
  align-items: flex-start;
  gap: 40rpx;
  cursor: pointer;
  padding: 20rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.user-info:hover {
  background: #f0fff0;
  transform: translateY(-2rpx);
}

/* 背景贴纸样式 */
.avatar-background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
  opacity: 0.5;
  overflow: hidden;
}

.avatar-sticker {
  position: absolute;
  font-size: 80rpx;
  line-height: 1;
  opacity: 0.9;
  animation: float 6s ease-in-out infinite;
}

/* 贴纸位置和动画延迟 */
.sticker-1 {
  top: 10rpx;
  left: 10rpx;
  animation-delay: 0s;
  transform: rotate(-25deg);
  opacity: 0.9;
  font-size: 80rpx;
}

.sticker-2 {
  top: -20rpx;
  right: 80rpx;
  animation-delay: 1s;
  transform: rotate(30deg);
  opacity: 1;
  font-size: 100rpx;
}

.sticker-3 {
  bottom: 10rpx;
  left: 20rpx;
  animation-delay: 2s;
  transform: rotate(45deg);
  opacity: 1;
  font-size: 60rpx;
}

.sticker-4 {
  bottom: -10rpx;
  right: 20rpx;
  animation-delay: 3s;
  transform: rotate(-40deg);
  opacity: 0.9;
  font-size: 95rpx;
}

.sticker-5 {
  top: 20rpx;
  left: 300rpx;
  transform: rotate(60deg);
  animation-delay: 4s;
  opacity: 1;
  font-size: 80rpx;
}

/* 新增贴纸 */
.sticker-6 {
  bottom: 30rpx;
  left: 410rpx;
  transform: rotate(-35deg);
  animation-delay: 0.5s;
  opacity: 0.9;
  font-size: 90rpx;
}

.sticker-7 {
  top: 70rpx;
  left: 180rpx;
  transform: rotate(15deg);
  animation-delay: 1.5s;
  opacity: 1;
  font-size: 75rpx;
}

.sticker-8 {
  bottom: 10rpx;
  left: 270rpx;
  transform: rotate(-50deg);
  animation-delay: 2.5s;
  opacity: 0.9;
  font-size: 65rpx;
}

/* 浮动动画 */
@keyframes float {
  0%, 100% {
    transform: translate(0, 0) rotate(var(--rotate, 0deg));
  }
  25% {
    transform: translate(5rpx, -5rpx) rotate(calc(var(--rotate, 0deg) + 2deg));
  }
  50% {
    transform: translate(0, -10rpx) rotate(calc(var(--rotate, 0deg) - 2deg));
  }
  75% {
    transform: translate(-5rpx, -5rpx) rotate(calc(var(--rotate, 0deg) + 1deg));
  }
}

/* 确保用户信息和头像在贴纸上方 */
.avatar,
.user-details {
  position: relative;
  z-index: 1;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160 0%, #059e4d 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.2);
}

.avatar-text {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.username-display {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  letter-spacing: 2rpx;
}

.username-display:empty::before {
  content: '点击自定义用户名';
  color: #999;
  font-weight: normal;
}

/* 头像选项样式 */
.avatar-options {
  margin-top: 10rpx;
  display: flex;
  gap: 20rpx;
}

.avatar-option {
  font-size: 24rpx;
  color: #07c160;
  cursor: pointer;
  padding: 5rpx 10rpx;
  border-radius: 10rpx;
  transition: all 0.3s ease;
}

.avatar-option:active {
  background: #f0fff0;
  transform: translateY(2rpx);
}

/* 表情文字样式 */
.avatar-emoji-text {
  font-size: 24rpx;
  color: #666;
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
  font-weight: 500;
  align-self: flex-start;
  margin-top: 10rpx;
}

/* 积极情绪背景 */
.emoji-emotion-positive {
  background: #f0fff0;
  color: #07c160;
}

/* 中性情绪背景 */
.emoji-emotion-neutral {
  background: #f0f0f0;
  color: #666;
}

/* 消极情绪背景 */
.emoji-emotion-negative {
  background: #fff0f0;
  color: #ff4d4f;
}

/* 表情头像样式 */
.avatar-emoji {
  font-size: 80rpx;
  line-height: 120rpx;
  text-align: center;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 表情选择弹窗样式 - 重新设计 */
.modal-container.emoji-modal {
  width: 90%;
  max-width: 600rpx;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.18);
  overflow: hidden;
  background: white;
  animation: modalSlideIn 0.3s ease-out;
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* 模态框滑入动画 */
@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) translateY(0);
  }
}

.modal-container.emoji-modal .modal-header {
  background: linear-gradient(135deg, #07c160 0%, #059e4d 100%);
  color: white;
  border: none;
  padding: 30rpx;
}

.modal-container.emoji-modal .modal-title {
  color: white;
  font-size: 36rpx;
  font-weight: 600;
}

.modal-container.emoji-modal .modal-close-btn {
  color: white;
  font-size: 36rpx;
}

.modal-container.emoji-modal .modal-content {
  padding: 0;
  background: white;
  width: 100%;
}

.emoji-content {
  max-height: 550rpx;
  overflow-y: auto;
  padding: 0;
  box-sizing: border-box;
}

/* 自定义滚动条 */
.emoji-content::-webkit-scrollbar {
  width: 6rpx;
}

.emoji-content::-webkit-scrollbar-track {
  background: #f8f8f8;
  border-radius: 3rpx;
}

.emoji-content::-webkit-scrollbar-thumb {
  background: #d1d1d1;
  border-radius: 3rpx;
}

.emoji-content::-webkit-scrollbar-thumb:hover {
  background: #b1b1b1;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 20rpx;
  background: white;
  justify-content: space-around;
  box-sizing: border-box;
  width: 100%;
}

.emoji-item {
  flex: 0 0 calc(25% - 15rpx);
  width: calc(25% - 15rpx);
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #fafafa;
  cursor: pointer;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.emoji-item:hover {
  background: #f0fff0;
  transform: translateY(-4rpx);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
}

.emoji-item:active {
  background: #e6fff0;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 选中表情项样式 */
.emoji-item-selected {
  background: linear-gradient(135deg, #e6f7ff, #f0f9ff);
  border: 2rpx solid #1890ff;
  box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.2);
  transform: scale(1.1);
  position: relative;
}

.emoji-item-selected::after {
  content: '';
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 24rpx;
  height: 24rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  border-radius: 50%;
  border: 4rpx solid white;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.3);
  animation: pulse 0.6s ease-out;
}

/* 选中动画 */
@keyframes pulse {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  50% {
    transform: scale(1.2);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.emoji-icon {
  font-size: 72rpx;
  line-height: 1;
  transition: all 0.2s ease;
}

.selected-emoji {
  margin: 0;
  padding: 20rpx 30rpx;
  background: #fafafa;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.selected-emoji-label {
  font-size: 28rpx;
  color: #555;
  font-weight: 500;
}

.selected-emoji-icon {
  font-size: 48rpx;
  line-height: 1;
}

.modal-container.emoji-modal .modal-footer {
  background: #fafafa;
  border-top: 1rpx solid #f0f0f0;
  padding: 20rpx 30rpx;
  gap: 24rpx;
  display: flex;
}

.modal-container.emoji-modal .modal-btn {
  flex: 1;
  height: 92rpx;
  border-radius: 46rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 1rpx;
}

.modal-container.emoji-modal .cancel-btn {
  background: white;
  color: #666;
  border: 2rpx solid #e0e0e0;
}

.modal-container.emoji-modal .cancel-btn:hover {
  background: #f8f8f8;
  border-color: #d0d0d0;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-2rpx);
}

.modal-container.emoji-modal .cancel-btn:active {
  background: #e8e8e8;
  border-color: #c0c0c0;
  transform: translateY(0);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.modal-container.emoji-modal .confirm-btn {
  background: linear-gradient(135deg, #07c160 0%, #059e4d 100%);
  color: white;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.35);
  position: relative;
  overflow: hidden;
}

.modal-container.emoji-modal .confirm-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.modal-container.emoji-modal .confirm-btn:hover::before {
  left: 100%;
}

.modal-container.emoji-modal .confirm-btn:hover {
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.45);
  transform: translateY(-3rpx);
}

.modal-container.emoji-modal .confirm-btn:active {
  background: linear-gradient(135deg, #059e4d 0%, #048c42 100%);
  transform: translateY(0) scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

/* 模态框通用样式 - 统一弹窗设计 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

/* 基础弹窗样式 - 与表情头像弹窗保持一致 */
.modal-container {
  width: 90%;
  max-width: 600rpx;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.18);
  overflow: hidden;
  background: white;
  animation: modalSlideIn 0.3s ease-out;
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1000;
}

/* 模态框滑入动画 */
@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) translateY(0);
  }
}

/* 弹窗头部样式 - 渐变背景 */
.modal-header {
  background: linear-gradient(135deg, #07c160 0%, #059e4d 100%);
  color: white;
  border: none;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 弹窗标题样式 */
.modal-title {
  color: white;
  font-size: 36rpx;
  font-weight: 600;
}

/* 关闭按钮样式 */
.modal-close-btn {
  width: 60rpx;
  height: 60rpx;
  padding: 0;
  margin: 0;
  background: rgba(255, 255, 255, 0.2);
  border: none;
  font-size: 36rpx;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.modal-close-btn:hover {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(1.05);
}

.modal-close-btn:active {
  background: rgba(255, 255, 255, 0.4);
  transform: scale(0.95);
}

/* 弹窗内容区域 */
.modal-content {
  padding: 40rpx 30rpx 20rpx 30rpx;
  background: white;
  width: 100%;
  box-sizing: border-box;
}

/* 输入框组样式 */
.modal-input-group {
  display: flex;
  align-items: center;
  width: 100%;
  margin-bottom: 20rpx;
}

/* 输入框样式 */
.modal-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #07c160;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 80rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.1);
  transition: all 0.3s ease;
}

.modal-input:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.3);
  outline: none;
}

/* 提示文字样式 */
.modal-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 20rpx;
}

/* 弹窗底部样式 */
.modal-footer {
  background: #fafafa;
  border-top: 1rpx solid #f0f0f0;
  padding: 20rpx 30rpx;
  gap: 24rpx;
  display: flex;
  justify-content: space-between;
}

/* 按钮通用样式 */
.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 0.5rpx;
}

/* 取消按钮样式 */
.cancel-btn {
  background: white;
  color: #666;
  border: 2rpx solid #e0e0e0;
}

.cancel-btn:hover {
  background: #f8f8f8;
  border-color: #d0d0d0;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-2rpx);
}

.cancel-btn:active {
  background: #e8e8e8;
  border-color: #c0c0c0;
  transform: translateY(0);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 确定按钮样式 - 渐变背景 */
.confirm-btn {
  background: linear-gradient(135deg, #07c160 0%, #059e4d 100%);
  color: white;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.35);
  position: relative;
  overflow: hidden;
}

.confirm-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.confirm-btn:hover::before {
  left: 100%;
}

.confirm-btn:hover {
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.45);
  transform: translateY(-3rpx);
}

.confirm-btn:active {
  background: linear-gradient(135deg, #059e4d 0%, #048c42 100%);
  transform: translateY(0) scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

/* 更新日志样式 */
.changelog-container {
  background: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #f0f0f0;
  margin-top: 20rpx;
}

.changelog-scroll {
  height: 500rpx; /* 设置固定高度，允许向下滚动查看所有内容 */
  overflow-y: auto;
  padding: 20rpx;
}

/* 自定义滚动条样式 */
.changelog-scroll::-webkit-scrollbar {
  width: 8rpx;
}

.changelog-scroll::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 4rpx;
}

.changelog-scroll::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 4rpx;
}

.changelog-scroll::-webkit-scrollbar-thumb:hover {
  background: #a1a1a1;
}

/* 版本小板块样式 */
.changelog-version-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 版本标题样式 */
.changelog-version-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.version-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #07c160;
}

.version-date {
  font-size: 22rpx;
  color: #999;
}

/* 版本内容样式 */
.changelog-version-content {
  font-size: 24rpx;
  line-height: 1.6;
  color: #333;
  white-space: pre-wrap; /* 保留换行符 */
  letter-spacing: 0.5rpx;
}

/* 空行样式 */
.changelog-version-content text:empty {
  display: none;
}

.changelog-empty {
  height: 500rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
  font-size: 28rpx;
}

/* 确保滚动条在iOS设备上也能正常显示 */
@media screen and (-webkit-min-device-pixel-ratio: 0) {
  .changelog-scroll {
    -webkit-overflow-scrolling: touch;
  }
}