<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 页面标题区 -->
  <view class="page-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="header-user-info">
        <view class="header-avatar-wrapper" bindtap="showEmojiModal">
          <view class="header-avatar">
            <text class="header-avatar-text" wx:if="{{avatarType === 'text'}}">{{avatarText}}</text>
            <text class="header-avatar-emoji" wx:else>{{avatarEmoji || '😊'}}</text>
          </view>
          <view class="header-avatar-edit {{avatarType === 'emoji' && emojiEmotion ? emojiEmotion : ''}}"></view>
        </view>
        <view class="header-user-details">
          <text class="header-username" bindtap="showCloudLoginOrRegisterModal">{{username || '点击设置云备份账号'}}</text>
          <text class="header-user-status {{avatarType === 'emoji' && emojiEmotion ? 'emotion-' + emojiEmotion : ''}}" wx:if="{{avatarType === 'emoji' && emojiText}}">{{emojiText}}</text>
          <text class="header-user-status" wx:else>点击头像更换表情</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 项目介绍区块 -->
  <view class="section about-section">
    <view class="section-header">
      <view class="section-icon about-icon">
        <text class="icon-text">💝</text>
      </view>
      <text class="section-title">项目介绍</text>
      <view class="section-right">
        <view class="manual-btn" bindtap="navigateToDocs">
          <text class="btn-text">说明书</text>
        </view>
      </view>
    </view>
    <view class="section-body">
      <view class="about-content">
        <view class="about-item">
          <text class="about-dot">🎯</text>
          <text class="about-text">这是一个为作者爱人创建的便捷工时/排班管理系统，功能正在逐步完善，完全免费无广告的公益项目。</text>
        </view>
        <view class="about-item">
          <text class="about-dot">🤝</text>
          <text class="about-text">若您觉得好用，可以分享此小程序以支持作者，也可以点击捐赠支持，支持公益事业！</text>
        </view>
        <view class="about-item">
          <text class="about-dot">🔒</text>
          <text class="about-text">所有的数据都保存在本地，没有数据上传请保管好自己的数据，如有问题反馈欢迎联系作者。</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 云备份区块 -->
  <view class="section">
    <view class="section-header">
      <view class="section-icon webdav-icon">
        <text class="icon-text">☁️</text>
      </view>
      <text class="section-title">云备份</text>
    </view>
    <view class="section-body">
      <view wx:if="{{cloudLoggedIn}}" class="cloud-info">
        <view class="btn-grid">
          <view class="grid-btn backup-btn" bindtap="backupToCloud">
            <text class="btn-icon">⬆️</text>
            <text class="btn-text">备份</text>
          </view>
          <view class="grid-btn restore-btn" bindtap="restoreFromCloud">
            <text class="btn-icon">⬇️</text>
            <text class="btn-text">恢复</text>
          </view>
        </view>
      </view>
      <view wx:else class="cloud-login">
        <view class="btn-grid">
          <view class="grid-btn login-btn" bindtap="showCloudLoginModal">
            <text class="btn-icon">🔑</text>
            <text class="btn-text">登录</text>
          </view>
          <view class="grid-btn register-btn" bindtap="showCloudRegisterModal">
            <text class="btn-icon">📝</text>
            <text class="btn-text">注册</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 数据管理区块 -->
  <view class="section">
    <view class="section-header">
      <view class="section-icon data-icon">
        <text class="icon-text">💾</text>
      </view>
      <text class="section-title">数据管理</text>
      <view class="help-btn" bindtap="navigateToDocs" data-type="data">
        <text class="help-icon">?</text>
      </view>
    </view>
    <view class="section-body">
      <view class="btn-grid">
        <view class="grid-btn export-btn" bindtap="showDataTypeModal">
          <text class="btn-icon">📤</text>
          <text class="btn-text">导出数据</text>
        </view>
        <view class="grid-btn share-btn" bindtap="shareExportedFile">
          <text class="btn-icon">📨</text>
          <text class="btn-text">分享数据</text>
        </view>
        <view class="grid-btn import-btn" bindtap="importData">
          <text class="btn-icon">📥</text>
          <text class="btn-text">导入数据</text>
        </view>
        <view class="grid-btn clear-btn" bindtap="clearAllData">
          <text class="btn-icon">🗑️</text>
          <text class="btn-text">清空数据</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 更新日志区块 -->
  <view class="section">
    <view class="section-header">
      <view class="section-icon changelog-icon">
        <text class="icon-text">📝</text>
      </view>
      <text class="section-title">更新日志</text>
    </view>
    <view class="section-body">
      <!-- WeUI 风格更新日志 -->
      <view class="weui-panel weui-panel_access" wx:if="{{changelog && changelog.length > 0}}">
        <scroll-view class="changelog-scroll" scroll-y enhanced show-scrollbar scroll-into-view="changelog-item-0">
          <view class="weui-cells__title" wx:if="{{changelog.length > 0}}">
            <view class="weui-cells__title-text">版本历史</view>
          </view>
          <view class="weui-cells">
            <view id="changelog-item-{{index}}" class="weui-cell weui-cell_access {{index === 0 ? 'weui-cell_active' : ''}}" wx:for="{{changelog}}" wx:key="version">
              <view class="weui-cell__hd">
                <view class="weui-cell__icon-wrapper">
                  <view class="weui-cell__icon {{index === 0 ? 'weui-cell__icon_latest' : ''}}"></view>
                  <view class="weui-cell__line" wx:if="{{index !== changelog.length - 1}}"></view>
                </view>
              </view>
              <view class="weui-cell__bd">
                <view class="weui-cell__version">
                  <text class="weui-cell__version-tag">{{item.version}}</text>
                  <view class="weui-badge weui-badge_dot" wx:if="{{index === 0}}">
                    <view class="weui-badge__text">最新</view>
                  </view>
                </view>
                <view class="weui-cell__date">{{item.date}}</view>
                <view class="weui-cell__content">
                  <text class="weui-cell__text">{{item.content}}</text>
                </view>
              </view>
              <view class="weui-cell__ft"></view>
            </view>
          </view>
        </scroll-view>
      </view>
      
      <!-- 空状态 -->
      <view class="weui-msg" wx:else>
        <view class="weui-msg__icon-area">
          <text class="weui-msg__icon">📝</text>
        </view>
        <view class="weui-msg__text-area">
          <view class="weui-msg__title">暂无更新日志</view>
          <view class="weui-msg__desc">后续更新将在这里显示</view>
        </view>
      </view>
      
      <!-- 操作按钮 -->
      <view class="weui-btn-area">
        <view class="weui-btn weui-btn_default" bindtap="contactAuthor">
          <text class="weui-btn__icon">💬</text>
          <text class="weui-btn__text">联系乐乐</text>
        </view>
        <view class="weui-btn weui-btn_primary" bindtap="donate">
          <text class="weui-btn__icon">❤️</text>
          <text class="weui-btn__text">捐赠支持</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 用户名设置弹窗 -->
  <view class="modal-mask {{showUsernameModal ? 'show' : ''}}" wx:if="{{showUsernameModal}}" bindtap="hideUsernameModal"></view>
  <view class="modal-container {{showUsernameModal ? 'show' : ''}}" wx:if="{{showUsernameModal}}">
    <view class="modal-header">
      <text class="modal-title">设置用户名</text>
      <view class="modal-close" bindtap="hideUsernameModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="modal-body">
      <view class="input-wrapper">
        <input class="modal-input" placeholder="请输入用户名" value="{{tempUsername}}" bindinput="onTempUsernameInput" maxlength="20"></input>
      </view>
      <text class="input-hint">用户名将用于导出文件名</text>
    </view>
    <view class="modal-footer">
      <button class="modal-btn btn-cancel" bindtap="hideUsernameModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="confirmUsername">确定</button>
    </view>
  </view>

  <!-- 表情选择弹窗 -->
  <view class="modal-mask {{showEmojiModal ? 'show' : ''}}" wx:if="{{showEmojiModal}}" bindtap="hideEmojiModal"></view>
  <view class="modal-container emoji-modal {{showEmojiModal ? 'show' : ''}}" wx:if="{{showEmojiModal}}">
    <view class="modal-header">
      <text class="modal-title">选择表情头像</text>
      <view class="modal-close" bindtap="hideEmojiModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="modal-body emoji-body">
      <view class="emoji-grid">
        <view class="emoji-item {{selectedEmoji === item ? 'selected' : ''}}" wx:for="{{emojiList}}" wx:key="index" bindtap="selectEmoji" data-emoji="{{item}}">
          <text class="emoji-char">{{item}}</text>
        </view>
      </view>
      <view class="emoji-preview" wx:if="{{selectedEmoji}}">
        <text class="preview-label">已选择：</text>
        <text class="preview-emoji">{{selectedEmoji}}</text>
        <text class="preview-text">{{emojiTextMap[selectedEmoji]}}</text>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn btn-cancel" bindtap="hideEmojiModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="confirmEmoji">确定</button>
    </view>
  </view>

  <!-- 数据类型选择弹窗 -->
  <view class="modal-mask {{showDataTypeModal ? 'show' : ''}}" wx:if="{{showDataTypeModal}}" bindtap="hideDataTypeModal"></view>
  <view class="modal-container {{showDataTypeModal ? 'show' : ''}}" wx:if="{{showDataTypeModal}}">
    <view class="modal-header">
      <text class="modal-title">选择导出数据</text>
      <view class="modal-close" bindtap="hideDataTypeModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="modal-body">
      <view class="checkbox-list">
        <view class="checkbox-item" wx:for="{{dataTypes}}" wx:key="id" bindtap="onDataTypeSelect" data-typeid="{{item.id}}">
          <view class="checkbox-wrapper">
            <view class="checkbox {{item.checked ? 'checked' : ''}}">
              <text class="check-icon" wx:if="{{item.checked}}">✓</text>
            </view>
          </view>
          <text class="checkbox-label">{{item.name}}</text>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn btn-cancel" bindtap="hideDataTypeModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="confirmDataTypeSelect">确定</button>
    </view>
  </view>

  <!-- 文件名设置弹窗 -->
  <view class="modal-mask {{showFileNameModal ? 'show' : ''}}" wx:if="{{showFileNameModal}}" bindtap="hideFileNameModal"></view>
  <view class="modal-container {{showFileNameModal ? 'show' : ''}}" wx:if="{{showFileNameModal}}">
    <view class="modal-header">
      <text class="modal-title">设置文件名</text>
      <view class="modal-close" bindtap="hideFileNameModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="modal-body">
      <view class="input-wrapper">
        <input class="modal-input" placeholder="{{defaultFileNameHint}}" value="{{tempFileName}}" bindinput="onTempFileNameInput" maxlength="50"></input>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn btn-cancel" bindtap="hideFileNameModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="confirmExport">确定导出</button>
    </view>
  </view>

  <!-- 云开发登录弹窗 -->
  <view class="modal-mask {{showCloudLoginModal ? 'show' : ''}}" wx:if="{{showCloudLoginModal}}" bindtap="hideCloudLoginModal"></view>
  <view class="modal-container {{showCloudLoginModal ? 'show' : ''}}" wx:if="{{showCloudLoginModal}}">
    <view class="modal-header">
      <text class="modal-title">登录</text>
      <view class="modal-close" bindtap="hideCloudLoginModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="modal-body">
      <view class="form-group">
        <text class="form-label">账号</text>
        <input class="form-input" placeholder="请输入账号" value="{{cloudAccountInput}}" bindinput="onCloudAccountInput"></input>
      </view>
      <view class="form-group">
        <text class="form-label">密码</text>
        <view class="password-wrapper">
          <input class="form-input password-input" placeholder="请输入密码" value="{{cloudPasswordInput}}" bindinput="onCloudPasswordInput" password="{{!showCloudPassword}}"></input>
          <view class="password-toggle" bindtap="toggleCloudPasswordVisibility">
            <text class="toggle-text">{{showCloudPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn btn-cancel" bindtap="hideCloudLoginModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="loginToCloud">登录</button>
    </view>
  </view>

  <!-- 云开发注册弹窗 -->
  <view class="modal-mask {{showCloudRegisterModal ? 'show' : ''}}" wx:if="{{showCloudRegisterModal}}" bindtap="hideCloudRegisterModal"></view>
  <view class="modal-container {{showCloudRegisterModal ? 'show' : ''}}" wx:if="{{showCloudRegisterModal}}">
    <view class="modal-header">
      <text class="modal-title">注册</text>
      <view class="modal-close" bindtap="hideCloudRegisterModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="modal-body">
      <view class="form-group">
        <text class="form-label">账号</text>
        <input class="form-input" placeholder="请输入账号" value="{{cloudAccountInput}}" bindinput="onCloudAccountInput"></input>
      </view>
      <view class="form-group">
        <text class="form-label">密码</text>
        <view class="password-wrapper">
          <input class="form-input password-input" placeholder="请输入密码" value="{{cloudPasswordInput}}" bindinput="onCloudPasswordInput" password="{{!showCloudPassword}}"></input>
          <view class="password-toggle" bindtap="toggleCloudPasswordVisibility">
            <text class="toggle-text">{{showCloudPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">确认密码</text>
        <view class="password-wrapper">
          <input class="form-input password-input" placeholder="请再次输入密码" value="{{cloudConfirmPassword}}" bindinput="onCloudConfirmPasswordInput" password="{{!showCloudPassword}}"></input>
          <view class="password-toggle" bindtap="toggleCloudPasswordVisibility">
            <text class="toggle-text">{{showCloudPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn btn-cancel" bindtap="hideCloudRegisterModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="registerToCloud">注册</button>
    </view>
  </view>

  <!-- 用户管理弹窗 -->
  <view class="modal-mask {{showUserManagementModal ? 'show' : ''}}" wx:if="{{showUserManagementModal}}" bindtap="hideUserManagementModal"></view>
  <view class="modal-container user-management-modal {{showUserManagementModal ? 'show' : ''}}" wx:if="{{showUserManagementModal}}">
    <view class="modal-header">
      <text class="modal-title">用户管理</text>
      <view class="modal-close" bindtap="hideUserManagementModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="modal-body">
      <view class="user-info-section">
        <view class="user-info-header">
          <view class="user-avatar" bindtap="showEmojiModal">
            <text class="user-avatar-text" wx:if="{{avatarType === 'text'}}">{{avatarText}}</text>
            <text class="user-avatar-emoji" wx:else>{{avatarEmoji || '😊'}}</text>
          </view>
          <view class="user-info-details">
            <text class="user-account">{{cloudAccount}}</text>
            <text class="user-status">已登录</text>
          </view>
        </view>
        <view class="user-info-divider"></view>
        <view class="user-info-item">
          <text class="info-label">账号</text>
          <text class="info-value">{{cloudAccount}}</text>
        </view>
        <view class="user-info-item">
          <text class="info-label">登录状态</text>
          <text class="info-value status-online">在线</text>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn btn-cancel" bindtap="hideUserManagementModal">关闭</button>
      <button class="modal-btn btn-danger" bindtap="confirmLogout">退出登录</button>
    </view>
  </view>
</view>
