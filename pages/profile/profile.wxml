<!-- pages/profile/profile.wxml -->
<view class="container">
  <view class="header">
    <text class="title">个人中心</text>
  </view>

  <view class="profile-section">
    <view class="avatar-container">
    <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar" mode="aspectFill" binderror="onAvatarError"></image>
    <image wx:else src="/images/default_avatar.png" class="avatar" mode="aspectFill"></image>
  </view>
    <view class="nickname-container">
    <text class="nickname">{{userInfo.nickName}}</text>
  </view>
    <!-- 微信登录按钮 -->
    <view class="login-section" wx:if="{{!hasLogin}}">
      <button class="login-btn" bindtap="loginWithWeChat">使用微信登录</button>
    </view>
  </view>

  <view class="section">
    <text class="section-title">项目介绍</text>
    <view class="intro-content">
      <text>这是一个便捷的排班管理系统，支持班次模板设置、排班安排和统计功能。\n\n主要功能：\n1. 班次模板管理 - 创建和管理常用班次\n2. 排班安排 - 按周或月查看和编辑排班\n3. 数据统计 - 统计工时和班次情况\n4. 数据导入导出 - 保护您的数据安全</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">数据管理</text>
    <view class="input-item">
      <input class="filename-input" placeholder="请输入导出文件名(不含扩展名)" value="{{exportFileName}}" bindinput="onFileNameInput"></input>
    </view>
    <view class="data-actions">
      <button class="action-btn export-btn" bindtap="exportData">导出数据</button>
      <button class="action-btn import-btn" bindtap="importData">导入数据</button>
    </view>
    <view class="data-actions" style="margin-top: 20rpx;">
      <button class="action-btn clear-btn" bindtap="clearAllData">清空数据</button>
    </view>
  </view>
  
  <view class="section">
    <text class="section-title">更多功能</text>
    <view class="data-actions">
      <button class="action-btn export-btn" bindtap="exportAllDataToCSV">导出CSV</button>
      <button class="action-btn import-btn" bindtap="importAllDataFromCSV">导入CSV</button>
    </view>
  </view>
</view>