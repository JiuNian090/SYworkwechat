<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 页面标题区 -->
  <view class="page-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="header-user-info">
        <view class="header-avatar-wrapper" bindtap="showCloudLoginOrRegisterModal">
          <view class="header-avatar">
            <text class="header-avatar-text" wx:if="{{avatarType === 'text'}}">{{avatarText}}</text>
            <text class="header-avatar-emoji" wx:else>{{avatarEmoji || '😊'}}</text>
          </view>
          <view class="header-avatar-edit {{avatarType === 'emoji' && emojiEmotion ? emojiEmotion : ''}}"></view>
        </view>
        <view class="header-user-details">
          <text class="header-username" bindtap="showCloudLoginOrRegisterModal">{{username || '点击登录云账号'}}</text>
          <text class="header-user-status {{avatarType === 'emoji' && emojiEmotion ? 'emotion-' + emojiEmotion : ''}}" wx:if="{{avatarType === 'emoji' && emojiText}}">{{emojiText}}</text>
          <text class="header-user-status" wx:else>点击头像进入用户管理</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 区块容器 -->
  <view class="sections-container">
    <!-- 项目介绍区块 -->
    <view class="section about-section">
      <view class="section-header">
        <view class="section-icon about-icon">
          <text class="icon-text">💝</text>
        </view>
        <text class="section-title">项目介绍</text>
        <view class="section-right">
          <view class="manual-btn" bindtap="navigateToDocs">
            <text class="btn-text">说明书</text>
          </view>
        </view>
      </view>
      <view class="section-body">
        <view class="about-content">
          <view class="about-item">
            <text class="about-dot">🎯</text>
            <text class="about-text">这是一个为作者爱人创建的便捷工时/排班管理系统，功能正在逐步完善，完全免费无广告的公益项目。</text>
          </view>
          <view class="about-item">
            <text class="about-dot">🤝</text>
            <text class="about-text">若您觉得好用，可以分享此小程序以支持作者，也可以点击捐赠支持，支持公益事业！</text>
          </view>
          <view class="about-item">
            <text class="about-dot">🔒</text>
            <text class="about-text">数据默认保存在本地，安全可靠。若使用云备份功能，请妥善保管您的账号密码，定期备份重要数据。如有任何问题或建议，欢迎随时联系作者反馈。</text>
          </view>
        </view>
        
        <!-- 操作按钮 -->
        <view class="weui-btn-area">
          <button open-type="contact" class="weui-btn weui-btn_default">
            <text class="weui-btn__icon">💬</text>
            <text class="weui-btn__text">联系乐乐</text>
          </button>
          <view class="weui-btn weui-btn_primary" bindtap="donate">
            <text class="weui-btn__icon">❤️</text>
            <text class="weui-btn__text">捐赠支持</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 云备份区块 -->
    <view class="section">
      <view class="section-header">
        <view class="section-header-left">
          <view class="section-icon cloud-icon">
            <text class="icon-text">☁️</text>
          </view>
          <text class="section-title">云备份</text>
          <view class="cloud-status {{cloudLoggedIn ? 'cloud-status-logged-in' : ''}}" wx:if="{{backupStatus}}" catchtap="onCloudStatusTap">
            <view class="status-breath status-{{backupStatus.type}}"></view>
            <text class="status-label">{{backupStatus.label}}</text>
          </view>
        </view>
        <view class="help-btn" bindtap="navigateToDocs" data-type="cloud">
          <text class="help-icon">?</text>
        </view>
      </view>
      <view class="section-body">
        <view wx:if="{{cloudLoggedIn}}" class="cloud-info">
          <view class="btn-grid">
            <view class="grid-btn backup-btn" bindtap="backupToCloud">
              <text class="btn-icon">⬆️</text>
              <text class="btn-text">备份</text>
            </view>
            <view class="grid-btn restore-btn" bindtap="restoreFromCloud">
              <text class="btn-icon">⬇️</text>
              <text class="btn-text">恢复</text>
            </view>
          </view>
        </view>
        <view wx:else class="cloud-login">
          <view class="btn-grid">
            <view class="grid-btn login-btn" bindtap="showCloudLoginModal">
              <text class="btn-icon">🔑</text>
              <text class="btn-text">登录</text>
            </view>
            <view class="grid-btn register-btn" bindtap="showCloudRegisterModal">
              <text class="btn-icon">📝</text>
              <text class="btn-text">注册</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 数据管理区块 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">💾</text>
        </view>
        <text class="section-title">数据管理</text>
        <view class="help-btn" bindtap="navigateToDocs" data-type="data">
          <text class="help-icon">?</text>
        </view>
      </view>
      <view class="section-body">
        <view class="btn-grid">
          <view class="grid-btn export-btn" bindtap="showDataTypeModal">
            <text class="btn-icon">📤</text>
            <text class="btn-text">导出数据</text>
          </view>
          <view class="grid-btn share-btn" bindtap="shareExportedFile">
            <text class="btn-icon">📨</text>
            <text class="btn-text">分享数据</text>
          </view>
          <view class="grid-btn import-btn" bindtap="importData">
            <text class="btn-icon">📥</text>
            <text class="btn-text">导入数据</text>
          </view>
          <view class="grid-btn clear-btn" bindtap="clearAllData">
            <text class="btn-icon">🗑️</text>
            <text class="btn-text">清空数据</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 更新日志区块 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon changelog-icon">
          <text class="icon-text">📝</text>
        </view>
        <text class="section-title">更新日志</text>
      </view>
      <view class="section-body">
        <!-- WeUI 风格更新日志 -->
        <view class="weui-panel weui-panel_access" wx:if="{{changelog && changelog.length > 0}}">
          <scroll-view class="changelog-scroll" scroll-y enhanced show-scrollbar scroll-into-view="changelog-item-0">
            <view class="weui-cells__title" wx:if="{{changelog.length > 0}}">
              <view class="weui-cells__title-text">版本历史</view>
            </view>
            <view class="weui-cells">
              <view id="changelog-item-{{index}}" class="weui-cell weui-cell_access {{index === 0 ? 'weui-cell_active' : ''}}" wx:for="{{changelog}}" wx:key="version">
                <view class="weui-cell__hd">
                  <view class="weui-cell__icon-wrapper">
                    <view class="weui-cell__icon {{index === 0 ? 'weui-cell__icon_latest' : ''}}"></view>
                    <view class="weui-cell__line" wx:if="{{index !== changelog.length - 1}}"></view>
                  </view>
                </view>
                <view class="weui-cell__bd">
                  <view class="weui-cell__version">
                    <text class="weui-cell__version-tag">{{item.version}}</text>
                    <view class="weui-badge weui-badge_dot" wx:if="{{index === 0}}">
                      <view class="weui-badge__text">最新</view>
                    </view>
                  </view>
                  <view class="weui-cell__date">{{item.date}}</view>
                  <view class="weui-cell__content">
                    <text class="weui-cell__text">{{item.content}}</text>
                  </view>
                </view>
                <view class="weui-cell__ft"></view>
              </view>
            </view>
          </scroll-view>
        </view>
        
        <!-- 空状态 -->
        <view class="weui-msg" wx:else>
          <view class="weui-msg__icon-area">
            <text class="weui-msg__icon">📝</text>
          </view>
          <view class="weui-msg__text-area">
            <view class="weui-msg__title">暂无更新日志</view>
            <view class="weui-msg__desc">后续更新将在这里显示</view>
          </view>
        </view>
        

      </view>
    </view>
  </view>

  <!-- 用户名设置弹窗 -->
  <view class="modal-mask {{showUsernameModal ? 'show' : ''}}" wx:if="{{showUsernameModal}}" bindtap="hideUsernameModal"></view>
  <view class="modal-container {{showUsernameModal ? 'show' : ''}}" wx:if="{{showUsernameModal}}">
    <view class="modal-header">
      <text class="modal-title">设置用户名</text>
      <view class="modal-close" bindtap="hideUsernameModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="modal-body">
      <view class="input-wrapper">
        <input class="modal-input" placeholder="请输入用户名" value="{{tempUsername}}" bindinput="onTempUsernameInput" maxlength="20"></input>
      </view>
      <text class="input-hint">用户名将用于导出文件名</text>
    </view>
    <view class="modal-footer">
      <button class="modal-btn btn-cancel" bindtap="hideUsernameModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="confirmUsername">确定</button>
    </view>
  </view>



  <!-- 数据类型选择弹窗 -->
  <view class="modal-mask {{showDataTypeModal ? 'show' : ''}}" wx:if="{{showDataTypeModal}}" bindtap="hideDataTypeModal"></view>
  <view class="modal-container {{showDataTypeModal ? 'show' : ''}}" wx:if="{{showDataTypeModal}}">
    <view class="modal-header">
      <text class="modal-title">选择导出数据</text>
      <view class="modal-close" bindtap="hideDataTypeModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="modal-body">
      <view class="checkbox-list">
        <view class="checkbox-item" wx:for="{{dataTypes}}" wx:key="id" bindtap="onDataTypeSelect" data-typeid="{{item.id}}">
          <view class="checkbox-wrapper">
            <view class="checkbox {{item.checked ? 'checked' : ''}}">
              <text class="check-icon" wx:if="{{item.checked}}">✓</text>
            </view>
          </view>
          <text class="checkbox-label">{{item.name}}</text>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn btn-cancel" bindtap="hideDataTypeModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="confirmDataTypeSelect">确定</button>
    </view>
  </view>

  <!-- 文件名设置弹窗 -->
  <view class="modal-mask {{showFileNameModal ? 'show' : ''}}" wx:if="{{showFileNameModal}}" bindtap="hideFileNameModal"></view>
  <view class="modal-container {{showFileNameModal ? 'show' : ''}}" wx:if="{{showFileNameModal}}">
    <view class="modal-header">
      <text class="modal-title">设置文件名</text>
      <view class="modal-close" bindtap="hideFileNameModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="modal-body">
      <view class="input-wrapper">
        <input class="modal-input" placeholder="{{defaultFileNameHint}}" value="{{tempFileName}}" bindinput="onTempFileNameInput" maxlength="50"></input>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn btn-cancel" bindtap="hideFileNameModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="confirmExport">确定导出</button>
    </view>
  </view>



  <!-- 云开发注册弹窗 -->
  <view class="modal-mask {{showCloudRegisterModal ? 'show' : ''}}" wx:if="{{showCloudRegisterModal}}" bindtap="hideCloudRegisterModal"></view>
  <view class="modal-container {{showCloudRegisterModal ? 'show' : ''}}" wx:if="{{showCloudRegisterModal}}">
    <view class="modal-header">
      <text class="modal-title">注册</text>
      <view class="modal-close" bindtap="hideCloudRegisterModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="modal-body">
      <view class="form-group">
        <text class="form-label">账号</text>
        <input class="form-input" placeholder="请输入账号" value="{{cloudAccountInput}}" bindinput="onCloudAccountInput"></input>
      </view>
      <view class="form-group">
        <text class="form-label">昵称（可选）</text>
        <input class="form-input" placeholder="请输入昵称" value="{{cloudNicknameInput}}" bindinput="onCloudNicknameInput"></input>
      </view>
      <view class="form-group">
        <text class="form-label">密码</text>
        <view class="password-wrapper">
          <input class="form-input password-input" placeholder="请输入密码" value="{{cloudPasswordInput}}" bindinput="onCloudPasswordInput" password="{{!showCloudPassword}}"></input>
          <view class="password-toggle" bindtap="toggleCloudPasswordVisibility">
            <text class="toggle-text">{{showCloudPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">确认密码</text>
        <view class="password-wrapper">
          <input class="form-input password-input" placeholder="请再次输入密码" value="{{cloudConfirmPassword}}" bindinput="onCloudConfirmPasswordInput" password="{{!showCloudPassword}}"></input>
          <view class="password-toggle" bindtap="toggleCloudPasswordVisibility">
            <text class="toggle-text">{{showCloudPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn btn-cancel" bindtap="hideCloudRegisterModal">取消</button>
      <button class="modal-btn btn-confirm" bindtap="registerToCloud">注册</button>
    </view>
  </view>

  <!-- 用户管理弹窗 -->
  <view class="modal-mask {{showUserManagementModal ? 'show' : ''}}" wx:if="{{showUserManagementModal}}" bindtap="hideUserManagementModal"></view>
  <view class="modal-container user-management-modal {{showUserManagementModal ? 'show' : ''}}" wx:if="{{showUserManagementModal}}">
    <view class="modal-header">
      <view class="header-left" bindtap="goBackToUserManagement" wx:if="{{currentUserPage !== 'main'}}" hover-class="header-btn-hover" hover-stay-time="100">
        <text class="back-icon">←</text>
      </view>
      <view class="header-placeholder" wx:else></view>
      <view class="modal-title-wrapper">
        <text class="modal-title-icon">{{currentUserPage === 'main' ? '👤' : 
          (currentUserPage === 'updateNickname' ? '🏷️' : 
          (currentUserPage === 'updatePassword' ? '🔐' : 
          (currentUserPage === 'avatar' ? '🎭' : 
          (currentUserPage === 'switchAccount' ? '🔄' : 
          (currentUserPage === 'login' ? '🔑' : '🗑️')))))}}</text>
        <text class="modal-title">{{currentUserPage === 'main' ? '用户管理' : 
          (currentUserPage === 'updateNickname' ? '修改昵称' : 
          (currentUserPage === 'updatePassword' ? '修改密码' : 
          (currentUserPage === 'avatar' ? '选择头像' : 
          (currentUserPage === 'switchAccount' ? '切换账号' : 
          (currentUserPage === 'login' ? '账号登录' : '删除账户')))))}}</text>
      </view>
      <view class="modal-close" bindtap="hideUserManagementModal" hover-class="header-btn-hover" hover-stay-time="100">
        <text class="close-icon">✕</text>
      </view>
    </view>
    <view class="modal-body">
      <!-- 主页面 -->
      <view class="user-page user-page-main" wx:if="{{currentUserPage === 'main'}}">
        <view class="user-info-section">
          <view class="user-info-header" bindtap="switchUserPage" data-page="avatar" hover-class="user-info-header-hover" hover-stay-time="100">
            <view class="user-avatar">
              <text class="user-avatar-text" wx:if="{{avatarType === 'text'}}">{{avatarText}}</text>
              <text class="user-avatar-emoji" wx:else>{{avatarEmoji || '😊'}}</text>
            </view>
            <view class="user-info-details">
              <text class="user-nickname">{{cloudUserInfo.nickname || cloudUserInfo.account}}</text>
              <view class="user-status">
                <view class="status-dot"></view>
                <text class="status-text">在线</text>
              </view>
            </view>
            <text class="header-arrow">›</text>
          </view>
          <view class="user-info-list">
            <view class="user-info-item">
              <view class="info-item-left">
                <view class="info-icon-wrapper account-icon">
                  <text class="info-icon">👤</text>
                </view>
                <text class="info-label">账号</text>
              </view>
              <view class="info-value-row">
                <text class="info-value">{{cloudUserInfo.account}}</text>
              </view>
            </view>
            <view class="user-info-item" bindtap="switchUserPage" data-page="updateNickname" hover-class="user-info-item-hover" hover-stay-time="100">
              <view class="info-item-left">
                <view class="info-icon-wrapper nickname-icon">
                  <text class="info-icon">🏷️</text>
                </view>
                <text class="info-label">昵称</text>
              </view>
              <view class="info-value-row">
                <text class="info-value">{{cloudUserInfo.nickname || cloudUserInfo.account}}</text>
                <text class="arrow-icon">›</text>
              </view>
            </view>
            <view class="user-info-item" bindtap="switchUserPage" data-page="updatePassword" hover-class="user-info-item-hover" hover-stay-time="100">
              <view class="info-item-left">
                <view class="info-icon-wrapper password-icon">
                  <text class="info-icon">🔒</text>
                </view>
                <text class="info-label">密码</text>
              </view>
              <view class="info-value-row">
                <text class="info-value">••••••</text>
                <text class="arrow-icon">›</text>
              </view>
            </view>
            <view class="user-info-item" bindtap="switchUserPage" data-page="avatar" hover-class="user-info-item-hover" hover-stay-time="100">
              <view class="info-item-left">
                <view class="info-icon-wrapper avatar-icon">
                  <text class="info-icon">🎭</text>
                </view>
                <text class="info-label">头像</text>
              </view>
              <view class="info-value-row">
                <text class="info-value">{{avatarType === 'text' ? avatarText : avatarEmoji}}</text>
                <text class="arrow-icon">›</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 修改昵称页面 -->
      <view class="user-page user-page-update-nickname" wx:if="{{currentUserPage === 'updateNickname'}}">
        <view class="form-card">
          <view class="form-group">
            <text class="form-label">新昵称</text>
            <input class="form-input" placeholder="请输入新昵称" value="{{newNickname}}" bindinput="onNicknameInput" maxlength="20" />
          </view>
        </view>
      </view>
      
      <!-- 修改密码页面 -->
      <view class="user-page user-page-update-password" wx:if="{{currentUserPage === 'updatePassword'}}">
        <view class="form-card">
          <view class="form-group">
            <text class="form-label">原密码</text>
            <input class="form-input" type="password" placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onOldPasswordInput" />
          </view>
          <view class="form-group">
            <text class="form-label">新密码</text>
            <input class="form-input" type="password" placeholder="请输入新密码（至少 6 位）" value="{{newPassword}}" bindinput="onNewPasswordInput" />
          </view>
          <view class="form-group">
            <text class="form-label">确认新密码</text>
            <input class="form-input" type="password" placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
          </view>
        </view>
      </view>
      
      <!-- 删除账户页面 -->
      <view class="user-page user-page-delete-account" wx:if="{{currentUserPage === 'deleteAccount'}}">
        <view class="warning-card">
          <view class="warning-icon-wrapper">
            <text class="warning-icon">⚠️</text>
          </view>
          <text class="warning-title">危险操作</text>
          <text class="warning-content">删除账户将同时删除所有云端备份数据，此操作不可恢复！</text>
        </view>
        <view class="form-card">
          <view class="form-group">
            <text class="form-label">请输入密码确认</text>
            <input class="form-input" type="password" placeholder="请输入密码" value="{{deleteAccountPassword}}" bindinput="onDeleteAccountPasswordInput" />
          </view>
        </view>
      </view>
      
      <!-- 表情选择页面 -->
      <view class="user-page user-page-emoji-select" wx:if="{{currentUserPage === 'avatar'}}">
        <emoji-picker
          emojiCategories="{{emojiCategories}}"
          currentCategory="{{currentEmojiCategory}}"
          selectedEmoji="{{selectedEmoji}}"
          bind:categorychange="onEmojiCategoryChange"
          bind:select="onEmojiSelect"
          bind:confirm="onEmojiConfirm"
        />
      </view>
      
      <!-- 切换账号页面 -->
      <view class="user-page user-page-switch-account" wx:if="{{currentUserPage === 'switchAccount'}}">
        <view class="switch-tip" wx:if="{{savedAccounts.length > 0}}">
          <text class="switch-tip-icon">☑️</text>
          <text class="switch-tip-text">勾选后下次登录自动恢复数据</text>
        </view>
        <view wx:if="{{savedAccounts.length > 0}}">
          <view class="account-item" wx:for="{{savedAccounts}}" wx:key="account" bindtap="selectAccount" data-index="{{index}}" hover-class="account-item-hover" hover-stay-time="100">
            <view class="account-avatar {{item.avatarEmoji ? 'avatar-emotion-' + (item.avatarEmojiEmotion || 'neutral') : ''}}">
              <text wx:if="{{item.avatarType === 'text'}}" class="avatar-text">{{item.avatarText || ((item.account && item.account.length > 0) ? item.account.charAt(0).toUpperCase() : 'U')}}</text>
              <text wx:else class="avatar-emoji">{{item.avatarEmoji || '😊'}}</text>
            </view>
            <view class="account-info">
              <text class="account-name">{{item.account}}</text>
            </view>
            <view class="account-actions">
              <view class="auto-restore-checkbox {{autoRestoreMap[item.account] ? 'checked' : ''}}" catchtap="toggleAutoRestore" data-account="{{item.account}}" hover-class="checkbox-hover" hover-stay-time="50">
                <text wx:if="{{autoRestoreMap[item.account]}}" class="checkmark">✓</text>
              </view>
              <view class="delete-btn" catchtap="deleteSavedAccount" data-account="{{item.account}}" hover-class="delete-hover" hover-stay-time="50">
                <text class="delete-icon">🗑️</text>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-state" wx:else>
          <text class="empty-icon">🔑</text>
          <text class="empty-text">暂无保存的账号</text>
          <text class="empty-hint">登录时选择"记住密码"可保存账号</text>
        </view>
      </view>
      
      <!-- 登录页面 -->
      <view class="user-page user-page-login" wx:if="{{currentUserPage === 'login'}}">
        <view class="form-card">
          <view class="form-group">
            <text class="form-label">账号</text>
            <input class="form-input" placeholder="请输入账号" value="{{cloudAccountInput}}" bindinput="onCloudAccountInput"></input>
          </view>
          <view class="form-group">
            <text class="form-label">密码</text>
            <view class="password-wrapper">
              <input class="form-input password-input" placeholder="请输入密码" value="{{cloudPasswordInput}}" bindinput="onCloudPasswordInput" password="{{!showCloudPassword}}"></input>
              <view class="password-toggle" bindtap="toggleCloudPasswordVisibility">
                <text class="toggle-text">{{showCloudPassword ? '隐藏' : '显示'}}</text>
              </view>
            </view>
          </view>
          <view class="form-group remember-password">
            <view class="checkbox-wrapper" bindtap="toggleRememberPassword">
              <view class="checkbox {{rememberPassword ? 'checked' : ''}}">
                <text class="checkbox-icon" wx:if="{{rememberPassword}}">✓</text>
              </view>
              <text class="checkbox-label">记住密码</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <!-- 主页面按钮 -->
      <view wx:if="{{currentUserPage === 'main'}}">
        <button class="modal-btn btn-delete-account" bindtap="switchUserPage" data-page="deleteAccount">删除账户</button>
        <button class="modal-btn btn-primary" bindtap="showSwitchAccountModal">切换账号</button>
        <button class="modal-btn btn-danger" bindtap="confirmLogout">退出登录</button>
      </view>
      
      <!-- 修改昵称页面按钮 -->
      <view wx:if="{{currentUserPage === 'updateNickname'}}">
        <button class="modal-btn btn-cancel" bindtap="goBackToUserManagement">取消</button>
        <button class="modal-btn btn-confirm" bindtap="confirmUpdateNickname">确定</button>
      </view>
      
      <!-- 修改密码页面按钮 -->
      <view wx:if="{{currentUserPage === 'updatePassword'}}">
        <button class="modal-btn btn-cancel" bindtap="goBackToUserManagement">取消</button>
        <button class="modal-btn btn-confirm" bindtap="confirmUpdatePassword">确定</button>
      </view>
      
      <!-- 删除账户页面按钮 -->
      <view wx:if="{{currentUserPage === 'deleteAccount'}}">
        <button class="modal-btn btn-cancel" bindtap="goBackToUserManagement">取消</button>
        <button class="modal-btn btn-delete-confirm" bindtap="confirmDeleteAccount">确认删除</button>
      </view>
      
      <!-- 表情选择页面按钮 -->
      <view wx:if="{{currentUserPage === 'avatar'}}">
        <button class="modal-btn btn-cancel" bindtap="goBackToUserManagement">取消</button>
        <button class="modal-btn btn-confirm" bindtap="onEmojiConfirm">确定</button>
      </view>
      
      <!-- 切换账号页面按钮 -->
      <view wx:if="{{currentUserPage === 'switchAccount'}}">
        <button class="modal-btn btn-cancel" bindtap="goBackToUserManagement">取消</button>
        <button class="modal-btn btn-confirm" bindtap="showCloudLoginModal">登录新账号</button>
      </view>
      
      <!-- 登录页面按钮 -->
      <view wx:if="{{currentUserPage === 'login'}}">
        <button class="modal-btn btn-cancel" bindtap="goBackToUserManagement">取消</button>
        <button class="modal-btn btn-confirm" bindtap="loginToCloud">登录</button>
      </view>
    </view>
  </view>


</view>
