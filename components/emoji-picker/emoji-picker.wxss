.emoji-picker-component {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.emoji-tabs-wrapper {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.emoji-tabs {
  display: flex;
  gap: 8rpx;
  overflow-x: auto;
  flex-shrink: 0;
  flex-wrap: nowrap;
  max-width: 100%;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.emoji-tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.2s ease;
  white-space: nowrap;
  min-width: 72rpx;
  background: #f8f9fa;
}

.emoji-tab-item.active {
  background: linear-gradient(135deg, #34d399, #10b981);
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.3);
}

.emoji-tab-hover {
  background: #e8f7ef !important;
  transform: scale(0.95) !important;
}

.emoji-tab-icon {
  font-size: 32rpx;
  line-height: 1;
}

.emoji-tab-name {
  font-size: 20rpx;
  color: #999999;
  line-height: 1;
  font-weight: 500;
}

.emoji-tab-item.active .emoji-tab-name {
  color: #fff;
}

.emoji-scroll {
  flex: 1;
  overflow-y: auto;
  min-height: 0;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #ffffff;
  margin: 0 24rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #f0f0f0;
}

.emoji-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8rpx;
  padding-bottom: 8rpx;
}

.emoji-item {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f9fa;
  border-radius: 12rpx;
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.emoji-item-hover {
  background: #e8f7ef !important;
  transform: scale(0.92) !important;
}

.emoji-item.selected {
  background: linear-gradient(135deg, #d1fae5, #ecfdf5);
  border-color: #34d399;
  box-shadow: 0 2rpx 8rpx rgba(52, 211, 153, 0.2);
}

.emoji-char {
  font-size: 40rpx;
  line-height: 1;
}

.emoji-preview {
  margin: 16rpx 24rpx 0;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
  border-radius: 16rpx;
  border: 1rpx solid #bbf7d0;
  flex-shrink: 0;
  box-sizing: border-box;
  opacity: 0.6;
  transition: all 0.3s ease;
}

.emoji-preview.show {
  opacity: 1;
  box-shadow: 0 4rpx 16rpx rgba(52, 211, 153, 0.15);
}

.preview-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.preview-emoji {
  font-size: 52rpx;
  line-height: 1;
  flex-shrink: 0;
}

.preview-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.preview-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  line-height: 1.3;
}

.preview-hint {
  font-size: 22rpx;
  color: #10b981;
  line-height: 1.3;
}

@media (max-width: 375px) {
  .emoji-grid {
    grid-template-columns: repeat(5, 1fr);
  }
}
