.color-picker-component {
  width: 100%;
}

.color-circles-container {
  padding: 6rpx 0;
}

.color-circles-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.color-circle-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
  position: relative;
  min-width: 0;
}

.color-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid #e8e8e8;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.color-circle-item:active .color-dot,
.color-circle-item:active .custom-color-entry {
  transform: scale(0.88);
}

.color-circle-item.active .color-dot,
.color-circle-item.active .custom-color-entry {
  border-color: #333;
  border-width: 4rpx;
  box-shadow: 0 0 0 4rpx rgba(0, 0, 0, 0.08), 0 2rpx 10rpx rgba(0, 0, 0, 0.18);
}

.custom-color-entry {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid #e8e8e8;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.custom-color-icon {
  font-size: 30rpx;
  font-weight: 700;
  color: #555;
  line-height: 1;
  position: relative;
  z-index: 1;
  text-shadow: 0 0 6rpx rgba(255,255,255,0.9);
}

.custom-color-overlay {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 0;
}

.color-circle-label {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  white-space: nowrap;
  line-height: 1.3;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.color-circle-item.active .color-circle-label {
  color: #333;
  font-weight: 600;
}

.label-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.color-indicator {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0,0,0,0.1);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.color-name-tag {
  font-size: 26rpx;
  font-weight: 600;
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(0,0,0,0.04);
  -webkit-font-smoothing: antialiased;
}

.color-picker-panel {
  margin-top: 12rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #f0f0f0;
}

.palette-container {
  margin-bottom: 14rpx;
}

.palette-area {
  position: relative;
  width: 100%;
  height: 220rpx;
  border-radius: 10rpx;
  overflow: hidden;
  cursor: pointer;
}

.palette-white {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to right, #fff 0%, transparent 100%);
  pointer-events: none;
}

.palette-black {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to top, #000 0%, transparent 100%);
  pointer-events: none;
}

.palette-cursor {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 0 8rpx rgba(0,0,0,0.6), inset 0 0 4rpx rgba(0,0,0,0.2);
  transform: translate(-50%, 50%);
  pointer-events: none;
  z-index: 5;
}

.hue-slider-container {
  margin-top: 14rpx;
}

.hue-slider {
  position: relative;
  width: 100%;
  height: 36rpx;
  border-radius: 18rpx;
  background: linear-gradient(to right, #ff0000 0%, #ffff00 16%, #00ff00 33%, #00ffff 50%, #0000ff 67%, #ff00ff 83%, #ff0000 100%);
  cursor: pointer;
  box-shadow: inset 0 1rpx 4rpx rgba(0,0,0,0.1);
}

.hue-slider-thumb {
  position: absolute;
  top: 50%;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 0 8rpx rgba(0,0,0,0.45);
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 2;
}

.picker-preview-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
  padding: 0 4rpx;
}

.picker-preview {
  width: 60rpx;
  height: 48rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e8e8e8;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  flex-shrink: 0;
}

.picker-hex-value {
  font-size: 28rpx;
  color: #555;
  font-family: 'Courier New', 'Consolas', monospace;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.picker-actions {
  display: flex;
  gap: 16rpx;
}

.picker-cancel-btn, .picker-confirm-btn {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  font-size: 26rpx;
  border-radius: 34rpx;
  font-weight: 500;
  border: none;
  transition: all 0.2s ease;
}

.picker-cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.picker-cancel-btn:active {
  background: #e8e8e8;
  transform: scale(0.96);
}

.picker-confirm-btn {
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  color: #fff;
  box-shadow: 0 2rpx 10rpx rgba(16, 185, 129, 0.35);
}

.picker-confirm-btn:active {
  opacity: 0.9;
  transform: scale(0.96);
}
