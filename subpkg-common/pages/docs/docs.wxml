<!-- subpkg-common/pages/docs/docs.wxml -->
<view class="container">
  <!-- 页面标题区 -->
  <view class="page-header">
    <view class="header-content">
      <text class="header-title">📖 使用说明</text>
      <text class="header-subtitle">快速了解排班助手功能</text>
    </view>
  </view>

  <view class="content">
    <!-- 使用方法 -->
    <view class="section about-section {{activeSection === 'about' ? 'highlight' : ''}}" id="section-about">
      <view class="section-header">
        <view class="section-icon-wrapper about-icon">
          <text class="section-icon">📖</text>
        </view>
        <view class="section-title-wrapper">
          <text class="section-title">使用方法</text>
          <text class="section-desc">快速上手排班助手</text>
        </view>
      </view>
      <view class="section-content">
        <view class="guide-list">
          <view class="guide-item">
            <view class="guide-badge">1</view>
            <view class="guide-body">
              <text class="guide-title">添加班次模板</text>
              <text class="guide-text">
                - 进入计划页面，点击添加班次模板
                - 输入班次名称、选择班次类型
                - 通过颜色条选择器自定义班次颜色
                - 设置开始时间和结束时间
                - 精确设置工时（小时+分钟）
                - 点击保存，排班就可以使用这个模板
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">不同班次可以设置不同颜色，便于快速区分；工时支持精确到分钟设置</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">2</view>
            <view class="guide-body">
              <text class="guide-title">创建排班表</text>
              <text class="guide-text">
                - 可在周视图和月视图之间切换查看
                - 点击"回到今天"快速切换到当前日期
                - 点击日期单元格
                - 从弹出的班次列表中选择对应班次
                - 可添加自定义标签标记特殊排班
                - 点击确定完成排班
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">修改排班：点击已有排班可快速替换；删除排班：长按日期可删除；周/月视图顶部会显示工时统计进度条</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">3</view>
            <view class="guide-body">
              <text class="guide-title">添加排班图片</text>
              <text class="guide-text">
                - 在周视图页面的"本周排班图片"卡片中
                - 点击"添加图片"按钮
                - 选择图片并输入名称
                - 即可上传排班照片并一直保留且保留在对应星期
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">支持从相册或相机拍摄选择图片，方便记录纸质排班表</text>
              </view>
            </view>
          </view>

        </view>
      </view>
    </view>

    <!-- 统计页面使用说明 -->
    <view class="section {{activeSection === 'statistics' ? 'highlight' : ''}}" id="section-statistics">
      <view class="section-header">
        <view class="section-icon-wrapper stats-icon">
          <text class="section-icon">📈</text>
        </view>
        <view class="section-title-wrapper">
          <text class="section-title">统计页面使用说明</text>
          <text class="section-desc">生成与分享排班报表</text>
        </view>
      </view>
      <view class="section-content">
        <view class="guide-list">
          <view class="guide-item">
            <view class="guide-badge">1</view>
            <view class="guide-body">
              <text class="guide-title">排班统计图</text>
              <text class="guide-text">
                - 在统计页面选择日期范围
                - 即可查看选定期间内的所有排班详情
                - 包括总工时、班次分布，工时差额等
                - 工时统计里的设置按钮⚙️可以设置自定义每周标准工时
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">可按月份、季度或自定义时间范围查询，默认的标准工时是每周35小时</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">2</view>
            <view class="guide-body">
              <text class="guide-title">导出与分享报表</text>
              <text class="guide-text">
                - 点击导出报表
                - 在弹窗中输入文件名（可按姓名+日期范围）
                - 出现导出成功提示后，点击分享报表
                - 可以分享给自己或好友
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">在聊天界面点击CSV，选择用WPS打开，即可生成报表！</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">3</view>
            <view class="guide-body">
              <text class="guide-title">排班详情展示</text>
              <text class="guide-text">
                - 查询后，页面下方会显示选定日期内的所有排班详情
                - 包括每天的班次、工时等信息
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">可滑动查看完整的排班详情列表</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 云备份使用说明 -->
    <view class="section {{activeSection === 'cloud' ? 'highlight' : ''}}" id="section-cloud">
      <view class="section-header">
        <view class="section-icon-wrapper webdav-icon">
          <text class="section-icon">☁️</text>
        </view>
        <view class="section-title-wrapper">
          <text class="section-title">云备份使用说明</text>
          <text class="section-desc">多设备数据同步与备份</text>
        </view>
      </view>
      <view class="section-content">
        <view class="guide-list">
          <view class="guide-item">
            <view class="guide-badge">1</view>
            <view class="guide-body">
              <text class="guide-title">开启云备份</text>
              <text class="guide-text">
                - 在首页或个人中心找到云备份板块，点击进入
                - 首次使用需要注册账号，已有账号直接登录
                - 注册时需填写账号、密码，可选择填写昵称
                - 昵称将显示在头像旁边，便于识别
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">建议使用复杂账号密码，请妥善保管好。</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">2</view>
            <view class="guide-body">
              <text class="guide-title">账号管理</text>
              <text class="guide-text">
                - 注册后会自动登录，弹出用户管理界面
                - 点击头像或昵称也可以打开用户管理界面
                - 在用户管理界面可以：
                - 退出账号：安全退出当前登录
                - 修改昵称：更新显示名称
                - 修改密码：定期更新密码确保安全
                - 删除账号：谨慎操作，删除后数据无法恢复
              </text>
              <view class="guide-tip warning-tip">
                <text class="tip-icon">⚠️</text>
                <text class="tip-text">若是共享账号，删除操作会影响所有使用该账号的用户，请谨慎操作！</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">3</view>
            <view class="guide-body">
              <text class="guide-title">多设备使用</text>
              <text class="guide-text">
                - 在其他设备上打开此小程序，登录同一账号
                - 登录后可手动同步所有数据，包括排班、模板和图片
                - 数据同步流程：
                - 账号主：在本地填写好数据后，点击"备份到云端"
                - 共享人：在其他设备上登录同一账号，点击"恢复"，将数据恢复到本地
                - 所有设备的数据将保持一致
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">建议定期备份数据，确保重要信息不会丢失</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">4</view>
            <view class="guide-body">
              <text class="guide-title">数据安全</text>
              <text class="guide-text">
                - 云备份数据采用微信云存储，保障数据安全
                - 请妥善保管账号密码，不要分享给陌生人
                - 定期修改密码，增强账号安全性
                - 若账号密码丢失，目前无法找回！
              </text>
              <view class="guide-tip warning-tip">
                <text class="tip-icon">⚠️</text>
                <text class="tip-text">请勿使用简单密码，建议包含字母、数字和特殊字符</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">5</view>
            <view class="guide-body">
              <text class="guide-title">常见问题</text>
              <text class="guide-text">
                - 备份失败：请检查网络连接，确保网络畅通
                - 恢复失败：请检查账号权限和网络连接
                - 数据不同步：尝试重新登录账号后再次同步
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">如果遇到其他问题，请联系开发者获取帮助</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 数据管理使用说明 -->
    <view class="section {{activeSection === 'data' ? 'highlight' : ''}}" id="section-data">
      <view class="section-header">
        <view class="section-icon-wrapper data-icon">
          <text class="section-icon">📊</text>
        </view>
        <view class="section-title-wrapper">
          <text class="section-title">数据管理使用说明</text>
          <text class="section-desc">备份、分享与恢复数据</text>
        </view>
      </view>
      <view class="section-content">
        <view class="guide-list">
          <view class="guide-item">
            <view class="guide-badge">1</view>
            <view class="guide-body">
              <text class="guide-title">导出数据</text>
              <text class="guide-text">
                - 点击导出数据
                - 在弹窗中输入自定义文件名后点击确定
                - 可暂存数据文件到剪贴板
                - 当选了图片之后，导出为zip
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">可自选需要导出的数据：排班数据、班次模板、排班图片</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">2</view>
            <view class="guide-body">
              <text class="guide-title">分享数据</text>
              <text class="guide-text">
                - 导出后可快速分享给好友
                - 也可以分享到"文件传输助手"或者小号，用来备份
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">分享完整的数据备份，这个导出后的json或者zip文件是暂存的，暂存时间很短，请尽快分享数据。</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">3</view>
            <view class="guide-body">
              <text class="guide-title">导入数据</text>
              <text class="guide-text">
                - 选择好友通过微信分享给你的json文件，或者zip文件
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">可以将json文件或者zip转发给"文件传输助手"，点击导入，选择"文件传输助手"，找到对应的文件，即可替换本地的模板、排班、图片等</text>
              </view>
            </view>
          </view>

          <view class="guide-item warning">
            <view class="guide-badge">4</view>
            <view class="guide-body">
              <text class="guide-title">清空数据</text>
              <text class="guide-text">
                - 清空请谨慎操作
                - 但也可以通过每周导出的备份来进行恢复
              </text>
              <view class="guide-tip warning-tip">
                <text class="tip-icon">⚠️</text>
                <text class="tip-text">清空所有数据，如要恢复，请导入之前分享出去的json或zip文件！</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 个人中心使用说明 -->
    <view class="section {{activeSection === 'profile' ? 'highlight' : ''}}" id="section-profile">
      <view class="section-header">
        <view class="section-icon-wrapper profile-icon">
          <text class="section-icon">👤</text>
        </view>
        <view class="section-title-wrapper">
          <text class="section-title">个人中心使用说明</text>
          <text class="section-desc">管理个人信息与功能</text>
        </view>
      </view>
      <view class="section-content">
        <view class="guide-list">
          <view class="guide-item">
            <view class="guide-badge">1</view>
            <view class="guide-body">
              <text class="guide-title">表情头像设置</text>
              <text class="guide-text">
                - 点击头像或昵称进入用户管理
                - 选择"头像"进入表情选择页面
                - 按情绪分类浏览各种表情
                - 选择喜欢的表情作为头像
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">表情头像会同步到云端，在多设备间保持一致</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">2</view>
            <view class="guide-body">
              <text class="guide-title">用户管理功能</text>
              <text class="guide-text">
                - 修改昵称：更新显示名称
                - 修改密码：定期更新密码确保安全
                - 切换账号：快速登录已保存的其他账号
                - 删除账户：谨慎操作，删除后数据无法恢复
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">登录时可选择"记住密码"，方便下次快速切换账号；切换账号时可选择是否自动恢复云端数据</text>
              </view>
            </view>
          </view>

          <view class="guide-item">
            <view class="guide-badge">3</view>
            <view class="guide-body">
              <text class="guide-title">联系与支持</text>
              <text class="guide-text">
                - 点击"联系乐乐"通过微信客服咨询问题
                - 点击"捐赠支持"支持公益项目发展
                - 查看"更新日志"了解版本更新内容
              </text>
              <view class="guide-tip">
                <text class="tip-icon">💡</text>
                <text class="tip-text">如有任何问题或建议，欢迎随时联系反馈</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部导航栏 - 微信小程序官方样式 -->
  <view class="bottom-nav">
    <view class="nav-tabs">
      <view class="nav-tab {{activeSection === 'about' ? 'active' : ''}}" bindtap="scrollToSection" data-id="section-about">
        <text class="nav-tab-icon">📖</text>
        <text class="nav-tab-label">使用方法</text>
      </view>
      <view class="nav-tab {{activeSection === 'statistics' ? 'active' : ''}}" bindtap="scrollToSection" data-id="section-statistics">
        <text class="nav-tab-icon">📈</text>
        <text class="nav-tab-label">统计报表</text>
      </view>
      <view class="nav-tab {{activeSection === 'cloud' ? 'active' : ''}}" bindtap="scrollToSection" data-id="section-cloud">
        <text class="nav-tab-icon">☁️</text>
        <text class="nav-tab-label">云备份</text>
      </view>
      <view class="nav-tab {{activeSection === 'data' ? 'active' : ''}}" bindtap="scrollToSection" data-id="section-data">
        <text class="nav-tab-icon">📊</text>
        <text class="nav-tab-label">数据管理</text>
      </view>
      <view class="nav-tab {{activeSection === 'profile' ? 'active' : ''}}" bindtap="scrollToSection" data-id="section-profile">
        <text class="nav-tab-icon">👤</text>
        <text class="nav-tab-label">个人中心</text>
      </view>
    </view>
  </view>


</view>
