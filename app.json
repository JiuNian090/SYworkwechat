{
  "lazyCodeLoading": "requiredComponents",
  "pages": [
    "pages/plan/plan",
    "pages/schedule/schedule",
    "pages/statistics/statistics",
    "pages/profile/profile"
  ],
  "subpackages": [
    {
      "root": "subpkg-common",
      "name": "common",
      "pages": [
        "pages/docs/docs"
      ]
    }
  ],
  "preloadRule": {
    "pages/profile/profile": {
      "network": "all",
      "packages": ["common"]
    },
    "pages/statistics/statistics": {
      "network": "all",
      "packages": ["common"]
    }
  },
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#fff",
    "navigationBarTitleText": "SYwork",
    "navigationBarTextStyle": "black"
  },
  "tabBar": {
    "color": "#000000",
    "selectedColor": "#07C160",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "position": "bottom",
    "list": [
      {
        "pagePath": "pages/plan/plan",
        "text": "计划",
        "iconPath": "images/list-add.png",
        "selectedIconPath": "images/list-add-1.png"
      },
      {
        "pagePath": "pages/schedule/schedule",
        "text": "排班",
        "iconPath": "images/schedule.png",
        "selectedIconPath": "images/schedule-1.png"
      },
      {
        "pagePath": "pages/statistics/statistics",
        "text": "统计",
        "iconPath": "images/status.png",
        "selectedIconPath": "images/status-1.png"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的",
        "iconPath": "images/me.png",
        "selectedIconPath": "images/me-1.png"
      }
    ]
  }
}
